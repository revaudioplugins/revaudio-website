---
import type { AudioDemo as Demo } from '../data/plugins';

interface Props {
  demo: Demo;
}

const { demo } = Astro.props;
const hasAudio = !!(demo.beforeUrl && demo.afterUrl);
---

<div class="ab" data-demo>
  <div class="ab-head">
    <h4>{demo.label}</h4>
    {demo.description && <p class="muted">{demo.description}</p>}
  </div>

  {hasAudio ? (
    <div class="ab-players">
      <div class="player">
        <span class="tag" aria-hidden="true">Before</span>
        <audio controls preload="none" src={demo.beforeUrl ?? undefined} aria-label={`Before: ${demo.label}`}></audio>
      </div>
      <div class="player after">
        <span class="tag" aria-hidden="true">After</span>
        <audio controls preload="none" src={demo.afterUrl ?? undefined} aria-label={`After: ${demo.label}`}></audio>
      </div>
    </div>
  ) : (
    <div class="placeholder">[ Before / After audio &mdash; bouncing soon ]</div>
  )}
</div>

<style>
  .ab {
    background: var(--bg-1);
    border: 1px solid var(--border);
    padding: 1.25rem 1.5rem;
    margin-bottom: 1rem;
  }

  .ab-head h4 {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--brass);
    margin: 0 0 0.5rem;
  }

  .ab-head p {
    font-size: 0.85rem;
    margin: 0 0 1rem;
  }

  .ab-players {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  @media (max-width: 600px) {
    .ab-players { grid-template-columns: 1fr; }
  }

  .player {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    padding: 0.75rem;
    background: var(--bg-0);
    border: 1px solid var(--border);
  }

  .player.after {
    border-color: var(--brass-dark);
    box-shadow: 0 0 0 1px rgba(232, 200, 120, 0.08) inset;
  }

  .tag {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--fg-faint);
  }

  .player.after .tag { color: var(--brass-bright); }

  audio {
    width: 100%;
    height: 32px;
  }

  .placeholder {
    height: 60px;
    background: var(--bg-2);
    border: 1px dashed var(--border-bright);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--fg-faint);
    font-family: var(--font-mono);
    font-size: 0.8rem;
  }
</style>
