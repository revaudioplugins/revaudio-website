---
import { Image } from 'astro:assets';
import type { Plugin } from '../data/plugins';
import { fmtPrice, discountPct, isBuyable } from '../data/plugins';
import { pluginImage } from '../lib/images';
import StarRating from './StarRating.astro';

interface Props {
  plugin: Plugin;
  cta?: string;
  /** Store grid: show an inline "Add to cart" button beside the CTA (buyable only). */
  showCart?: boolean;
}

const { plugin, cta, showCart = false } = Astro.props;
const buyable = isBuyable(plugin);
const pct = discountPct(plugin);
const thumb = pluginImage(plugin.heroImage);
// The "coming soon" plate is a true-alpha graphic, not a screenshot — float it
// frameless on the card instead of letterboxing it in the dark screenshot box
// (which left black bars either side of the narrower plate).
const isPlate = plugin.heroImage === 'coming-soon-plate.png';
---

<div class="plugin-card-wrap">
<a class="plugin-card" href={`/${plugin.slug}`} data-reveal="card">
  <div class:list={['card-thumb', { 'is-plate': isPlate }]}>
    {thumb ? (
      <Image src={thumb} alt={plugin.name} width={1600} format="webp" quality={92} loading="lazy" />
    ) : (
      <span class="thumb-placeholder">{plugin.name}</span>
    )}
  </div>
  <h3>{plugin.name}</h3>
  <p class="one-liner">{plugin.oneLiner}</p>
  <StarRating rating={plugin.reviewsAvg} count={plugin.reviewsCount} scale={0.9} />
  <div class="prices" data-reveal-accent>
    {buyable ? (
      pct != null ? (
        <>
          <span class="now">{fmtPrice(plugin.introPriceUsd)}</span>
          <span class="was">{fmtPrice(plugin.regularPriceUsd)}</span>
          <span class="pct">&minus;{pct}% launch sale</span>
          {plugin.promoCode && <span class="promo-hint">code {plugin.promoCode}</span>}
        </>
      ) : (
        <span class="now">{fmtPrice(plugin.introPriceUsd)}</span>
      )
    ) : plugin.status === 'beta' ? (
      <>
        <span class="now muted-now">{fmtPrice(plugin.introPriceUsd)}</span>
        <span class="hint muted">Launch price &middot; subscribe for it</span>
      </>
    ) : (
      <span class="hint muted">Target {plugin.releaseTarget}</span>
    )}
  </div>
  <span class="more">{cta ?? (buyable ? 'View & buy' : plugin.status === 'in-development' ? 'Learn more' : 'Subscribe')} &rarr;</span>
</a>
{showCart && buyable && (
  <button
    type="button"
    class="card-add"
    data-add-to-cart
    data-slug={plugin.slug}
    data-name={plugin.name}
    data-price={plugin.regularPriceUsd ?? plugin.introPriceUsd}
    data-checkout-url={plugin.checkoutUrl}
  >Add to cart</button>
)}
</div>

<style>
  .plugin-card-wrap { position: relative; }

  /* Store grid: simple inline Add-to-cart button, sat in the footer row to the
     right of the card CTA. A sibling of the card <a> (never nested in it). */
  .card-add {
    position: absolute;
    right: 1.5rem;
    bottom: 1.4rem;
    z-index: 2;
    font-family: var(--font-display);
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--bg-0);
    background: var(--brass);
    border: 1px solid var(--brass-dark);
    border-radius: 4px;
    padding: 0.45rem 0.8rem;
    cursor: pointer;
    transition: background 0.2s var(--ease), transform 0.15s var(--ease);
  }
  .card-add:hover { background: var(--brass-bright); }
  .card-add:active { transform: scale(0.96); }

  .plugin-card {
    background: var(--bg-1);
    border: 1px solid var(--border);
    padding: 1.5rem;
    transition: border-color 0.2s var(--ease), transform 0.2s var(--ease);
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    color: inherit;
    position: relative;
  }

  .plugin-card:hover {
    border-color: var(--brass-dark);
    transform: translateY(-2px);
  }

  .status {
    position: absolute;
    top: 1rem;
    right: 1rem;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    color: var(--fg-faint);
    text-transform: uppercase;
  }
  .status.live { color: var(--emerald); }
  .status.beta { color: var(--brass); }
  .status.dev { color: var(--oxide); }

  .card-thumb {
    aspect-ratio: 2542 / 1226;
    background: #080808;
    border: 1px solid var(--border);
    border-radius: 10px;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .card-thumb img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
  }

  /* Coming-soon plate: drop the dark screenshot frame so the plate floats on the
     card surface (no black side bars), and give the thumb the plate's OWN aspect
     ratio so the whole plate shows — no side bars, no top/bottom crop. */
  .card-thumb.is-plate {
    aspect-ratio: 1555 / 1060;
    background: none;
    border: 0;
    border-radius: 0;
    overflow: visible;
  }
  .card-thumb.is-plate img {
    filter: drop-shadow(0 7px 16px rgba(0, 0, 0, 0.55));
  }

  .thumb-placeholder {
    font-family: var(--font-display);
    letter-spacing: 0.1em;
    color: var(--fg-faint);
    font-size: 1.4rem;
  }

  h3 {
    font-size: 1.75rem;
    margin: 0;
    color: var(--brass-bright);
    text-align: center;
  }

  .one-liner {
    font-size: 0.9rem;
    color: var(--fg-dim);
    margin: 0;
    text-align: center;
  }

  .prices {
    display: flex;
    align-items: baseline;
    gap: 0.6rem;
    flex-wrap: wrap;
    margin-top: auto;
  }

  .now {
    font-family: var(--font-display);
    font-size: 1.5rem;
    color: var(--brass-bright);
    letter-spacing: 0.04em;
  }

  .now.muted-now { color: var(--fg-dim); }

  .was {
    font-family: var(--font-display);
    font-size: 1.425rem;
    color: var(--fg-faint);
    text-decoration: line-through;
    margin-left: -7px;
  }

  .pct {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--oxide-text);
    border: 1px solid var(--oxide);
    padding: 0.1rem 0.4rem;
  }

  .promo-hint {
    width: 100%;
    font-family: var(--font-mono);
    font-size: 0.82rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--brass);
  }

  .hint { font-size: 0.85rem; }

  .more {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--fg);
    margin-top: 0.5rem;
  }
</style>
