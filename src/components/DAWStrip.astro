---
import { daws } from '../data/daws';
import cubaseMark from '../assets/daws/cubase.svg';
import abletonMark from '../assets/daws/ableton.svg';
import flMark from '../assets/daws/fl-studio.svg';
import proToolsMark from '../assets/daws/pro-tools.svg';

interface Props {
  heading?: string;
}

const { heading = 'Tested in your DAW' } = Astro.props;

// Mobile-only brand marks. Desktop keeps the original text chips untouched
// (these marks are hidden above 900px). Only DAWs with a genuine, sourceable
// official mark get one — the rest stay name-only, set in the display face.
// No fabricated logos.
const marks: Record<string, ImageMetadata | undefined> = {
  ableton: abletonMark,
  'pro-tools': proToolsMark,
  cubase: cubaseMark,
  'fl-studio': flMark,
};
// Wordmark logos already spell the product name — suppress the text label
// under those on mobile so the chip doesn't read "CUBASE / CUBASE".
const wordmarks = new Set(['cubase', 'fl-studio']);
---

<section class="daw-strip">
  <div class="container">
    <h2 class="center">{heading}</h2>
    <ul class="daws" data-drift="4">
      {daws.map((d) => {
        const mark = marks[d.slug];
        return (
          <li class:list={[d.tested ? 'tested' : 'planned', mark ? 'has-mark' : 'text-only', { 'is-wordmark': wordmarks.has(d.slug) }]}>
            {mark && (
              <span class="daw-mark" style={`--mark:url(${mark.src})`} aria-hidden="true"></span>
            )}
            <span class="text">{d.name}</span>
          </li>
        );
      })}
    </ul>
    <p class="muted center note">
      Built and verified on the marked DAWs as of the current build.
    </p>
  </div>
</section>

<style>
  .daw-strip {
    padding: 2.5rem 0;
    border-top: 1px solid var(--border);
    overflow-x: clip; /* the data-drift scrub pushes the strip past the edge by design */
  }

  .daw-strip h2 {
    color: var(--fg-dim);
    margin-bottom: 2rem;
  }

  .daws {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 1rem 1.25rem;
  }

  .daws li {
    padding: 0.5rem 1rem;
    border: 1px solid var(--border);
    color: var(--fg-dim);
    font-family: var(--font-display);
    letter-spacing: 0.1em;
    font-size: 1.05rem;
    text-transform: uppercase;
    transition: color 0.2s, border-color 0.2s;
  }

  .daws li.tested {
    color: var(--fg);
    border-color: var(--border-bright);
  }

  .daws li.planned {
    color: var(--fg-faint);
    border-style: dashed;
  }

  /* Desktop keeps text-only chips: hide the mobile brand marks above 900px. */
  .daw-mark {
    display: none;
  }

  .note {
    margin: 2rem auto 0;
    font-size: 0.85rem;
    text-align: center;
  }

  /* ---- Mobile (≤900px): real brand marks + a classy 3D garage-stage bg ----
     Desktop (>900px) is untouched — every rule below is behind this gate. */
  @media (max-width: 900px) {
    .daw-strip {
      position: relative;
      isolation: isolate; /* keep the stage layers behind, chips above */
      padding: 3rem 0 3.25rem;
    }

    /* Perspective floor grid receding into the brown-black — pure CSS 3D. */
    .daw-strip::before {
      content: '';
      position: absolute;
      left: -25%;
      right: -25%;
      bottom: 0;
      height: 78%;
      background:
        repeating-linear-gradient(90deg, transparent 0 47px, rgba(201, 163, 92, 0.16) 47px 48px),
        repeating-linear-gradient(0deg, transparent 0 47px, rgba(201, 163, 92, 0.12) 47px 48px);
      transform: perspective(300px) rotateX(64deg);
      transform-origin: bottom center;
      -webkit-mask-image: linear-gradient(to top, #000 0%, rgba(0, 0, 0, 0.45) 42%, transparent 78%);
      mask-image: linear-gradient(to top, #000 0%, rgba(0, 0, 0, 0.45) 42%, transparent 78%);
      z-index: -2;
      pointer-events: none;
    }

    /* Warm radial glow behind the chips + a faint top edge highlight. */
    .daw-strip::after {
      content: '';
      position: absolute;
      inset: 0;
      background:
        radial-gradient(90% 62% at 50% 34%, rgba(200, 51, 31, 0.12), transparent 60%),
        linear-gradient(to bottom, rgba(232, 200, 120, 0.14), transparent 3px);
      z-index: -1;
      pointer-events: none;
    }

    .container {
      position: relative;
      z-index: 1;
    }

    .daws {
      gap: 0.85rem 0.9rem;
    }

    .daws li {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 0.5rem;
      min-width: 6.25rem;
      min-height: 3.4rem;
      padding: 0.7rem 0.9rem;
      border-radius: 3px;
      /* brushed-metal plate sitting on the stage */
      background: linear-gradient(180deg, rgba(42, 36, 32, 0.55), rgba(11, 10, 9, 0.6));
      border-color: var(--border);
      box-shadow: inset 0 1px 0 rgba(232, 200, 120, 0.08), 0 6px 16px rgba(0, 0, 0, 0.45);
    }

    .daws li.tested {
      border-color: var(--border-bright);
    }

    /* One family: every mark rendered as a single warm-brass silhouette,
       so the row reads as one set rather than seven brand colors. */
    .daw-mark {
      display: block;
      width: 5.4rem;
      height: 1.35rem;
      background-color: var(--brass-bright);
      -webkit-mask: var(--mark) center / contain no-repeat;
      mask: var(--mark) center / contain no-repeat;
    }

    .has-mark .text {
      font-family: 'VT323', var(--font-mono);
      font-size: 0.9rem;
      letter-spacing: 0.12em;
      line-height: 1;
      color: var(--fg-dim);
    }

    /* Wordmark logos already spell the name — no duplicate label under them.
       (The name stays in the DOM for screen readers / desktop chips.) */
    .is-wordmark .text {
      position: absolute;
      width: 1px;
      height: 1px;
      overflow: hidden;
      clip-path: inset(50%);
    }
    .is-wordmark .daw-mark { width: 108px; height: 30px; }

    /* DAWs without a sourceable official mark — name set in the display face,
       tinted into the same brass family. Honest: a name label, not a logo. */
    .text-only .text {
      font-family: var(--font-display);
      font-size: 1.15rem;
      letter-spacing: 0.08em;
      color: var(--brass-bright);
    }

    /* Optional slow idle drift of the floor — static under reduced motion. */
    @media (prefers-reduced-motion: no-preference) {
      .daw-strip::before {
        animation: daw-floor-drift 26s linear infinite;
      }
    }
  }

  @keyframes daw-floor-drift {
    from { background-position: 0 0, 0 0; }
    to { background-position: 0 48px, 0 48px; }
  }
</style>
