---
/**
 * MobileBuyBar — sticky bottom buy bar for product pages (≤900px only).
 *
 * Gives the phone a BUY NOW control in the first viewport (the crane door is
 * ~2 screens down). Live text (not the image-plate pattern), token-styled so it
 * inherits high-contrast mode. Hides only while the real buy card (the aside)
 * is on screen, so the two never compete. Cart dedupes by slug and the LS
 * checkout applies VROOM, so data-price is the REGULAR price ($93) to match the
 * crane + PluginCard buttons; $56 is display-only until VROOM is typed.
 */
import type { Plugin } from '../data/plugins';
import { fmtPrice, discountPct } from '../data/plugins';

interface Props {
  plugin: Plugin;
}

const { plugin } = Astro.props;
const pct = discountPct(plugin);
const cartPrice = plugin.regularPriceUsd ?? plugin.introPriceUsd;
---

<div class="mbb" data-mobile-buybar>
  <div class="mbb-price">
    <span class="mbb-row1">
      <span class="mbb-now">{fmtPrice(plugin.introPriceUsd)}</span>
      {plugin.regularPriceUsd != null && <s class="mbb-was">{fmtPrice(plugin.regularPriceUsd)}</s>}
      {pct != null && <span class="mbb-pct">&minus;{pct}%</span>}
    </span>
    {plugin.promoCode && <span class="mbb-code">code {plugin.promoCode} at checkout</span>}
  </div>
  <button type="button" class="mbb-buy" data-add-to-cart
    data-slug={plugin.slug} data-name={plugin.name} data-price={cartPrice}
    data-checkout-url={plugin.checkoutUrl}
    aria-label={`Add ${plugin.name} to cart — ${fmtPrice(cartPrice)}`}>BUY NOW</button>
</div>

<style>
  :global(:root) { --mbb-h: 64px; }
  .mbb {
    position: fixed; left: 0; right: 0; bottom: 0; z-index: 40;
    display: none; align-items: center; justify-content: space-between; gap: 0.75rem;
    min-height: var(--mbb-h);
    padding: 0.5rem max(1rem, env(safe-area-inset-right))
             calc(0.5rem + env(safe-area-inset-bottom)) max(1rem, env(safe-area-inset-left));
    background: var(--bg-1); border-top: 1px solid var(--brass-dark);
    box-shadow: 0 -8px 30px rgba(0, 0, 0, 0.5);
    transition: transform 0.28s var(--ease-settle), visibility 0s 0s; will-change: transform;
  }
  .mbb.is-away { transform: translateY(105%); visibility: hidden;
    transition: transform 0.24s var(--ease-exit), visibility 0s 0.24s; }
  @media (prefers-reduced-motion: reduce) { .mbb, .mbb.is-away { transition: none; } }
  /* cookie banner (z9000) owns the bottom edge while visible */
  :global(body:has(#cookie-banner.cb--visible)) .mbb { transform: translateY(105%); visibility: hidden; }
  @media (max-width: 900px) {
    .mbb { display: flex; }
    /* Doubled class + descendant out-specifies A11yToggle's own scoped
       `.a11y-fab[data-astro-cid]` (0,2,0) rule, which otherwise pins bottom:16px. */
    :global(body .a11y-fab.a11y-fab) { bottom: calc(16px + var(--mbb-h) + env(safe-area-inset-bottom, 0px)); }
    :global(.site-footer) { margin-bottom: calc(var(--mbb-h) + env(safe-area-inset-bottom, 0px)); }
    :global(html) { scroll-padding-bottom: calc(var(--mbb-h) + 16px); }
  }

  .mbb-price { display: flex; flex-direction: column; gap: 0.15rem; min-width: 0; }
  .mbb-row1 { display: flex; align-items: baseline; gap: 0.5rem; flex-wrap: wrap; }
  .mbb-now { font-family: var(--font-display); font-size: 1.6rem; line-height: 1; color: var(--brass-bright); }
  .mbb-was { font-size: 0.9rem; color: var(--fg-faint); }
  .mbb-pct, .mbb-code { font-family: var(--font-mono); color: var(--brass); }
  .mbb-pct { font-size: 0.68rem; letter-spacing: 0.06em; }
  .mbb-code { font-size: 0.75rem; letter-spacing: 0.04em; color: var(--fg-faint); }
  .mbb-buy { flex: none; min-height: 48px; padding: 0 1.7rem;
    font-family: var(--font-display); font-size: 1.35rem; letter-spacing: 0.08em;
    color: #0a0908; background: var(--brass); border: 1px solid var(--brass-bright);
    border-radius: 6px; cursor: pointer; }
  .mbb-buy:active { transform: scale(0.97); }
</style>

<script>
  const bar = document.querySelector('[data-mobile-buybar]');
  const target = document.querySelector('[data-buy-aside]');
  if (bar && target) {
    const set = (away: boolean) => bar.classList.toggle('is-away', away);
    const io = new IntersectionObserver(
      (entries) => set(entries.some((e) => e.isIntersecting)),
      { rootMargin: '0px 0px -25% 0px', threshold: 0 });
    io.observe(target);
    window.addEventListener('pageshow', (e) => {   // Safari bfcache backstop (house pattern)
      if (!e.persisted) return;
      const r = target.getBoundingClientRect();
      set(r.top < window.innerHeight * 0.75 && r.bottom > 0);
    });
  }
</script>
