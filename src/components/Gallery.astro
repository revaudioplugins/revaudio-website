---
import { Image } from 'astro:assets';
import { pluginImage } from '../lib/images';

interface Props {
  /** primary image (hero) — filename in src/assets/plugins; placeholder block if unresolved */
  hero: string | null;
  /** thumbnail strip; click to swap into hero. Same item appearing in hero is fine. */
  images?: string[];
  alt: string;
}

const { hero, images = [], alt } = Astro.props;
const seen = new Set<string>();
const all = [hero, ...images]
  .map(pluginImage)
  .filter((m): m is NonNullable<typeof m> => !!m && !seen.has(m.src) && !!seen.add(m.src));
const hasAny = all.length > 0;
---

<div class="gallery">
  {hasAny ? (
    <>
      <div class="hero-frame" data-gallery-hero>
        <Image src={all[0]} alt={alt} width={1200} format="webp" loading="eager" />
      </div>
      {all.length > 1 && (
        <div class="thumbs">
          {all.map((src, i) => (
            <button
              class={`thumb ${i === 0 ? 'active' : ''}`}
              data-gallery-thumb
              data-src={src.src}
              type="button"
              aria-label={`Show image ${i + 1} of ${all.length}`}
              aria-pressed={i === 0 ? 'true' : 'false'}
            >
              <Image src={src} alt="" width={320} height={180} format="webp" loading="lazy" />
            </button>
          ))}
        </div>
      )}
    </>
  ) : (
    <div class="hero-frame placeholder">
      <span>[ Plugin screenshot &mdash; coming soon ]</span>
    </div>
  )}
</div>

<script>
  document.querySelectorAll('[data-gallery-hero]').forEach((heroEl) => {
    const root = heroEl.closest('.gallery');
    if (!root) return;
    const img = heroEl.querySelector('img');
    const thumbs = root.querySelectorAll<HTMLButtonElement>('[data-gallery-thumb]');
    thumbs.forEach((t) => {
      t.addEventListener('click', () => {
        const src = t.dataset.src;
        if (img && src) img.src = src;
        thumbs.forEach((other) => {
          const isActive = other === t;
          other.classList.toggle('active', isActive);
          other.setAttribute('aria-pressed', isActive ? 'true' : 'false');
        });
      });
    });
  });
</script>

<style>
  .gallery {
    width: 100%;
  }

  .hero-frame {
    width: 100%;
    background: var(--bg-2);
    border: 1px solid var(--border-bright);
    border-radius: 10px;
    overflow: hidden;
    box-shadow: 0 24px 60px rgba(0, 0, 0, 0.55);
  }

  /* Show the whole plugin UI at its natural ratio — never crop the product. */
  .hero-frame img {
    width: 100%;
    height: auto;
    display: block;
  }

  .hero-frame.placeholder {
    aspect-ratio: 16 / 9;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: none;
    color: var(--fg-faint);
    font-family: var(--font-mono);
    font-size: 0.85rem;
    border-style: dashed;
    border-color: var(--border-bright);
  }

  .thumbs {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 0.5rem;
    margin-top: 0.5rem;
  }

  @media (max-width: 600px) {
    .thumbs { grid-template-columns: repeat(4, 1fr); }
  }

  .thumb {
    aspect-ratio: 16 / 10;
    background: var(--bg-2);
    border: 1px solid var(--border);
    cursor: pointer;
    padding: 0;
    overflow: hidden;
    transition: border-color 0.15s var(--ease);
  }

  .thumb:hover { border-color: var(--brass-dark); }
  .thumb.active { border-color: var(--brass); }

  .thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
</style>
