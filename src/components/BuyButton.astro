---
import { getImage } from 'astro:assets';
import type { Plugin } from '../data/plugins';
import { isBuyable, fmtPrice, discountPct } from '../data/plugins';
import { pluginImage } from '../lib/images';

interface Props {
  plugin: Plugin;
}

const { plugin } = Astro.props;
const buyable = isBuyable(plugin);
const pct = discountPct(plugin);

// Optimized thumbnail for the add-to-cart payload. Checkout itself uses the Paddle price ID.
const heroMeta = pluginImage(plugin.heroImage);
const cartThumb = heroMeta ? await getImage({ src: heroMeta, width: 112, height: 64, format: 'webp' }) : null;
---

<div class="buy-block">
  {buyable && plugin.paddlePriceId ? (
    <>
      <div class="prices">
        <span class="price-now">{fmtPrice(plugin.introPriceUsd)}</span>
        {plugin.regularPriceUsd != null && pct != null && (
          <>
            <span class="price-was">{fmtPrice(plugin.regularPriceUsd)}</span>
            <span class="price-tag">&minus;{pct}% intro</span>
          </>
        )}
      </div>
      <button
        type="button"
        class="btn primary"
        data-add-to-cart
        data-slug={plugin.slug}
        data-name={plugin.name}
        data-price={plugin.introPriceUsd}
        data-price-id={plugin.paddlePriceId}
        data-img={cartThumb?.src}
      >
        Add to cart
      </button>
      {plugin.demoUrl && (
        <a class="btn ghost" href={plugin.demoUrl}>
          Download demo
        </a>
      )}
      <p class="micro muted">Secure checkout by Paddle — without leaving the site.</p>
    </>
  ) : plugin.checkoutPaused ? (
    <>
      <div class="prices">
        <span class="price-now">{fmtPrice(plugin.introPriceUsd)}</span>
      </div>
      <a class="btn primary" href={`/${plugin.slug}#waitlist`}>
        Email me when checkout reopens
      </a>
      <p class="micro muted">Checkout is moving to a new payment processor — back online in a few days.</p>
    </>
  ) : plugin.status === 'beta' ? (
    <>
      <div class="prices muted">
        <span class="price-now">{fmtPrice(plugin.introPriceUsd)}</span>
        <span class="price-tag waitlist">Waitlist price</span>
      </div>
      <a class="btn primary" href={`/${plugin.slug}#waitlist`}>
        Join the beta waitlist
      </a>
      <p class="micro muted">Beta builds go to the waitlist first. Launch in {plugin.releaseTarget}.</p>
    </>
  ) : (
    <>
      <div class="prices muted">
        <span class="hint muted">Launch target {plugin.releaseTarget}</span>
      </div>
      <a class="btn primary" href={`/${plugin.slug}#waitlist`}>
        Notify me when {plugin.name} ships
      </a>
    </>
  )}

  <ul class="includes">
    <li>VST3 plugin (Windows 64-bit)</li>
    <li>Free updates within v1.x</li>
    <li>Mac build included when shipped</li>
    <li>Up to 3 machines per licence</li>
    <li>14-day refund</li>
  </ul>
</div>

<style>
  .buy-block {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding: 1.75rem;
    background: var(--bg-1);
    border: 1px solid var(--border);
    border-top: 3px solid var(--brass);
  }

  .prices {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-bottom: 0.5rem;
  }

  .prices.muted .price-now { color: var(--fg-dim); }

  .price-now {
    font-family: var(--font-display);
    font-size: 2.5rem;
    color: var(--brass-bright);
    letter-spacing: 0.04em;
  }

  .price-was {
    font-family: var(--font-display);
    font-size: 1.25rem;
    color: var(--fg-faint);
    text-decoration: line-through;
  }

  .price-tag {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--oxide);
    border: 1px solid var(--oxide);
    padding: 0.15rem 0.5rem;
  }

  .price-tag.waitlist {
    color: var(--brass);
    border-color: var(--brass-dark);
  }

  .btn {
    display: inline-block;
    padding: 0.875rem 1.5rem;
    font-family: var(--font-display);
    font-size: 1.05rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-align: center;
    border: 1px solid transparent;
    transition: background 0.2s var(--ease), border-color 0.2s var(--ease), color 0.2s var(--ease);
    cursor: pointer;
  }

  .btn.primary {
    background: var(--brass);
    color: var(--bg-0);
  }
  .btn.primary:hover { background: var(--brass-bright); color: var(--bg-0); }

  .btn.ghost {
    background: transparent;
    color: var(--fg);
    border-color: var(--border-bright);
  }
  .btn.ghost:hover { border-color: var(--brass); color: var(--brass-bright); }

  .btn.link {
    background: transparent;
    color: var(--fg-dim);
    padding: 0.4rem 0;
    text-align: left;
    font-size: 0.85rem;
    letter-spacing: 0.1em;
  }
  .btn.link:hover { color: var(--brass-bright); }

  .micro { font-size: 0.8rem; margin: 0; }

  .includes {
    list-style: none;
    padding: 1rem 0 0;
    margin: 0.5rem 0 0;
    border-top: 1px solid var(--border);
    font-size: 0.85rem;
    color: var(--fg-dim);
  }

  .includes li {
    padding: 0.4rem 0;
  }

  .includes li::before {
    content: '+ ';
    color: var(--brass);
    font-weight: 600;
  }
</style>
