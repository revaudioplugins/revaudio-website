---
import type { Plugin } from '../data/plugins';
import { isBuyable, fmtPrice, discountPct } from '../data/plugins';

interface Props {
  plugin: Plugin;
}

const { plugin } = Astro.props;
const buyable = isBuyable(plugin);
const pct = discountPct(plugin);
---

<div class="buy-block">
  {buyable && plugin.gumroadUrl ? (
    <>
      <div class="prices">
        <span class="price-now">{fmtPrice(plugin.introPriceUsd)}</span>
        {plugin.regularPriceUsd != null && pct != null && (
          <>
            <span class="price-was">{fmtPrice(plugin.regularPriceUsd)}</span>
            <span class="price-tag">&minus;{pct}% intro</span>
          </>
        )}
      </div>
      <button type="button" class="btn primary" data-cart-open data-cart-url={`${plugin.gumroadUrl}?wanted=true`}>
        Add to cart
      </button>
      {plugin.demoUrl && (
        <a class="btn ghost" href={plugin.demoUrl}>
          Download demo
        </a>
      )}
      <p class="micro muted">Secure checkout by Gumroad — without leaving the site.</p>
    </>
  ) : plugin.status === 'beta' ? (
    <>
      <div class="prices muted">
        <span class="price-now">{fmtPrice(plugin.introPriceUsd)}</span>
        <span class="price-tag waitlist">Waitlist price</span>
      </div>
      <a class="btn primary" href={`/${plugin.slug}#waitlist`}>
        Join the beta waitlist
      </a>
      <p class="micro muted">Beta builds go to the waitlist first. Launch in {plugin.releaseTarget}.</p>
    </>
  ) : (
    <>
      <div class="prices muted">
        <span class="hint muted">Launch target {plugin.releaseTarget}</span>
      </div>
      <a class="btn primary" href={`/${plugin.slug}#waitlist`}>
        Notify me when {plugin.name} ships
      </a>
    </>
  )}

  <ul class="includes">
    <li>VST3 plugin (Windows 64-bit)</li>
    <li>Free updates within v1.x</li>
    <li>Mac build included when shipped</li>
    <li>Up to 3 machines per licence</li>
    <li>14-day refund</li>
  </ul>
</div>

{buyable && plugin.gumroadUrl && (
  <dialog class="cart-modal" data-cart-modal aria-label={`Buy ${plugin.name}`}>
    <button type="button" class="cart-close" data-cart-close aria-label="Close checkout">&times;</button>
    <iframe data-cart-frame title={`${plugin.name} secure checkout`} allow="payment"></iframe>
  </dialog>
)}

<script is:inline>
  (function () {
    var dlg = document.querySelector('[data-cart-modal]');
    var frame = dlg && dlg.querySelector('[data-cart-frame]');
    if (!dlg || !frame) return;
    var html = document.documentElement;
    function openCart(url) {
      if (!url) return;
      if (typeof dlg.showModal !== 'function') { window.open(url, '_blank', 'noopener'); return; }
      frame.src = url;
      dlg.showModal();
      html.style.overflow = 'hidden';
    }
    function shut() { if (dlg.open) dlg.close(); }
    dlg.addEventListener('close', function () { frame.src = 'about:blank'; html.style.overflow = ''; });
    dlg.addEventListener('click', function (e) { if (e.target === dlg) shut(); });
    Array.prototype.forEach.call(document.querySelectorAll('[data-cart-open]'), function (b) {
      b.addEventListener('click', function () { openCart(b.getAttribute('data-cart-url')); });
    });
    var x = dlg.querySelector('[data-cart-close]');
    if (x) x.addEventListener('click', shut);
  })();
</script>

<style>
  .buy-block {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding: 1.75rem;
    background: var(--bg-1);
    border: 1px solid var(--border);
    border-top: 3px solid var(--brass);
  }

  .prices {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-bottom: 0.5rem;
  }

  .prices.muted .price-now { color: var(--fg-dim); }

  .price-now {
    font-family: var(--font-display);
    font-size: 2.5rem;
    color: var(--brass-bright);
    letter-spacing: 0.04em;
  }

  .price-was {
    font-family: var(--font-display);
    font-size: 1.25rem;
    color: var(--fg-faint);
    text-decoration: line-through;
  }

  .price-tag {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--oxide);
    border: 1px solid var(--oxide);
    padding: 0.15rem 0.5rem;
  }

  .price-tag.waitlist {
    color: var(--brass);
    border-color: var(--brass-dark);
  }

  .btn {
    display: inline-block;
    padding: 0.875rem 1.5rem;
    font-family: var(--font-display);
    font-size: 1.05rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-align: center;
    border: 1px solid transparent;
    transition: background 0.2s var(--ease), border-color 0.2s var(--ease), color 0.2s var(--ease);
    cursor: pointer;
  }

  .btn.primary {
    background: var(--brass);
    color: var(--bg-0);
  }
  .btn.primary:hover { background: var(--brass-bright); color: var(--bg-0); }

  .btn.ghost {
    background: transparent;
    color: var(--fg);
    border-color: var(--border-bright);
  }
  .btn.ghost:hover { border-color: var(--brass); color: var(--brass-bright); }

  .btn.link {
    background: transparent;
    color: var(--fg-dim);
    padding: 0.4rem 0;
    text-align: left;
    font-size: 0.85rem;
    letter-spacing: 0.1em;
  }
  .btn.link:hover { color: var(--brass-bright); }

  .micro { font-size: 0.8rem; margin: 0; }

  .includes {
    list-style: none;
    padding: 1rem 0 0;
    margin: 0.5rem 0 0;
    border-top: 1px solid var(--border);
    font-size: 0.85rem;
    color: var(--fg-dim);
  }

  .includes li {
    padding: 0.4rem 0;
  }

  .includes li::before {
    content: '+ ';
    color: var(--brass);
    font-weight: 600;
  }

  /* On-site checkout modal (Gumroad iframe inside our own dialog) */
  .cart-modal {
    width: min(460px, 94vw);
    height: min(760px, 88vh);
    max-width: 94vw;
    max-height: 88vh;
    padding: 0;
    border: 1px solid var(--border-bright);
    border-radius: 14px;
    background: var(--bg-1);
    color: var(--fg);
    overflow: hidden;
    box-shadow: 0 30px 90px rgba(0, 0, 0, 0.7);
  }

  .cart-modal::backdrop {
    background: rgba(8, 7, 6, 0.66);
    backdrop-filter: blur(4px);
  }

  .cart-modal iframe {
    width: 100%;
    height: 100%;
    border: 0;
    display: block;
    background: #fff;
  }

  .cart-close {
    position: absolute;
    top: 10px;
    right: 12px;
    z-index: 2;
    width: 34px;
    height: 34px;
    border-radius: 50%;
    border: 1px solid var(--border-bright);
    background: var(--bg-0);
    color: var(--fg);
    font-size: 1.4rem;
    line-height: 1;
    cursor: pointer;
    transition: border-color 0.2s var(--ease), color 0.2s var(--ease);
  }

  .cart-close:hover { border-color: var(--brass); color: var(--brass-bright); }
</style>
