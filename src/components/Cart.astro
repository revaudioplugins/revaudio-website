---
import { Image } from 'astro:assets';
import checkoutImg from '../assets/ui/btn-checkout.png';
import checkoutPressed from '../assets/ui/btn-checkout-pressed.png';
import { plugins } from '../data/plugins';
import TermsContent from './legal/TermsContent.astro';
import { TERMS_LAST_UPDATED } from '../data/legal';
/**
 * Global cart: a localStorage-backed mini-cart shared across every page.
 * - [data-add-to-cart] buttons (with data-slug/name/price/price-id/img) add items
 * - the header cart icon ([data-cart-toggle]) + badge ([data-cart-badge]) open the drawer
 * - Checkout opens the Lemon Squeezy overlay (lemon.js + ?embed=1) ON the site,
 *   no full redirect; falls back to a redirect if lemon.js is blocked
 * Rendered once in BaseLayout. No framework — vanilla JS, progressive.
 *
 * Checkout URLs are resolved fresh from this catalog map by slug at checkout
 * time — NEVER from the URL persisted in the cart. A buyer's localStorage can
 * hold a stale URL (e.g. a test-mode link saved before a live swap); resolving
 * by slug means a deployed URL change takes effect immediately for everyone.
 */
const checkoutMap: Record<string, string> = {};
for (const p of plugins) if (p.checkoutUrl) checkoutMap[p.slug] = p.checkoutUrl;
---

<script is:inline type="application/json" data-checkout-map set:html={JSON.stringify(checkoutMap)}></script>

<!-- Lemon Squeezy overlay checkout — renders the payment screen in a modal over the site. -->
<script is:inline src="https://assets.lemonsqueezy.com/lemon.js" defer></script>

<!-- Cart drawer -->
<dialog class="cart-drawer" data-cart-drawer aria-label="Your cart">
  <div class="cd-head">
    <h2>Your cart</h2>
    <button type="button" class="cd-x" data-cart-close aria-label="Close cart">&times;</button>
  </div>
  <p class="cd-empty" data-cart-empty>Your cart is empty.</p>
  <ul class="cd-items" data-cart-items data-lenis-prevent></ul>
  <div class="cd-foot" data-cart-foot hidden>
    <div class="cd-sub"><span>Subtotal</span><span data-cart-subtotal>$0</span></div>
    <div class="cd-checkout panel">
      <Image src={checkoutImg} alt="" width={680} height={453} format="webp" />
      <button type="button" class="panel-hit hit-round hit-checkout" data-checkout aria-label="Checkout"></button>
      <Image src={checkoutPressed} alt="" width={680} height={453} format="webp" loading="eager" class="press" />
    </div>
    <button type="button" class="cd-cont" data-cart-close>Continue browsing</button>
  </div>
</dialog>

<!-- Terms & Conditions consent modal — the "I agree" box unlocks only after the
     buyer scrolls to the end of the terms (scroll-wrap + clickwrap). -->
<dialog class="terms-modal" data-terms-modal aria-labelledby="tm-title">
  <div class="tm-head">
    <h2 id="tm-title">Terms &amp; Conditions</h2>
    <button type="button" class="cd-x" data-terms-close aria-label="Close">&times;</button>
  </div>
  <div class="tm-body" data-terms-scroll tabindex="0" data-lenis-prevent>
    <TermsContent />
    <div class="tm-end" data-terms-end aria-hidden="true"></div>
  </div>
  <div class="tm-foot">
    <p class="tm-hint" data-terms-hint>↓&nbsp; Scroll to the end to accept</p>
    <label class="tm-agree">
      <input type="checkbox" data-terms-agree data-terms-version={TERMS_LAST_UPDATED} disabled />
      <span>I have read and agree to the Terms &amp; Conditions and <a href="/eula" target="_blank" rel="noopener">Licence Agreement</a>.</span>
    </label>
    <button type="button" class="tm-proceed" data-terms-proceed disabled>Agree &amp; continue to checkout</button>
  </div>
</dialog>

<script is:inline>
  (function () {
    var KEY = 'revaudio_cart_v2';
    var html = document.documentElement;
    var drawer = document.querySelector('[data-cart-drawer]');
    var itemsEl = drawer && drawer.querySelector('[data-cart-items]');
    var emptyEl = drawer && drawer.querySelector('[data-cart-empty]');
    var footEl = drawer && drawer.querySelector('[data-cart-foot]');
    var subEl = drawer && drawer.querySelector('[data-cart-subtotal]');

    function read() { try { return JSON.parse(localStorage.getItem(KEY)) || []; } catch (e) { return []; } }
    function write(c) { try { localStorage.setItem(KEY, JSON.stringify(c)); } catch (e) {} }
    function count(c) { return c.reduce(function (n, i) { return n + (i.qty || 1); }, 0); }
    function esc(s) {
      return String(s == null ? '' : s).replace(/[&<>"']/g, function (m) {
        return { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[m];
      });
    }

    function lock() { html.style.overflow = (drawer && drawer.open) ? 'hidden' : ''; }

    function add(item) {
      if (!item || !item.slug) return;
      var c = read();
      // One licence per product — re-adding just reopens the cart, never stacks qty.
      var exists = c.some(function (i) { return i.slug === item.slug; });
      if (!exists) {
        c.push({ slug: item.slug, name: item.name, price: +item.price || 0, checkoutUrl: item.checkoutUrl || '', img: item.img || '', qty: 1 });
        write(c);
      }
      sync(); openDrawer();
    }
    function remove(slug) {
      write(read().filter(function (i) { return i.slug !== slug; }));
      sync();
    }

    function sync() {
      var c = read();
      var n = count(c);
      var badges = document.querySelectorAll('[data-cart-badge]');
      for (var b = 0; b < badges.length; b++) { badges[b].textContent = n; badges[b].hidden = n === 0; }
      if (!itemsEl) return;
      if (!c.length) {
        itemsEl.innerHTML = '';
        if (emptyEl) emptyEl.hidden = false;
        if (footEl) footEl.hidden = true;
        return;
      }
      if (emptyEl) emptyEl.hidden = true;
      if (footEl) footEl.hidden = false;
      var sub = 0;
      itemsEl.innerHTML = c.map(function (i) {
        sub += (i.price || 0) * (i.qty || 1);
        return '<li class="ci">' +
          (i.img ? '<img class="ci-img" src="' + esc(i.img) + '" alt="" width="56" height="32" loading="lazy">' : '') +
          '<div class="ci-main"><span class="ci-name">' + esc(i.name) + '</span>' +
          '<span class="ci-meta">' + ((i.qty || 1) > 1 ? (i.qty + ' &times; ') : '') + '$' + (i.price || 0) + '</span></div>' +
          '<button type="button" class="ci-x" data-remove="' + esc(i.slug) + '" aria-label="Remove ' + esc(i.name) + '">&times;</button>' +
          '</li>';
      }).join('');
      if (subEl) subEl.textContent = '$' + sub;
    }

    function openDrawer() {
      if (!drawer) return;
      if (typeof drawer.showModal === 'function') drawer.showModal(); else drawer.setAttribute('open', '');
      lock();
    }

    // ---- Lemon Squeezy overlay ----
    // lemon.js loads deferred; init lazily on first checkout (it's loaded by the
    // time a user can click). Clear the cart when the buyer completes payment.
    var lemonReady = false;
    function ensureLemon() {
      if (lemonReady) return !!(window.LemonSqueezy && window.LemonSqueezy.Url);
      if (typeof window.createLemonSqueezy !== 'function') return false;
      try {
        window.createLemonSqueezy();
        window.LemonSqueezy.Setup({
          eventHandler: function (ev) {
            if (ev && ev.event === 'Checkout.Success') {
              write([]); sync();
              window.location.href = '/thank-you';
            }
          }
        });
        lemonReady = true;
      } catch (e) {}
      return lemonReady;
    }

    // Catalog map (slug -> current checkout URL), baked at build time. Resolving
    // here means the cart never serves a stale URL persisted in localStorage.
    function checkoutMap() {
      var el = document.querySelector('[data-checkout-map]');
      try { return el ? JSON.parse(el.textContent || '{}') : {}; } catch (e) { return {}; }
    }
    function checkoutUrlFor(item) {
      var map = checkoutMap();
      return (item && map[item.slug]) || (item && item.checkoutUrl) || '';
    }

    // ---- Terms & Conditions consent modal (scroll-to-accept) ----
    // Legally stronger than a bare checkbox: the buyer must scroll through the
    // full T&C before the "I agree" box unlocks. The LS overlay can't host our
    // consent (it only shows LS's own terms), so we gate on this side of payment.
    var termsAccepted = false;
    var tModal = document.querySelector('[data-terms-modal]');
    var tScroll = tModal && tModal.querySelector('[data-terms-scroll]');
    var tEnd = tModal && tModal.querySelector('[data-terms-end]');
    var tAgree = tModal && tModal.querySelector('[data-terms-agree]');
    var tProceed = tModal && tModal.querySelector('[data-terms-proceed]');
    var tHint = tModal && tModal.querySelector('[data-terms-hint]');
    var tObserver = null;

    function enableTermsAgree() {
      if (tAgree) tAgree.disabled = false;
      if (tHint) tHint.hidden = true;
    }
    function termsCleanup() {
      if (tObserver) { tObserver.disconnect(); tObserver = null; }
      html.style.overflow = (drawer && drawer.open) ? 'hidden' : '';
    }
    function openTermsModal() {
      if (!tModal) { launchCheckout(); return; } // fail-open only if markup is missing
      if (tAgree) { tAgree.checked = false; tAgree.disabled = true; }
      if (tProceed) tProceed.disabled = true;
      if (tHint) tHint.hidden = false;
      if (tScroll) tScroll.scrollTop = 0;
      if (typeof tModal.showModal === 'function') tModal.showModal(); else tModal.setAttribute('open', '');
      html.style.overflow = 'hidden';
      // Unlock the checkbox once the end sentinel is reached — works for mouse,
      // keyboard, and content shorter than the viewport (IO fires on observe if
      // the sentinel is already visible, so short terms never trap the user).
      if ('IntersectionObserver' in window && tEnd && tScroll) {
        if (tObserver) tObserver.disconnect();
        tObserver = new IntersectionObserver(function (entries) {
          for (var i = 0; i < entries.length; i++) if (entries[i].isIntersecting) enableTermsAgree();
        }, { root: tScroll, rootMargin: '0px 0px 48px 0px' });
        tObserver.observe(tEnd);
      } else {
        enableTermsAgree();
      }
    }
    function closeTermsModal() {
      if (tModal && tModal.open && typeof tModal.close === 'function') tModal.close(); // 'close' event → termsCleanup
      else { if (tModal) tModal.removeAttribute('open'); termsCleanup(); }
    }

    // Cart Checkout button: prompt the terms once per session, then go to payment.
    function startCheckout() {
      var items = read().filter(function (i) { return checkoutUrlFor(i); });
      if (!items.length) return;
      if (termsAccepted) { launchCheckout(); return; }
      if (drawer && drawer.open) drawer.close();
      openTermsModal();
    }
    // Opens the LS overlay, stamping the accepted legal-bundle version onto the
    // order via LS custom passthrough data (consent record; LS docs: Passing Custom Data).
    function launchCheckout() {
      var items = read().filter(function (i) { return checkoutUrlFor(i); });
      if (!items.length) return;
      var url = checkoutUrlFor(items[0]);
      url += (url.indexOf('?') === -1 ? '?' : '&') + 'embed=1';
      url += '&checkout[custom][terms_accepted]=true';
      var ver = (tAgree && tAgree.getAttribute('data-terms-version')) || '';
      if (ver) url += '&checkout[custom][terms_version]=' + encodeURIComponent(ver);
      if (drawer && drawer.open) drawer.close();
      // Overlay on-site (no redirect). Fall back to a full redirect if lemon.js is blocked.
      if (ensureLemon()) { window.LemonSqueezy.Url.Open(url); return; }
      window.location.href = url;
    }

    document.addEventListener('click', function (e) {
      var t = e.target;
      var addBtn = t.closest('[data-add-to-cart]');
      if (addBtn) {
        e.preventDefault();
        add({
          slug: addBtn.getAttribute('data-slug'),
          name: addBtn.getAttribute('data-name'),
          price: addBtn.getAttribute('data-price'),
          checkoutUrl: addBtn.getAttribute('data-checkout-url'),
          img: addBtn.getAttribute('data-img')
        });
        return;
      }
      if (t.closest('[data-cart-toggle]')) { e.preventDefault(); openDrawer(); return; }
      var rm = t.closest('[data-remove]');
      if (rm) { remove(rm.getAttribute('data-remove')); return; }
      if (t.closest('[data-checkout]')) { e.preventDefault(); startCheckout(); return; }
      if (t.closest('[data-terms-close]')) { e.preventDefault(); closeTermsModal(); return; }
      if (t.closest('[data-terms-proceed]')) {
        e.preventDefault();
        if (tAgree && tAgree.checked) { termsAccepted = true; closeTermsModal(); launchCheckout(); }
        return;
      }
      if (t.closest('[data-cart-close]') && drawer && drawer.open) { drawer.close(); return; }
    });

    if (drawer) {
      drawer.addEventListener('click', function (e) { if (e.target === drawer) drawer.close(); }); // backdrop
      drawer.addEventListener('close', lock);
    }

    if (tModal) {
      tModal.addEventListener('close', termsCleanup);                                  // Esc / close()
      tModal.addEventListener('click', function (e) { if (e.target === tModal) closeTermsModal(); }); // backdrop
      tModal.addEventListener('change', function (e) {
        if (e.target && e.target.matches('[data-terms-agree]') && tProceed) tProceed.disabled = !e.target.checked;
      });
    }

    sync();
  })();
</script>

<style>
  /* ---- Cart drawer (slides from the right) ---- */
  .cart-drawer {
    margin: 0 0 0 auto;
    height: 100dvh;
    max-height: 100dvh;
    width: min(380px, 92vw);
    padding: 0;
    border: 0;
    border-left: 1px solid var(--border-bright);
    background: var(--bg-1);
    color: var(--fg);
    box-shadow: -24px 0 80px rgba(0, 0, 0, 0.6);
    transform: translateX(100%);
    transition: transform 0.28s var(--ease), overlay 0.28s ease allow-discrete, display 0.28s ease allow-discrete;
  }
  .cart-drawer[open] { transform: translateX(0); }
  @starting-style { .cart-drawer[open] { transform: translateX(100%); } }

  .cart-drawer::backdrop { background: rgba(8, 7, 6, 0); transition: background 0.28s ease; }
  .cart-drawer[open]::backdrop { background: rgba(8, 7, 6, 0.6); backdrop-filter: blur(4px); }
  @starting-style { .cart-drawer[open]::backdrop { background: rgba(8, 7, 6, 0); } }

  .cd-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.25rem 1.25rem 1rem;
    border-bottom: 1px solid var(--border);
  }
  .cd-head h2 { margin: 0; font-size: 1.5rem; color: var(--fg); }

  .cd-x {
    width: 34px; height: 34px; border-radius: 50%;
    border: 1px solid var(--border-bright);
    background: var(--bg-0); color: var(--fg);
    font-size: 1.4rem; line-height: 1; cursor: pointer;
    transition: border-color 0.2s var(--ease), color 0.2s var(--ease);
  }
  .cd-x:hover { border-color: var(--brass); color: var(--brass-bright); }

  .cd-empty { padding: 2rem 1.25rem; color: var(--fg-dim); }

  .cd-items { list-style: none; margin: 0; padding: 0.5rem 0.75rem; overflow-y: auto; }
  /* Cart items are injected at runtime, so they need :global to escape Astro scoping. */
  .cd-items :global(.ci) {
    display: flex; align-items: center; gap: 0.85rem;
    padding: 0.85rem 0.5rem; border-bottom: 1px solid var(--border);
  }
  .cd-items :global(.ci-img) { border-radius: 6px; border: 1px solid var(--border); object-fit: cover; flex: none; }
  .cd-items :global(.ci-main) { display: flex; flex-direction: column; gap: 0.15rem; flex: 1; min-width: 0; }
  .cd-items :global(.ci-name) { font-family: var(--font-display); letter-spacing: 0.03em; color: var(--brass-bright); font-size: 1.1rem; }
  .cd-items :global(.ci-meta) { font-family: var(--font-mono); font-size: 0.8rem; color: var(--fg-dim); }
  .cd-items :global(.ci-x) {
    flex: none; width: 26px; height: 26px; border-radius: 50%;
    border: 1px solid var(--border); background: transparent; color: var(--fg-faint);
    font-size: 1rem; line-height: 1; cursor: pointer;
    transition: color 0.2s, border-color 0.2s;
  }
  .cd-items :global(.ci-x:hover) { color: var(--redline); border-color: var(--redline); }

  .cd-foot {
    margin-top: auto;
    padding: 1.1rem 1.25rem 1.4rem;
    border-top: 1px solid var(--border);
    display: flex; flex-direction: column; gap: 0.75rem;
  }
  .cd-sub {
    display: flex; justify-content: space-between; align-items: baseline;
    font-family: var(--font-mono); font-size: 0.95rem; color: var(--fg);
  }
  .cd-sub span:last-child { color: var(--brass-bright); font-size: 1.15rem; }

  /* CHECKOUT panel — plate is decorative; the .panel-hit over the red button clicks. */
  .cd-checkout { width: 100%; }
  .cd-cont {
    background: none; border: 0; color: var(--fg-dim);
    font-size: 0.85rem; cursor: pointer; padding: 0.25rem;
  }
  .cd-cont:hover { color: var(--brass-bright); }

  /* drawer is a flex column so cd-foot can pin to the bottom */
  .cart-drawer { display: flex; flex-direction: column; }
  .cart-drawer:not([open]) { display: none; }

  /* ---- Terms & Conditions consent modal (centered) ---- */
  .terms-modal {
    margin: auto;
    width: min(680px, 94vw);
    max-height: min(86dvh, 880px);
    padding: 0;
    border: 1px solid var(--border-bright);
    border-radius: 14px;
    background: var(--bg-1);
    color: var(--fg);
    box-shadow: 0 30px 90px rgba(0, 0, 0, 0.65);
    flex-direction: column;
    overflow: hidden;
  }
  .terms-modal[open] { display: flex; }
  .terms-modal:not([open]) { display: none; }
  .terms-modal::backdrop { background: rgba(8, 7, 6, 0); transition: background 0.28s ease; }
  .terms-modal[open]::backdrop { background: rgba(8, 7, 6, 0.72); backdrop-filter: blur(4px); }
  @starting-style { .terms-modal[open]::backdrop { background: rgba(8, 7, 6, 0); } }

  .tm-head {
    display: flex; align-items: center; justify-content: space-between;
    padding: 1.15rem 1.35rem; border-bottom: 1px solid var(--border); flex: none;
  }
  .tm-head h2 { margin: 0; font-size: 1.5rem; color: var(--fg); }

  .tm-body { flex: 1; overflow-y: auto; padding: 0.4rem 1.35rem 1rem; }
  .tm-body:focus-visible { outline: 2px solid var(--brass); outline-offset: -3px; }
  /* TermsContent is a separate component, so its elements need :global to style. */
  .tm-body :global(.muted) { color: var(--fg-faint); font-size: 0.8rem; }
  .tm-body :global(h2) { font-size: 1.1rem; color: var(--fg); margin: 1.5rem 0 0.4rem; }
  .tm-body :global(p) { font-size: 0.88rem; line-height: 1.6; color: var(--fg-dim); margin: 0 0 0.6rem; }
  .tm-body :global(a) { color: var(--brass-bright); text-decoration: underline; }
  .tm-body :global(strong) { color: var(--fg); }
  .tm-end { height: 1px; }

  .tm-foot {
    flex: none; border-top: 1px solid var(--border);
    padding: 0.9rem 1.35rem 1.15rem; background: var(--bg-1);
    display: flex; flex-direction: column; gap: 0.7rem;
  }
  .tm-hint {
    margin: 0; font-family: var(--font-mono); font-size: 0.78rem;
    color: var(--brass-bright); letter-spacing: 0.02em;
  }
  .tm-agree { display: flex; align-items: flex-start; gap: 0.6rem; font-size: 0.85rem; line-height: 1.45; color: var(--fg); }
  .tm-agree input { flex: none; width: 17px; height: 17px; margin-top: 0.1rem; accent-color: var(--brass); cursor: pointer; }
  .tm-agree input:disabled { cursor: not-allowed; opacity: 0.45; }
  .tm-agree a { color: var(--brass-bright); text-decoration: underline; }
  .tm-proceed {
    align-self: stretch; padding: 0.75rem 1.4rem; border-radius: 9px;
    border: 1px solid var(--brass); background: var(--brass); color: var(--bg-0);
    font-family: var(--font-display); letter-spacing: 0.04em; font-size: 1rem;
    cursor: pointer; transition: background 0.2s var(--ease), opacity 0.2s var(--ease);
  }
  .tm-proceed:disabled { opacity: 0.4; cursor: not-allowed; }
  .tm-proceed:not(:disabled):hover { background: var(--brass-bright); }
</style>
