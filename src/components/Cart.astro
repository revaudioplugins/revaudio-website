---
import { Image } from 'astro:assets';
import checkoutImg from '../assets/ui/btn-checkout.png';
import checkoutPressed from '../assets/ui/btn-checkout-pressed.png';
import { plugins } from '../data/plugins';
import TermsContent from './legal/TermsContent.astro';
import EulaContent from './legal/EulaContent.astro';
import PrivacyContent from './legal/PrivacyContent.astro';
import { TERMS_LAST_UPDATED } from '../data/legal';
/**
 * Global cart: a localStorage-backed mini-cart shared across every page.
 * - [data-add-to-cart] buttons (with data-slug/name/price/price-id/img) add items
 * - the header cart icon ([data-cart-toggle]) + badge ([data-cart-badge]) open the drawer
 * - A required consent checkbox gates Checkout; its links open the legal-reader
 *   modal (Terms / Licence / Privacy) IN A POPUP — no page navigation.
 * - Checkout opens the Lemon Squeezy overlay (lemon.js + ?embed=1) ON the site,
 *   stamping the accepted terms version onto the order as a consent record.
 * Rendered once in BaseLayout. No framework — vanilla JS, progressive.
 *
 * Checkout URLs are resolved fresh from this catalog map by slug at checkout
 * time — NEVER from the URL persisted in the cart.
 */
const checkoutMap: Record<string, string> = {};
for (const p of plugins) if (p.checkoutUrl) checkoutMap[p.slug] = p.checkoutUrl;
---

<script is:inline type="application/json" data-checkout-map set:html={JSON.stringify(checkoutMap)}></script>

<!-- Lemon Squeezy overlay checkout — renders the payment screen in a modal over the site. -->
<script is:inline src="https://assets.lemonsqueezy.com/lemon.js" defer></script>

<!-- Cart drawer -->
<dialog class="cart-drawer" data-cart-drawer aria-label="Your cart">
  <div class="cd-head">
    <h2>Your cart</h2>
    <button type="button" class="cd-x" data-cart-close aria-label="Close cart">&times;</button>
  </div>
  <p class="cd-empty" data-cart-empty>Your cart is empty.</p>
  <ul class="cd-items" data-cart-items data-lenis-prevent></ul>
  <div class="cd-foot" data-cart-foot hidden>
    <div class="cd-sub"><span>Subtotal</span><span data-cart-subtotal>$0</span></div>
    <label class="cd-agree" data-agree-label>
      <input type="checkbox" data-cart-agree data-terms-version={TERMS_LAST_UPDATED} aria-describedby="cd-agree-hint" />
      <span>I have read and agree to RevAudio's
        <a href="/terms" data-open-legal="terms">Terms</a>,
        <a href="/eula" data-open-legal="eula">Licence</a> &amp;
        <a href="/privacy" data-open-legal="privacy">Privacy</a>.</span>
    </label>
    <p class="cd-agree-hint" id="cd-agree-hint" data-agree-hint hidden>Please agree to the terms to continue.</p>
    <div class="cd-checkout panel">
      <Image src={checkoutImg} alt="" width={680} height={453} format="webp" />
      <button type="button" class="panel-hit hit-round hit-checkout" data-checkout aria-label="Checkout"></button>
      <Image src={checkoutPressed} alt="" width={680} height={453} format="webp" loading="eager" class="press" />
    </div>
    <button type="button" class="cd-cont" data-cart-close>Continue browsing</button>
  </div>
</dialog>

<!-- Legal reader modal — read-only popup for Terms / Licence / Privacy (no page nav). -->
<dialog class="legal-modal" data-legal-modal aria-label="Legal documents">
  <div class="lm-head">
    <div class="lm-tabs" role="tablist" aria-label="Legal documents">
      <button type="button" class="lm-tab is-active" data-legal-tab="terms" role="tab" aria-selected="true">Terms &amp; Conditions</button>
      <button type="button" class="lm-tab" data-legal-tab="eula" role="tab" aria-selected="false">Licence</button>
      <button type="button" class="lm-tab" data-legal-tab="privacy" role="tab" aria-selected="false">Privacy</button>
    </div>
    <button type="button" class="cd-x" data-legal-close aria-label="Close">&times;</button>
  </div>
  <div class="lm-body" data-legal-scroll tabindex="0" data-lenis-prevent>
    <section data-legal-panel="terms"><TermsContent /></section>
    <section data-legal-panel="eula" hidden><EulaContent /></section>
    <section data-legal-panel="privacy" hidden><PrivacyContent /></section>
  </div>
</dialog>

<script is:inline>
  (function () {
    var KEY = 'revaudio_cart_v2';
    var html = document.documentElement;
    var drawer = document.querySelector('[data-cart-drawer]');
    var itemsEl = drawer && drawer.querySelector('[data-cart-items]');
    var emptyEl = drawer && drawer.querySelector('[data-cart-empty]');
    var footEl = drawer && drawer.querySelector('[data-cart-foot]');
    var subEl = drawer && drawer.querySelector('[data-cart-subtotal]');

    function read() { try { return JSON.parse(localStorage.getItem(KEY)) || []; } catch (e) { return []; } }
    function write(c) { try { localStorage.setItem(KEY, JSON.stringify(c)); } catch (e) {} }
    function count(c) { return c.reduce(function (n, i) { return n + (i.qty || 1); }, 0); }
    function esc(s) {
      return String(s == null ? '' : s).replace(/[&<>"']/g, function (m) {
        return { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[m];
      });
    }

    function lock() { html.style.overflow = anyModalOpen() ? 'hidden' : ''; }
    function anyModalOpen() {
      return (drawer && drawer.open) || (lModal && lModal.open);
    }

    function add(item) {
      if (!item || !item.slug) return;
      var c = read();
      // One licence per product — re-adding just reopens the cart, never stacks qty.
      var exists = c.some(function (i) { return i.slug === item.slug; });
      if (!exists) {
        c.push({ slug: item.slug, name: item.name, price: +item.price || 0, checkoutUrl: item.checkoutUrl || '', img: item.img || '', qty: 1 });
        write(c);
      }
      sync(); openDrawer();
    }
    function remove(slug) {
      write(read().filter(function (i) { return i.slug !== slug; }));
      sync();
    }

    function sync() {
      var c = read();
      var n = count(c);
      var badges = document.querySelectorAll('[data-cart-badge]');
      for (var b = 0; b < badges.length; b++) { badges[b].textContent = n; badges[b].hidden = n === 0; }
      if (!itemsEl) return;
      if (!c.length) {
        itemsEl.innerHTML = '';
        if (emptyEl) emptyEl.hidden = false;
        if (footEl) footEl.hidden = true;
        return;
      }
      if (emptyEl) emptyEl.hidden = true;
      if (footEl) footEl.hidden = false;
      var sub = 0;
      itemsEl.innerHTML = c.map(function (i) {
        sub += (i.price || 0) * (i.qty || 1);
        return '<li class="ci">' +
          (i.img ? '<img class="ci-img" src="' + esc(i.img) + '" alt="" width="56" height="32" loading="lazy">' : '') +
          '<div class="ci-main"><span class="ci-name">' + esc(i.name) + '</span>' +
          '<span class="ci-meta">' + ((i.qty || 1) > 1 ? (i.qty + ' &times; ') : '') + '$' + (i.price || 0) + '</span></div>' +
          '<button type="button" class="ci-x" data-remove="' + esc(i.slug) + '" aria-label="Remove ' + esc(i.name) + '">&times;</button>' +
          '</li>';
      }).join('');
      if (subEl) subEl.textContent = '$' + sub;
    }

    function openDrawer() {
      if (!drawer) return;
      if (typeof drawer.showModal === 'function') drawer.showModal(); else drawer.setAttribute('open', '');
      lock();
    }

    // ---- Lemon Squeezy overlay ----
    var lemonReady = false;
    function ensureLemon() {
      if (lemonReady) return !!(window.LemonSqueezy && window.LemonSqueezy.Url);
      if (typeof window.createLemonSqueezy !== 'function') return false;
      try {
        window.createLemonSqueezy();
        window.LemonSqueezy.Setup({
          eventHandler: function (ev) {
            if (ev && ev.event === 'Checkout.Success') {
              write([]); sync();
              window.location.href = '/thank-you';
            }
          }
        });
        lemonReady = true;
      } catch (e) {}
      return lemonReady;
    }

    function checkoutMap() {
      var el = document.querySelector('[data-checkout-map]');
      try { return el ? JSON.parse(el.textContent || '{}') : {}; } catch (e) { return {}; }
    }
    function checkoutUrlFor(item) {
      var map = checkoutMap();
      return (item && map[item.slug]) || (item && item.checkoutUrl) || '';
    }

    // ---- Consent gate: a required checkbox in the cart, ticked before checkout ----
    function agreeEl() { return drawer && drawer.querySelector('[data-cart-agree]'); }
    function setAgreeError(on) {
      var label = drawer && drawer.querySelector('[data-agree-label]');
      var hint = drawer && drawer.querySelector('[data-agree-hint]');
      if (label) label.classList.toggle('is-error', !!on);
      if (hint) hint.hidden = !on;
    }
    function openCheckout() {
      var items = read().filter(function (i) { return checkoutUrlFor(i); });
      if (!items.length) return;
      // Require agreement first — flag the checkbox and stop if unchecked.
      var agree = agreeEl();
      if (agree && !agree.checked) { setAgreeError(true); agree.focus(); return; }
      setAgreeError(false);
      var url = checkoutUrlFor(items[0]);
      url += (url.indexOf('?') === -1 ? '?' : '&') + 'embed=1';
      // Consent record: stamp the accepted legal-bundle version onto the order via
      // LS custom passthrough data. (LS docs: Passing Custom Data.)
      url += '&checkout[custom][terms_accepted]=true';
      var ver = (agree && agree.getAttribute('data-terms-version')) || '';
      if (ver) url += '&checkout[custom][terms_version]=' + encodeURIComponent(ver);
      if (drawer && drawer.open) drawer.close();
      if (ensureLemon()) { window.LemonSqueezy.Url.Open(url); return; }
      window.location.href = url;
    }

    // ---- Legal reader modal (read-only; Terms / Licence / Privacy tabs) ----
    var lModal = document.querySelector('[data-legal-modal]');
    var lScroll = lModal && lModal.querySelector('[data-legal-scroll]');
    function setLegalTab(doc) {
      if (!lModal) return;
      var tabs = lModal.querySelectorAll('[data-legal-tab]');
      for (var i = 0; i < tabs.length; i++) {
        var on = tabs[i].getAttribute('data-legal-tab') === doc;
        tabs[i].classList.toggle('is-active', on);
        tabs[i].setAttribute('aria-selected', on ? 'true' : 'false');
      }
      var panels = lModal.querySelectorAll('[data-legal-panel]');
      for (var j = 0; j < panels.length; j++) {
        panels[j].hidden = panels[j].getAttribute('data-legal-panel') !== doc;
      }
      if (lScroll) lScroll.scrollTop = 0;
    }
    function openLegal(doc) {
      if (!lModal) return;
      setLegalTab(doc || 'terms');
      if (typeof lModal.showModal === 'function') lModal.showModal(); else lModal.setAttribute('open', '');
      lock();
    }
    function closeLegal() {
      if (lModal && lModal.open && typeof lModal.close === 'function') lModal.close();
      else if (lModal) { lModal.removeAttribute('open'); lock(); }
    }

    document.addEventListener('click', function (e) {
      var t = e.target;
      var addBtn = t.closest('[data-add-to-cart]');
      if (addBtn) {
        e.preventDefault();
        add({
          slug: addBtn.getAttribute('data-slug'),
          name: addBtn.getAttribute('data-name'),
          price: addBtn.getAttribute('data-price'),
          checkoutUrl: addBtn.getAttribute('data-checkout-url'),
          img: addBtn.getAttribute('data-img')
        });
        return;
      }
      if (t.closest('[data-cart-toggle]')) { e.preventDefault(); openDrawer(); return; }
      var rm = t.closest('[data-remove]');
      if (rm) { remove(rm.getAttribute('data-remove')); return; }
      if (t.closest('[data-checkout]')) { e.preventDefault(); openCheckout(); return; }

      // Open the legal reader from the cart's consent links (popup, not a page).
      var openL = t.closest('[data-open-legal]');
      if (openL) { e.preventDefault(); openLegal(openL.getAttribute('data-open-legal')); return; }
      // Tab switching inside the reader.
      var tabBtn = t.closest('[data-legal-tab]');
      if (tabBtn) { e.preventDefault(); setLegalTab(tabBtn.getAttribute('data-legal-tab')); return; }
      if (t.closest('[data-legal-close]')) { e.preventDefault(); closeLegal(); return; }
      // Internal legal cross-links inside the reader → switch tab, stay in the popup.
      if (lModal && lModal.open && lModal.contains(t)) {
        var xref = t.closest('a[href^="/terms"], a[href^="/eula"], a[href^="/privacy"]');
        if (xref) {
          var href = xref.getAttribute('href');
          var doc = href.indexOf('/privacy') === 0 ? 'privacy' : href.indexOf('/eula') === 0 ? 'eula' : href.indexOf('/terms') === 0 ? 'terms' : '';
          if (doc) { e.preventDefault(); setLegalTab(doc); return; }
        }
      }

      if (t.closest('[data-cart-close]') && drawer && drawer.open) { drawer.close(); return; }
    });

    if (drawer) {
      drawer.addEventListener('click', function (e) { if (e.target === drawer) drawer.close(); }); // backdrop
      drawer.addEventListener('close', lock);
      drawer.addEventListener('change', function (e) {
        if (e.target && e.target.matches('[data-cart-agree]') && e.target.checked) setAgreeError(false);
      });
    }
    if (lModal) {
      lModal.addEventListener('close', lock);
      lModal.addEventListener('click', function (e) { if (e.target === lModal) closeLegal(); }); // backdrop
    }

    sync();
  })();
</script>

<style>
  /* ---- Cart drawer (slides from the right) ---- */
  .cart-drawer {
    margin: 0 0 0 auto;
    height: 100dvh;
    max-height: 100dvh;
    width: min(380px, 92vw);
    padding: 0;
    border: 0;
    border-left: 1px solid var(--border-bright);
    background: var(--bg-1);
    color: var(--fg);
    box-shadow: -24px 0 80px rgba(0, 0, 0, 0.6);
    transform: translateX(100%);
    transition: transform 0.28s var(--ease), overlay 0.28s ease allow-discrete, display 0.28s ease allow-discrete;
  }
  .cart-drawer[open] { transform: translateX(0); }
  @starting-style { .cart-drawer[open] { transform: translateX(100%); } }

  .cart-drawer::backdrop { background: rgba(8, 7, 6, 0); transition: background 0.28s ease; }
  .cart-drawer[open]::backdrop { background: rgba(8, 7, 6, 0.6); backdrop-filter: blur(4px); }
  @starting-style { .cart-drawer[open]::backdrop { background: rgba(8, 7, 6, 0); } }

  .cd-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.25rem 1.25rem 1rem;
    border-bottom: 1px solid var(--border);
  }
  .cd-head h2 { margin: 0; font-size: 1.5rem; color: var(--fg); }

  .cd-x {
    width: 34px; height: 34px; border-radius: 50%;
    border: 1px solid var(--border-bright);
    background: var(--bg-0); color: var(--fg);
    font-size: 1.4rem; line-height: 1; cursor: pointer;
    transition: border-color 0.2s var(--ease), color 0.2s var(--ease);
  }
  .cd-x:hover { border-color: var(--brass); color: var(--brass-bright); }

  .cd-empty { padding: 2rem 1.25rem; color: var(--fg-dim); }

  .cd-items { list-style: none; margin: 0; padding: 0.5rem 0.75rem; overflow-y: auto; }
  /* Cart items are injected at runtime, so they need :global to escape Astro scoping. */
  .cd-items :global(.ci) {
    display: flex; align-items: center; gap: 0.85rem;
    padding: 0.85rem 0.5rem; border-bottom: 1px solid var(--border);
  }
  .cd-items :global(.ci-img) { border-radius: 6px; border: 1px solid var(--border); object-fit: cover; flex: none; }
  .cd-items :global(.ci-main) { display: flex; flex-direction: column; gap: 0.15rem; flex: 1; min-width: 0; }
  .cd-items :global(.ci-name) { font-family: var(--font-display); letter-spacing: 0.03em; color: var(--brass-bright); font-size: 1.1rem; }
  .cd-items :global(.ci-meta) { font-family: var(--font-mono); font-size: 0.8rem; color: var(--fg-dim); }
  .cd-items :global(.ci-x) {
    flex: none; width: 26px; height: 26px; border-radius: 50%;
    border: 1px solid var(--border); background: transparent; color: var(--fg-faint);
    font-size: 1rem; line-height: 1; cursor: pointer;
    transition: color 0.2s, border-color 0.2s;
  }
  .cd-items :global(.ci-x:hover) { color: var(--redline); border-color: var(--redline); }

  .cd-foot {
    margin-top: auto;
    padding: 1.1rem 1.25rem 1.4rem;
    border-top: 1px solid var(--border);
    display: flex; flex-direction: column; gap: 0.75rem;
  }
  .cd-sub {
    display: flex; justify-content: space-between; align-items: baseline;
    font-family: var(--font-mono); font-size: 0.95rem; color: var(--fg);
  }
  .cd-sub span:last-child { color: var(--brass-bright); font-size: 1.15rem; }

  /* Consent checkbox — required before checkout; its links open the reader popup. */
  .cd-agree {
    display: flex; align-items: flex-start; gap: 0.55rem;
    font-size: 0.8rem; line-height: 1.4; color: var(--fg-dim); cursor: pointer;
  }
  .cd-agree input {
    flex: none; width: 16px; height: 16px; margin-top: 0.1rem;
    accent-color: var(--brass); cursor: pointer;
  }
  .cd-agree a { color: var(--brass-bright); text-decoration: underline; cursor: pointer; }
  .cd-agree a:hover { color: var(--brass); }
  .cd-agree.is-error { color: var(--redline); }
  .cd-agree.is-error input { outline: 2px solid var(--redline); outline-offset: 1px; }
  .cd-agree-hint { margin: -0.35rem 0 0; font-size: 0.75rem; color: var(--redline); }

  /* CHECKOUT panel — plate is decorative; the .panel-hit over the red button clicks. */
  .cd-checkout { width: 100%; }
  .cd-cont {
    background: none; border: 0; color: var(--fg-dim);
    font-size: 0.85rem; cursor: pointer; padding: 0.25rem;
  }
  .cd-cont:hover { color: var(--brass-bright); }

  /* drawer is a flex column so cd-foot can pin to the bottom */
  .cart-drawer { display: flex; flex-direction: column; }
  .cart-drawer:not([open]) { display: none; }

  /* ---- Legal reader modal (centered, tabbed) ---- */
  .legal-modal {
    margin: auto;
    width: min(720px, 94vw);
    max-height: min(88dvh, 900px);
    padding: 0;
    border: 1px solid var(--border-bright);
    border-radius: 14px;
    background: var(--bg-1);
    color: var(--fg);
    box-shadow: 0 30px 90px rgba(0, 0, 0, 0.65);
    flex-direction: column;
    overflow: hidden;
  }
  .legal-modal[open] { display: flex; }
  .legal-modal:not([open]) { display: none; }
  .legal-modal::backdrop { background: rgba(8, 7, 6, 0); transition: background 0.28s ease; }
  .legal-modal[open]::backdrop { background: rgba(8, 7, 6, 0.72); backdrop-filter: blur(4px); }
  @starting-style { .legal-modal[open]::backdrop { background: rgba(8, 7, 6, 0); } }

  .lm-head {
    display: flex; align-items: center; justify-content: space-between; gap: 0.75rem;
    padding: 0.9rem 1.1rem; border-bottom: 1px solid var(--border); flex: none;
  }
  .lm-tabs { display: flex; gap: 0.3rem; flex-wrap: wrap; }
  .lm-tab {
    padding: 0.4rem 0.8rem; border-radius: 7px; border: 1px solid var(--border);
    background: transparent; color: var(--fg-dim);
    font-family: var(--font-mono); font-size: 0.76rem; letter-spacing: 0.02em; cursor: pointer;
    transition: color 0.2s, border-color 0.2s, background 0.2s;
  }
  .lm-tab:hover { color: var(--brass-bright); border-color: var(--border-bright); }
  .lm-tab.is-active { color: var(--bg-0); background: var(--brass); border-color: var(--brass); }

  .lm-body { flex: 1; overflow-y: auto; padding: 0.4rem 1.35rem 1.2rem; }
  .lm-body:focus-visible { outline: 2px solid var(--brass); outline-offset: -3px; }
  /* Content comes from separate components, so style via :global. */
  .lm-body :global(.muted) { color: var(--fg-faint); font-size: 0.8rem; }
  .lm-body :global(h2) { font-size: 1.1rem; color: var(--fg); margin: 1.5rem 0 0.4rem; }
  .lm-body :global(p) { font-size: 0.88rem; line-height: 1.6; color: var(--fg-dim); margin: 0 0 0.6rem; }
  .lm-body :global(ul) { margin: 0 0 0.7rem; padding-left: 1.2rem; }
  .lm-body :global(li) { font-size: 0.88rem; line-height: 1.55; color: var(--fg-dim); margin: 0 0 0.3rem; }
  .lm-body :global(a) { color: var(--brass-bright); text-decoration: underline; }
  .lm-body :global(strong) { color: var(--fg); }
  .lm-body :global(code) { font-family: var(--font-mono); font-size: 0.82em; color: var(--brass-bright); }
</style>
