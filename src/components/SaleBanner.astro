---
/**
 * Site-wide launch-sale marquee. Mounted in BaseLayout above the Header;
 * config lives in src/data/site.ts (site.launchSale) — flip `active` there
 * to kill it everywhere. Honest by default: no countdown, real copy only.
 *
 * Sticky at top: 0 (z 60, one layer above the nav's 50). The nav parks
 * underneath via `top: var(--sale-h)`; body.has-sale in BaseLayout sets
 * that token, so with the sale off the nav returns to top: 0 with no gap.
 *
 * Marquee = two identical groups animated -50%; each group repeats the
 * message 3× so the group outruns wide viewports and the loop is seamless.
 * Pauses on hover; reduced-motion users get a single static centered line.
 */
import { site } from '../data/site';

const sale = site.launchSale;
const REPEATS = 3;
---

{
  sale.active && (
    <aside class="sale-banner" role="region" aria-label={`Launch sale: ${sale.pct}% off with code ${sale.code}`}>
      <div class="track">
        {[0, 1].map((group) => (
          <div class="group" aria-hidden={group === 1 ? 'true' : undefined}>
            {Array.from({ length: REPEATS }).map(() => (
              <span class="seg">
                LAUNCH SALE — <strong class="pct">{sale.pct}% OFF</strong> RevLimiter — Insert coupon code{' '}
                <strong class="code">"{sale.code}"</strong> at checkout — LIMITED TIME
                <span class="sep" aria-hidden="true">|</span>
              </span>
            ))}
          </div>
        ))}
      </div>
    </aside>
  )
}

<style>
  /* Race-track strip: asphalt slab + a dashed road centre-line the message
     drives along, framed by checkered-flag rails top & bottom. */
  .sale-banner {
    position: sticky;
    top: 0;
    z-index: 60;
    height: var(--sale-h, 41px);
    overflow: hidden;
    display: flex;
    align-items: center;
    background:
      /* dashed yellow lane line, centred band */
      repeating-linear-gradient(90deg, transparent 0 17px, rgba(214, 178, 90, 0.8) 17px 34px) center / 100% 3px no-repeat,
      /* asphalt */
      linear-gradient(180deg, #1b1b1e 0%, #27272b 50%, #1b1b1e 100%);
  }

  /* Checkered-flag rails. ::before = top, ::after = bottom. A tiled conic
     checkerboard (light chrome vs near-black), one cell tall per rail. */
  .sale-banner::before,
  .sale-banner::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    height: 4px;
    background: repeating-conic-gradient(#f7f7f7 0 90deg, #000000 0 180deg) 0 0 / 5px 5px;
    z-index: 1;
  }
  .sale-banner::before { top: 0; }
  .sale-banner::after { bottom: 0; }

  .track {
    display: flex;
    width: max-content;
    animation: sale-scroll 45s linear infinite;
    will-change: transform;
  }
  .sale-banner:hover .track { animation-play-state: paused; }

  .group {
    display: flex;
    flex-shrink: 0;
  }

  .seg {
    display: inline-flex;
    align-items: center;
    white-space: nowrap;
    padding-right: 1.1rem;
    font-family: var(--font-display);
    font-size: 0.92rem;
    letter-spacing: 0.14em;
    color: var(--fg);
    /* Solid asphalt outline around every glyph so the bright lane line breaks
       AT the text — letters read full-colour over the road, lane shows only in
       the gaps between words. (text-shadow is inherited → .pct picks it up.) */
    text-shadow:
      -2px 0 #1b1b1e, 2px 0 #1b1b1e, 0 -2px #1b1b1e, 0 2px #1b1b1e,
      -2px -2px #1b1b1e, 2px 2px #1b1b1e, 2px -2px #1b1b1e, -2px 2px #1b1b1e,
      0 0 3px #1b1b1e;
  }

  .pct,
  .code {
    font-weight: inherit;
    color: var(--brass-bright);
    margin: 0 0.35em;
  }
  .code {
    color: var(--chrome, #e8e6e1);
    /* Same asphalt outline as .seg (override would otherwise drop it) + the
       chrome glow on top. */
    text-shadow:
      -2px 0 #1b1b1e, 2px 0 #1b1b1e, 0 -2px #1b1b1e, 0 2px #1b1b1e,
      -2px -2px #1b1b1e, 2px 2px #1b1b1e, 2px -2px #1b1b1e, -2px 2px #1b1b1e,
      0 0 8px rgba(232, 230, 225, 0.25);
  }

  .sep {
    margin-left: 1.1rem;
    color: var(--brass);
    opacity: 0.7;
    /* the divider can sit on the lane line too — keep it readable */
    text-shadow:
      -2px 0 #1b1b1e, 2px 0 #1b1b1e, 0 -2px #1b1b1e, 0 2px #1b1b1e,
      0 0 3px #1b1b1e;
  }

  @keyframes sale-scroll {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }

  /* Reduced motion: one static centered line, duplicates hidden. */
  @media (prefers-reduced-motion: reduce) {
    .track { animation: none; width: 100%; justify-content: center; }
    .group[aria-hidden] { display: none; }
    .group .seg:not(:first-child) { display: none; }
    .sep { display: none; }
  }

  @media (max-width: 700px) {
    .seg { font-size: 0.8rem; letter-spacing: 0.1em; }
  }
</style>
