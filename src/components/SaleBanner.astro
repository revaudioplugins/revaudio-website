---
/**
 * Site-wide launch-sale marquee. Mounted in BaseLayout above the Header;
 * config lives in src/data/site.ts (site.launchSale) — flip `active` there
 * to kill it everywhere. Honest by default: no countdown, real copy only.
 *
 * Sticky at top: 0 (z 60, one layer above the nav's 50). The nav parks
 * underneath via `top: var(--sale-h)`; body.has-sale in BaseLayout sets
 * that token, so with the sale off the nav returns to top: 0 with no gap.
 *
 * Marquee = two identical groups animated -50%; each group repeats the
 * message 3× so the group outruns wide viewports and the loop is seamless.
 * Pauses on hover; reduced-motion users get a single static centered line.
 */
import { site } from '../data/site';

const sale = site.launchSale;
const REPEATS = 3;
---

{
  sale.active && (
    <aside class="sale-banner" role="region" aria-label={`Launch sale: ${sale.pct}% off with code ${sale.code}`}>
      <div class="track">
        {[0, 1].map((group) => (
          <div class="group" aria-hidden={group === 1 ? 'true' : undefined}>
            {Array.from({ length: REPEATS }).map(() => (
              <span class="seg">
                LAUNCH SALE — <strong class="pct">{sale.pct}% OFF</strong> EVERYTHING — CODE{' '}
                <strong class="code">{sale.code}</strong> AT CHECKOUT — LIMITED TIME
                <span class="flag" aria-hidden="true">
                  🏁
                </span>
              </span>
            ))}
          </div>
        ))}
      </div>
    </aside>
  )
}

<style>
  .sale-banner {
    position: sticky;
    top: 0;
    z-index: 60;
    height: var(--sale-h, 34px);
    overflow: hidden;
    display: flex;
    align-items: center;
    background: linear-gradient(90deg, var(--oxide-deep), var(--bg-1) 45%, var(--oxide-deep));
    border-bottom: 1px solid var(--brass-dark);
  }

  .track {
    display: flex;
    width: max-content;
    animation: sale-scroll 45s linear infinite;
    will-change: transform;
  }
  .sale-banner:hover .track { animation-play-state: paused; }

  .group {
    display: flex;
    flex-shrink: 0;
  }

  .seg {
    display: inline-flex;
    align-items: center;
    white-space: nowrap;
    padding-right: 1.1rem;
    font-family: var(--font-display);
    font-size: 0.92rem;
    letter-spacing: 0.14em;
    color: var(--fg);
  }

  .pct,
  .code {
    font-weight: inherit;
    color: var(--brass-bright);
    margin: 0 0.35em;
  }
  .code { color: var(--chrome, #e8e6e1); text-shadow: 0 0 8px rgba(232, 230, 225, 0.25); }

  .flag {
    font-size: 0.8rem;
    margin-left: 1.1rem;
    filter: saturate(0.6);
  }

  @keyframes sale-scroll {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }

  /* Reduced motion: one static centered line, duplicates hidden. */
  @media (prefers-reduced-motion: reduce) {
    .track { animation: none; width: 100%; justify-content: center; }
    .group[aria-hidden] { display: none; }
    .group .seg:not(:first-child) { display: none; }
    .flag { display: none; }
  }

  @media (max-width: 700px) {
    .seg { font-size: 0.8rem; letter-spacing: 0.1em; }
  }
</style>
