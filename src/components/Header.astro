---
import { Image } from 'astro:assets';
import { plugins } from '../data/plugins';
import cartIcon from '../assets/ui/icon-cart.png';

const path = Astro.url.pathname;
const isActive = (p: string) => path === p || path === p + '/';
const onProductPage = plugins.some((pl) => isActive(`/${pl.slug}`));
---

<nav class="site-nav" data-site-nav aria-label="Main navigation">
  <div class="nav-inner">
    <a href="/" class="logo" aria-label="RevAudio — home">
      {/* Spinning 3D brand plate. Animated WebP (alpha) plays in Safari/Chrome/FF
          and clicks pass through to the home link; reduced-motion gets a still. */}
      <picture>
        <source srcset="/brand/revaudio-plate-3d-static.webp" media="(prefers-reduced-motion: reduce)" />
        {/* Mobile (≤900px) serves the 13KB static plate — <source media> is
            picked at parse time so the 264KB animated webp is never fetched on
            phones. Wider screens fall through to the animated <img> below. */}
        <source srcset="/brand/revaudio-plate-3d-static.webp" media="(max-width: 900px)" />
        {/* Desktop ships the 13KB static plate in the critical path and swaps
            in the 264KB animated file on idle (script below). */}
        <img
          src="/brand/revaudio-plate-3d-static.webp"
          data-logo-anim="/brand/revaudio-plate-3d.webp"
          alt="RevAudio"
          width="660"
          height="216"
          class="logo-anim"
          loading="eager"
          decoding="async"
        />
      </picture>
    </a>
    <div class="nav-right">
      <ul id="nav-menu" class="nav-links">
        <li><a href="/" aria-current={isActive('/') ? 'page' : undefined}>Home</a></li>
        <li><a href="/store" aria-current={isActive('/store') || onProductPage ? 'page' : undefined}>Store</a></li>
        <li><a href="https://revlimiter-license.revaudio.workers.dev/download" target="_blank" rel="noopener noreferrer">Downloads</a></li>
        <li><a href="/about" aria-current={isActive('/about') ? 'page' : undefined}>About</a></li>
        <li><a href="/support" aria-current={isActive('/support') ? 'page' : undefined}>Support</a></li>
        <li><a href="/affiliate" aria-current={isActive('/affiliate') ? 'page' : undefined}>Affiliates</a></li>
        <li><a href="/terms" aria-current={isActive('/terms') ? 'page' : undefined}>T&amp;C</a></li>
      </ul>
      <button type="button" class="cart-toggle" data-cart-toggle aria-label="Open cart">
        <Image src={cartIcon} alt="" width={88} height={88} format="webp" class="cart-ico" />
        <span class="cart-badge" data-cart-badge hidden>0</span>
      </button>
      <button
        type="button"
        class="nav-burger"
        data-nav-toggle
        aria-controls="nav-menu"
        aria-expanded="false"
        aria-label="Menu"
      >
        <span class="burger-box"><span class="burger-line"></span></span>
      </button>
    </div>
  </div>
</nav>

<script is:inline>
  (function () {
    var nav = document.querySelector('[data-site-nav]');
    if (!nav) return;
    var burger = nav.querySelector('[data-nav-toggle]');
    var menu = nav.querySelector('#nav-menu');
    if (!burger || !menu) return;

    function setOpen(open) {
      nav.classList.toggle('nav-open', open);
      burger.setAttribute('aria-expanded', open ? 'true' : 'false');
    }
    function isOpen() { return nav.classList.contains('nav-open'); }

    burger.addEventListener('click', function (e) {
      e.stopPropagation();
      setOpen(!isOpen());
    });
    // Tapping a link navigates; collapse so it's tidy on back-nav.
    menu.addEventListener('click', function (e) {
      if (e.target.closest('a')) setOpen(false);
    });
    // Outside click / Escape close.
    document.addEventListener('click', function (e) {
      if (isOpen() && !nav.contains(e.target)) setOpen(false);
    });
    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape' && isOpen()) { setOpen(false); burger.focus(); }
    });
    // Re-show desktop nav if the viewport grows past the breakpoint.
    var mq = window.matchMedia('(min-width: 701px)');
    (mq.addEventListener ? mq.addEventListener.bind(mq, 'change') : mq.addListener.bind(mq))(function (ev) {
      if (ev.matches) setOpen(false);
    });

    // Idle-swap the animated brand plate on desktop: keeps 264KB off the
    // critical path. <source media> already keeps phones/reduced-motion on
    // the static file, so the swap only ever takes effect on wide screens.
    var logo = nav.querySelector('[data-logo-anim]');
    if (logo && window.matchMedia('(min-width: 901px)').matches
        && !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      var swap = function () {
        var pre = new Image();
        pre.onload = function () { logo.src = logo.dataset.logoAnim; };
        pre.src = logo.dataset.logoAnim;
      };
      ('requestIdleCallback' in window) ? requestIdleCallback(swap, { timeout: 4000 }) : setTimeout(swap, 1500);
    }
  })();
</script>

<style>
  .nav-right { display: flex; align-items: center; gap: 1.75rem; }

  .cart-toggle {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0;
    border: 0;
    background: transparent;
    cursor: pointer;
    line-height: 0;
  }
  .cart-ico { width: 30px; height: 30px; display: block; transition: filter 0.2s var(--ease), transform 0.12s var(--ease); }
  .cart-toggle:hover .cart-ico { filter: brightness(1.12); transform: translateY(-1px); }

  .cart-badge {
    position: absolute;
    top: -3px;
    right: -3px;
    min-width: 18px;
    height: 18px;
    padding: 0 5px;
    border-radius: 9px;
    background: var(--brass);
    color: var(--bg-0);
    font-family: var(--font-mono);
    font-size: 0.7rem;
    font-weight: 700;
    line-height: 18px;
    text-align: center;
  }

  /* ---- Hamburger (mobile only) ---- */
  .nav-burger {
    display: none; /* shown ≤700px */
    width: 44px;
    height: 44px;
    padding: 0;
    border: 1px solid var(--border-bright);
    border-radius: 8px;
    background: var(--bg-1);
    cursor: pointer;
    align-items: center;
    justify-content: center;
    transition: border-color 0.2s var(--ease), background 0.2s var(--ease);
  }
  .nav-burger:hover { border-color: var(--brass-dark); }

  /* 3 brass bars built from one element + its ::before/::after, so the middle
     bar can fade and the outer two rotate into an X on open. */
  .burger-box { position: relative; width: 20px; height: 14px; display: block; }
  .burger-line,
  .burger-line::before,
  .burger-line::after {
    position: absolute;
    left: 0;
    width: 100%;
    height: 2px;
    border-radius: 2px;
    background: var(--brass-bright);
    transition: transform 0.25s var(--ease), opacity 0.2s var(--ease);
  }
  .burger-line { top: 6px; }
  .burger-line::before { content: ''; top: -6px; }
  .burger-line::after { content: ''; top: 6px; }

  .nav-open .burger-line { background: transparent; }
  .nav-open .burger-line::before { transform: translateY(6px) rotate(45deg); background: var(--brass-bright); }
  .nav-open .burger-line::after { transform: translateY(-6px) rotate(-45deg); background: var(--brass-bright); }

  @media (max-width: 700px) {
    .nav-right { gap: 0.85rem; }
    .nav-burger { display: inline-flex; }

    /* Touch tap-target: pad the box to 44px (icon stays 30px). Mobile-scoped so
       the desktop nav + absolutely-positioned badge stay pixel-identical. */
    .cart-toggle { padding: 7px; }
    .cart-badge { top: 4px; right: 4px; font-size: 0.75rem; } /* Phase B: ≥12px count */

    /* Links collapse into a slide-down panel under the bar. */
    .nav-links {
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      flex-direction: column;
      gap: 0;
      padding: 0.5rem 0 0.75rem;
      background: rgba(11, 10, 9, 0.97);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid var(--border);
      box-shadow: 0 16px 40px rgba(0, 0, 0, 0.5);
      /* collapsed state */
      opacity: 0;
      transform: translateY(-8px);
      pointer-events: none;
      transition: opacity 0.22s var(--ease), transform 0.22s var(--ease);
    }
    .nav-open .nav-links {
      opacity: 1;
      transform: none;
      pointer-events: auto;
    }
    .nav-links li { width: 100%; }
    .nav-links a {
      display: block;
      padding: 0.95rem 1.5rem;
      font-size: 1.05rem;
      color: var(--fg);
      border-bottom: 1px solid var(--border);
    }
    .nav-links li:last-child a { border-bottom: 0; }
    .nav-links a[aria-current='page'] { color: var(--brass-bright); }
    .nav-links a:hover { color: var(--brass-bright); }
  }
</style>
