---
const path = Astro.url.pathname;
const isActive = (p: string) => path === p || path === p + '/';
---

<nav class="site-nav">
  <div class="nav-inner">
    <a href="/" class="logo">REV<span class="accent">AUDIO</span></a>
    <ul>
      <li><a href="/" aria-current={isActive('/') ? 'page' : undefined}>Home</a></li>
      <li><a href="/revlimiter">RevLimiter</a></li>
      <li><a href="/the-ac">The AC</a></li>
      <li><a href="/the-cooker">The Cooker</a></li>
      <li><a href="/maybach">Maybach</a></li>
      <li><a href="/store" aria-current={isActive('/store') ? 'page' : undefined}>Store</a></li>
      <li><a href="/about">About</a></li>
    </ul>
  </div>
</nav>
