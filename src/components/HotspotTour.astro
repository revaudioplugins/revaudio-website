---
/* C1 — "Under the hood" tap-to-explore callouts (mobile-only, ≤900px).
   Numbered hotspot badges float over the real RevLimiter panel; tapping one
   highlights it and swaps a detail card below the image. Desktop hides the
   whole section (display:none >900px) — desktop already has the interactive
   walkthrough. Reuses the plugin's own measured `stage.parts` rects (the same
   ones the desktop part-highlighter animates onto) to place each badge, and
   pulls the control name + one-line copy straight from `features` by `part`
   slug — no invented DSP claims. Add a `stage` + `part`-tagged features to any
   plugin and it works with no template change. */
import { Image } from 'astro:assets';
import type { Plugin } from '../data/plugins';
import { pluginImage } from '../lib/images';

interface Props {
  plugin: Plugin;
}
const { plugin } = Astro.props;

const shot = plugin.stage ? pluginImage(plugin.stage.shot) : undefined;

// The curated tour: real controls, in a top-to-bottom-ish reading order.
// Each slug must resolve to a rect part (not a `shot`-swap) AND a feature.
const TOUR_SLUGS = ['ab', 'gauge', 'ceiling', 'bands', 'saturation', 'meters'];

type Hotspot = { slug: string; name: string; desc: string; cx: number; cy: number };
const hotspots: Hotspot[] = plugin.stage
  ? TOUR_SLUGS.flatMap((slug) => {
      const part = plugin.stage!.parts[slug];
      const feat = plugin.features.find((f) => f.part === slug);
      if (!part || !('x' in part) || !feat) return [];
      // Badge sits at the rect centre — the same rect the desktop box animates onto.
      return [{ slug, name: feat.name, desc: feat.desc, cx: part.x + part.w / 2, cy: part.y + part.h / 2 }];
    })
  : [];

const show = !!shot && hotspots.length >= 5;
---

{show && (
  <section class="hotspot-tour" aria-labelledby="ht-heading" data-hotspot-tour>
    <h2 id="ht-heading" data-split>Under the hood</h2>
    <p class="ht-lede">Tap a number to see what each control does.</p>

    <figure class="ht-figure">
      <Image
        src={shot!}
        alt={`${plugin.name} interface`}
        width={1100}
        widths={[600, 900, 1100]}
        sizes="100vw"
        format="webp"
        loading="lazy"
        class="ht-shot"
      />
      {hotspots.map((h, i) => (
        <button
          type="button"
          class="ht-badge"
          data-ht-badge={h.slug}
          style={`left:${h.cx}%; top:${h.cy}%;`}
          aria-pressed={i === 0 ? 'true' : 'false'}
          aria-label={`${i + 1}. ${h.name}`}
        >{i + 1}</button>
      ))}
    </figure>

    <div class="ht-card" data-ht-card aria-live="polite">
      {hotspots.map((h, i) => (
        <div class="ht-detail" data-ht-detail={h.slug} hidden={i !== 0}>
          <span class="ht-num" aria-hidden="true">{String(i + 1).padStart(2, '0')}</span>
          <div class="ht-body">
            <span class="ht-name">{h.name}</span>
            <p class="ht-desc">{h.desc}</p>
          </div>
        </div>
      ))}
    </div>
  </section>
)}

<style>
  /* Mobile-only: the desktop walkthrough already tells this story interactively. */
  .hotspot-tour { display: none; }

  @media (max-width: 900px) {
    .hotspot-tour {
      display: block;
      padding: 2rem 0 3rem;
      border-top: 1px solid var(--border);
    }
  }

  .ht-lede {
    font-family: var(--font-mono);
    text-transform: uppercase;
    font-size: 0.85rem;
    letter-spacing: 0.08em;
    color: var(--brass);
    margin: 0 0 1.25rem;
  }

  .ht-figure {
    position: relative;
    margin: 0;
    border: 1px solid var(--border-bright);
    border-radius: 10px;
    overflow: hidden;
    background: var(--bg-2);
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.5);
  }

  .ht-shot { width: 100%; height: auto; display: block; }

  /* Circular numbered badge — race-red, VT323 numeral, ≥44px tap target,
     centred on its control via a translate(-50%,-50%). */
  .ht-badge {
    position: absolute;
    transform: translate(-50%, -50%);
    width: 44px;
    height: 44px;
    border-radius: 50%;
    display: grid;
    place-items: center;
    padding: 0;
    cursor: pointer;
    font-family: 'VT323', var(--font-mono);
    font-size: 1.5rem;
    line-height: 1;
    color: #f4ead6;
    background: #e83a3a;
    border: 2px solid #120804;
    box-shadow: 0 3px 10px rgba(0, 0, 0, 0.5), 0 0 0 4px rgba(232, 58, 58, 0.18);
    transition: transform 0.15s var(--ease), box-shadow 0.2s var(--ease), background 0.2s var(--ease);
  }

  .ht-badge:active { transform: translate(-50%, -50%) scale(0.92); }

  .ht-badge[aria-pressed='true'] {
    background: #ff4a4a;
    box-shadow: 0 3px 12px rgba(0, 0, 0, 0.55), 0 0 0 5px rgba(232, 200, 120, 0.55);
    z-index: 2;
  }

  .ht-badge:focus-visible {
    outline: 2px solid var(--brass-bright);
    outline-offset: 3px;
  }

  @media (hover: hover) {
    .ht-badge:hover { background: #ff4a4a; }
  }

  @media (prefers-reduced-motion: reduce) {
    .ht-badge { transition: none; }
  }

  /* Detail card — mono spec-row styling, mirrors .spec-row / walk-step voice. */
  .ht-card {
    margin-top: 1rem;
    background: var(--bg-1);
    border: 1px solid var(--border-bright);
    border-left: 3px solid var(--brass);
    border-radius: 6px;
    min-height: 92px;
  }

  .ht-detail {
    display: flex;
    gap: 0.9rem;
    align-items: flex-start;
    padding: 1rem 1.15rem;
  }

  /* `display:flex` above outranks the UA `[hidden]{display:none}`, so hide
     inactive details explicitly — otherwise every card stacks at once. */
  .ht-detail[hidden] { display: none; }

  .ht-num {
    font-family: 'VT323', var(--font-mono);
    font-size: 2rem;
    line-height: 1;
    color: #e83a3a;
    font-variant-numeric: tabular-nums;
  }

  .ht-name {
    display: block;
    color: var(--brass-bright);
    font-family: var(--font-display);
    letter-spacing: 0.04em;
    font-size: 1.35rem;
  }

  .ht-desc {
    color: var(--fg-dim);
    font-size: 0.98rem;
    margin: 0.35rem 0 0;
  }
</style>

<script>
  document.querySelectorAll<HTMLElement>('[data-hotspot-tour]').forEach((tour) => {
    const badges = Array.from(tour.querySelectorAll<HTMLButtonElement>('[data-ht-badge]'));
    const details = Array.from(tour.querySelectorAll<HTMLElement>('[data-ht-detail]'));
    const select = (slug: string) => {
      badges.forEach((b) => b.setAttribute('aria-pressed', String(b.dataset.htBadge === slug)));
      details.forEach((d) => (d.hidden = d.dataset.htDetail !== slug));
    };
    badges.forEach((b) => b.addEventListener('click', () => select(b.dataset.htBadge!)));
  });
</script>
