---
/* C2 — "Try it in your DAW" desktop bridge (mobile-only, ≤900px).
   A phone can't host a VST, so this hands the visitor three zero-backend ways
   to move the free trial onto their desktop: scan the QR, copy the link, or
   mail it to themselves. Desktop hides the whole module (display:none >900px) —
   there the TRY FREE button already lands on a machine that can run the plugin.
   The QR is a pre-generated static SVG (build-prep, committed) so there's no
   runtime QR dependency. */
import type { Plugin } from '../data/plugins';
// Raw-inline the committed QR so it's self-contained (no extra request) and its
// baked-in aria-label rides along. Points at plugin.trialUrl (verified below).
import qrSvg from '../assets/ui/revlimiter-trial-qr.svg?raw';

interface Props {
  plugin: Plugin;
}
const { plugin } = Astro.props;
const url = plugin.trialUrl!;
const mailBody = `Grab the free ${plugin.name} trial on your desktop:\n${url}`;
const mailto = `mailto:?subject=${encodeURIComponent(`${plugin.name} trial`)}&body=${encodeURIComponent(mailBody)}`;
---

{plugin.trialUrl && (
  <section class="daw-bridge" aria-labelledby="db-heading" data-daw-bridge>
    <h2 id="db-heading" data-split>Take it to the garage</h2>
    <p class="db-lede">
      A phone can't run a plugin. Point your desktop at the free {plugin.name} trial —
      scan the code, or send yourself the link and floor it later.
    </p>

    <div class="db-grid">
      <div class="db-qr" set:html={qrSvg}></div>

      <div class="db-actions">
        <button type="button" class="db-btn" data-db-copy data-db-url={url}>
          <span class="db-btn-label">Copy link</span>
        </button>
        <a class="db-btn" href={mailto}>
          <span class="db-btn-label">Email me the link</span>
        </a>
        {/* Clipboard fallback — hidden until a copy attempt fails, then the URL
            is shown + selected so the visitor can copy it by hand. */}
        <input
          class="db-fallback"
          type="text"
          readonly
          value={url}
          aria-label={`${plugin.name} trial download link`}
          data-db-fallback
          hidden
        />
      </div>
    </div>
  </section>
)}

<style>
  /* Mobile-only: on desktop the TRY FREE button already works on-machine. */
  .daw-bridge { display: none; }

  @media (max-width: 900px) {
    .daw-bridge {
      display: block;
      padding: 2rem 0 3rem;
      border-top: 1px solid var(--border);
    }
  }

  .db-lede {
    color: var(--fg-dim);
    font-size: 1rem;
    max-width: 46ch;
    margin: 0 0 1.5rem;
  }

  .db-grid {
    display: flex;
    gap: 1.25rem;
    align-items: center;
    flex-wrap: wrap;
  }

  /* Framed plate around the QR — brown-black frame, parchment-panel QR baked in. */
  .db-qr {
    flex: 0 0 auto;
    width: 192px;
    height: 192px;
    padding: 11px;
    background: #120804;
    border: 1px solid var(--border-bright);
    border-radius: 10px;
    box-shadow: 0 12px 30px rgba(0, 0, 0, 0.5);
  }
  .db-qr :global(svg) { width: 100%; height: 100%; display: block; border-radius: 3px; }

  .db-actions {
    flex: 1 1 220px;
    min-width: 200px;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .db-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 48px;
    padding: 0 1.25rem;
    font-family: 'VT323', var(--font-mono);
    font-size: 1.25rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--brass-bright);
    background: var(--bg-2);
    border: 1px solid var(--brass-dark);
    border-radius: 6px;
    cursor: pointer;
    transition: border-color 0.2s var(--ease), background 0.2s var(--ease), color 0.2s var(--ease);
  }

  .db-btn[data-db-copied] {
    color: #f4ead6;
    background: #e83a3a;
    border-color: #120804;
  }

  .db-btn:focus-visible {
    outline: 2px solid var(--brass-bright);
    outline-offset: 3px;
  }

  @media (hover: hover) {
    .db-btn:hover { border-color: var(--brass); color: #fff; }
  }

  .db-fallback {
    width: 100%;
    min-height: 44px;
    padding: 0 0.75rem;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--fg);
    background: var(--bg-1);
    border: 1px solid var(--brass-dark);
    border-radius: 6px;
  }

  @media (prefers-reduced-motion: reduce) {
    .db-btn { transition: none; }
  }
</style>

<script>
  document.querySelectorAll<HTMLButtonElement>('[data-db-copy]').forEach((btn) => {
    const url = btn.dataset.dbUrl ?? '';
    const label = btn.querySelector<HTMLElement>('.db-btn-label');
    const fallback = btn.parentElement?.querySelector<HTMLInputElement>('[data-db-fallback]');
    let resetTimer: ReturnType<typeof setTimeout> | undefined;

    const flash = (text: string) => {
      if (!label) return;
      const original = 'Copy link';
      label.textContent = text;
      btn.setAttribute('data-db-copied', '');
      clearTimeout(resetTimer);
      resetTimer = setTimeout(() => {
        label.textContent = original;
        btn.removeAttribute('data-db-copied');
      }, 2000);
    };

    const revealFallback = () => {
      if (!fallback) return;
      fallback.hidden = false;
      fallback.focus();
      fallback.select();
    };

    btn.addEventListener('click', async () => {
      try {
        if (!navigator.clipboard) throw new Error('no clipboard');
        await navigator.clipboard.writeText(url);
        flash('Copied ✓');
      } catch {
        revealFallback();
      }
    });
  });
</script>
