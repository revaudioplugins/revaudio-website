---
import { Image } from 'astro:assets';
import submitImg from '../assets/ui/btn-submit.png';
import submitPressed from '../assets/ui/btn-submit-pressed.png';

interface Props {
  heading?: string;
  subhead?: string;
  buttonLabel?: string;
  id?: string;
}

const {
  heading = 'Subscribe to the newsletter',
  subhead = 'New plugins, demo codes, and intro pricing — straight to your inbox. No spam.',
  buttonLabel = 'Submit',
  id,
} = Astro.props;

// GO LIVE: paste the Formspree form id in src/data/site.ts (single source for
// this form AND the hero subscribe modal). Until then the form won't pretend
// to capture — it shows an honest notice.
import { site } from '../data/site';

const endpoint = site.formspreeEndpoint;
---

<section class="signup" id={id}>
  <div class="container" data-reveal>
    <h2>{heading}</h2>
    <p>{subhead}</p>
    <form class="signup-form" action={endpoint} method="POST" data-newsletter>
      <input
        type="email"
        name="email"
        placeholder="you@studio.com"
        required
        aria-label="Email address"
      />
      <!-- honeypot: real users never fill this; bots do -->
      <input type="text" name="_gotcha" class="hp" tabindex="-1" autocomplete="off" aria-hidden="true" />
      <div class="notify-btn panel">
        <Image src={submitImg} alt="" width={520} height={347} format="webp" />
        <button type="submit" class="panel-hit hit-pill hit-submit" aria-label={buttonLabel}></button>
        <Image src={submitPressed} alt="" width={520} height={347} format="webp" loading="eager" class="press" />
      </div>
    </form>
    <p class="signup-status" role="status" aria-live="polite" hidden></p>
  </div>
</section>

<script>
  document.querySelectorAll<HTMLFormElement>('form[data-newsletter]').forEach((form) => {
    const status = form.parentElement?.querySelector<HTMLElement>('.signup-status');
    // Build-time placeholder still in the action ⇒ not wired to a real backend yet.
    const wired = !form.action.includes('REPLACE_WITH_FORM_ID');

    const show = (msg: string, ok: boolean) => {
      if (!status) return;
      status.textContent = msg;
      status.hidden = false;
      status.classList.toggle('ok', ok);
      status.classList.toggle('err', !ok);
    };

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (!wired) {
        show('Almost there — newsletter signup goes live shortly. Your email wasn’t sent yet.', false);
        return;
      }
      try {
        const res = await fetch(form.action, {
          method: 'POST',
          body: new FormData(form),
          headers: { Accept: 'application/json' },
        });
        if (res.ok) {
          form.hidden = true;
          show('You’re on the list — watch your inbox for the first build.', true);
        } else {
          show('Something went wrong. Try again, or email info@revaudio.net.', false);
        }
      } catch {
        show('Network hiccup — try again in a moment.', false);
      }
    });
  });
</script>

<style>
  /* stack the form so the full SUBMIT plate isn't cropped beside the input */
  .signup form { flex-direction: column; align-items: stretch; gap: 0.85rem; }
  .signup form .notify-btn {
    width: 150px;
    align-self: center;
    padding: 0;
    border: 0;
    background: none;
  }
  /* honeypot — visually and semantically hidden, still submittable by bots */
  .signup form .hp {
    position: absolute;
    left: -9999px;
    width: 1px;
    height: 1px;
    overflow: hidden;
  }
  .signup .signup-status {
    margin: 1.25rem auto 0;
    max-width: 480px;
    font-size: 0.95rem;
  }
  .signup .signup-status.ok { color: var(--brass-bright); }

  /* The one allowed confirmation accent (motion plan): soft settle-pop on the
     success message. Gated on motion-ok so reduced-motion/no-JS stay static.
     Overshoot bezier ≈ back.out, kept under the 8% bible ceiling. */
  :global(html.motion-ok) .signup .signup-status.ok {
    animation: status-pop 0.45s cubic-bezier(0.34, 1.35, 0.64, 1) both;
  }

  @keyframes status-pop {
    from { opacity: 0; transform: scale(0.92) translateY(6px); }
    to { opacity: 1; transform: none; }
  }
  .signup .signup-status.err { color: var(--fg-dim); }
  @media (max-width: 480px) {
    .signup form .notify-btn { width: 100%; max-width: 280px; }
  }
</style>
