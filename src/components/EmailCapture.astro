---
import { Image } from 'astro:assets';
import notifyImg from '../assets/ui/btn-notify.png';
import notifyPressed from '../assets/ui/btn-notify-pressed.png';

interface Props {
  heading?: string;
  subhead?: string;
  buttonLabel?: string;
}

const {
  heading = 'Get on the list',
  subhead = 'First builds, demo codes, and launch pricing — straight to your inbox. No spam.',
  buttonLabel = 'Notify me',
} = Astro.props;
---

<section class="signup">
  <div class="container">
    <h2>{heading}</h2>
    <p>{subhead}</p>
    <!-- TODO: replace action with real MailerLite endpoint once account is set up -->
    <form action="https://example.com/subscribe" method="POST" onsubmit="event.preventDefault(); alert('Email capture not yet wired. Add MailerLite endpoint in EmailCapture.astro.');">
      <input
        type="email"
        name="email"
        placeholder="you@studio.com"
        required
        aria-label="Email address"
      />
      <div class="notify-btn panel">
        <Image src={notifyImg} alt="" width={520} height={347} format="webp" />
        <button type="submit" class="panel-hit hit-pill hit-notify" aria-label={buttonLabel}></button>
        <Image src={notifyPressed} alt="" width={520} height={347} format="webp" loading="eager" class="press" />
      </div>
    </form>
  </div>
</section>

<style>
  /* stack the form so the full NOTIFY ME plate isn't cropped beside the input */
  .signup form { flex-direction: column; align-items: stretch; gap: 0.85rem; }
  .signup form .notify-btn {
    width: 220px;
    align-self: center;
    padding: 0;
    border: 0;
    background: none;
  }
  @media (max-width: 480px) {
    .signup form .notify-btn { width: 100%; max-width: 280px; }
  }
</style>
