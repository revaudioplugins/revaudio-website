  /* ── responsive (900 = the site-wide breakpoint) ── */
  @media (max-width: 900px) {
    .dash { grid-template-columns: 1fr; padding: 22px 16px; }

    /* the photoreal ARM plate stays desktop-only — mobile A/B lives on the
       in-glass switch below, so the whole section fits one phone screen */
    .armbay { display: none; }

    /* track = [play | name | time] / [LED bar] — two rows, one screen */
    .trk {
      grid-template-columns: 52px minmax(0, 1fr) auto;
      grid-template-rows: auto auto;
      row-gap: 6px;
      column-gap: 10px;
      padding: 8px 4px;
      font-size: 19px;
    }
    .trk .no { display: none; }
    .lcdplay { height: 40px; } /* 40 + 2×2px border = 44px tap height */
    .trk .name { grid-column: 2; grid-row: 1; align-self: center; }
    .trk .time { grid-column: 3; grid-row: 1; align-self: center; font-size: 16px; }
    .trk .bar-wrap { grid-column: 1 / -1; grid-row: 2; }
    .seek { inset: -14px 0; } /* 16px bar + 2×14px slop = 44px hit strip */
    .glass { padding: 16px 14px 12px; }
    /* stacked head = constant two lines: the SRC readout grows on arm
       ("MASTER BUS — PRESS PLAY") and a flex-row head would wrap it to a
       new line, resizing the whole glass on every A/B flip */
    .mon-head { flex-direction: column; gap: 2px; font-size: 14px; }
    .mon-head span { white-space: nowrap; }
    .cta { font-size: 17px; min-height: 44px; padding: 12px 0 4px; }

    /* ── in-glass A/B switch: segmented [RAW | REVLIMITER], same amber
       vocabulary as the LED bar (idle segment = dim outline, active =
       lit + glow). Replaces the ARM plate on mobile. ── */
    .abswitch {
      display: grid;
      grid-template-columns: 1fr 1.5fr;
      gap: 8px;
      position: relative;
      z-index: 1;
      margin-top: 12px;
      padding-top: 12px;
      border-top: 1px dashed rgba(255, 170, 60, 0.18);
    }
    .abseg {
      all: unset;
      box-sizing: border-box;
      cursor: pointer;
      min-height: 46px;
      display: grid;
      place-items: center;
      text-align: center;
      font-family: 'VT323', monospace;
      font-size: 20px;
      letter-spacing: 0.12em;
      color: #c07a20;
      border: 2px solid rgba(255, 170, 60, 0.35);
      border-radius: 4px;
      background: rgba(255, 160, 40, 0.05);
      transition: background 0.12s ease, box-shadow 0.12s ease, border-color 0.12s ease, color 0.12s ease;
    }
    .abseg[aria-pressed='true'] {
      color: #ffe6a6;
      border-color: #ffd070;
      background: rgba(255, 170, 60, 0.22);
      box-shadow: 0 0 16px rgba(255, 160, 40, 0.5), inset 0 0 10px rgba(255, 160, 40, 0.25);
      text-shadow: 0 0 8px rgba(255, 160, 40, 0.8);
    }
    .abseg:focus-visible { outline: 2px solid #ffd070; outline-offset: 3px; }

    /* ── floating A/B dock: the switch stays in the thumb zone while music
       plays (.arm-afloat = playing + in-glass switch off-screen, set in JS).
       Bottom-right above MobileBuyBar (--mbb-h, z40), clear of the
       bottom-LEFT a11y fab (z60); dock sits between at z39. ── */
    .arm-afloat .ab-dock {
      display: flex;
      flex-direction: column;
      gap: 6px;
      position: fixed;
      right: max(10px, env(safe-area-inset-right));
      bottom: calc(var(--mbb-h, 64px) + env(safe-area-inset-bottom, 0px) + 10px);
      z-index: 39;
      width: min(250px, calc(100vw - 90px)); /* never reaches the a11y fab column */
      padding: 10px 12px;
      border: 1px solid #0a0705;
      border-radius: 10px;
      background:
        repeating-linear-gradient(92deg, rgba(255, 255, 255, 0.015) 0 2px, transparent 2px 4px),
        linear-gradient(180deg, #241c14 0%, #160f0a 100%);
      box-shadow: 0 14px 34px rgba(0, 0, 0, 0.75), inset 0 2px 2px rgba(255, 225, 170, 0.08);
      animation: arm-dock-in 0.28s var(--ease-settle, ease-out) backwards;
    }
    .ab-dock .dock-cue {
      font-family: 'Special Elite', monospace;
      font-size: 11px;
      letter-spacing: 0.22em;
      text-align: center;
      color: #7a6a4a;
    }
    .ab-dock .abswitch { margin-top: 0; padding-top: 0; border-top: none; gap: 6px; }
    .ab-dock .abseg { min-height: 44px; font-size: 18px; }
    /* cookie banner (z9000) owns the bottom edge — no dock underneath it */
    :global(body:has(#cookie-banner.cb--visible)) .arm-afloat .ab-dock { display: none; }
  }

  @keyframes arm-dock-in {
    from { transform: translateY(14px); opacity: 0; }
    to { transform: translateY(0); opacity: 1; }
  }

  @media (prefers-reduced-motion: reduce) {
    .arm-afloat .ab-dock { animation: none; }
  }

  @media (max-width: 420px) {
    .mon-head { font-size: 13px; letter-spacing: 0.08em; }
    .bar { gap: 2px; }
    .abseg { font-size: 17px; letter-spacing: 0.08em; }
  }

