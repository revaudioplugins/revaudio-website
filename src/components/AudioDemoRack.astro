---
import type { AudioDemo as Demo, Plugin } from '../data/plugins';

interface Props {
  demos: Demo[];
  plugin: Plugin;
}

const { demos, plugin } = Astro.props;
const cartPrice = plugin.regularPriceUsd ?? plugin.introPriceUsd;
---

<!-- Dashboard cluster: LCD track monitor + ARM bay (design tuned on /hearlab).
     ARM = the plugin's #nosArm replica; armed = mastered render audible. -->
<div class="dash" data-abrack>
  <div class="screw tl" aria-hidden="true"></div>
  <div class="screw tr" aria-hidden="true"></div>
  <div class="screw bl" aria-hidden="true"></div>
  <div class="screw br" aria-hidden="true"></div>
  <span class="dash-label" aria-hidden="true">RA-56 MONITOR</span>

  <div class="monitor">
    <div class="glass">
      <div class="mon-head" aria-hidden="true">
        <span>REVAUDIO · AUX MONITOR</span>
        <span data-src-label>SRC: RAW BUS</span>
      </div>
      {demos.map((demo, i) => (
        <div class="trk" data-track>
          <span class="no" aria-hidden="true">{String(i + 1).padStart(2, '0')}</span>
          <button class="lcdplay" type="button" data-play aria-label={`Play ${demo.label}`}>
            <span class="glyph" aria-hidden="true"></span>
            <span class="spinner" aria-hidden="true"></span>
          </button>
          <span class="name">{demo.label}</span>
          <span class="bar-wrap">
            <span class="bar" aria-hidden="true" data-bar>{Array.from({ length: 18 }).map(() => <i></i>)}</span>
            <input class="seek" type="range" min="0" max="100" step="2" value="0" disabled data-seek aria-label={`Seek ${demo.label}`} />
          </span>
          <span class="time" data-time aria-hidden="true">-:--</span>
          <audio preload="metadata" src={demo.beforeUrl ?? undefined} data-before></audio>
          <audio preload="none" src={demo.afterUrl ?? undefined} data-after></audio>
        </div>
      ))}
      {/* channel 04 — the visitor's own file, processed live through the
          plugin's first factory preset (Idle Mix) via Web Audio. Decode and
          processing are entirely local; the file never leaves the browser. */}
      <div class="trk trk-user" data-user-track>
        <span class="no" aria-hidden="true">04</span>
        <button class="lcdplay" type="button" data-uplay aria-label="Play your track" hidden>
          <span class="glyph" aria-hidden="true"></span>
          <span class="spinner" aria-hidden="true"></span>
        </button>
        <button class="lcdplay" type="button" data-uload aria-label="Load your own track — processed locally, never uploaded">
          <span class="glyph eject" aria-hidden="true"></span>
          <span class="spinner" aria-hidden="true"></span>
        </button>
        <span class="name uname">
          <span data-uname>YOUR TRACK — LOAD A FILE</span>
          <button class="swap" type="button" data-uswap hidden aria-label="Change file">⏏ SWAP</button>
        </span>
        <span class="bar-wrap">
          <span class="bar" aria-hidden="true" data-bar>{Array.from({ length: 18 }).map(() => <i></i>)}</span>
          <input class="seek" type="range" min="0" max="100" step="2" value="0" disabled data-seek aria-label="Seek your track" />
        </span>
        <span class="time" data-time aria-hidden="true">-:--</span>
        <input type="file" accept="audio/*" hidden data-ufile />
        <span class="sr-only" aria-live="polite" data-user-live></span>
      </div>
      <p class="local-note">CH 04 RUNS IDLE MIX — THE DEFAULT PRESET — IN YOUR BROWSER. NOTHING UPLOADS.</p>
      <button
        type="button"
        class="cta"
        data-cta
        data-add-to-cart
        data-slug={plugin.slug}
        data-name={plugin.name}
        data-price={cartPrice}
        data-checkout-url={plugin.checkoutUrl}
        aria-label={`That's ${plugin.name} — add to cart`}
      >THAT'S {plugin.name.toUpperCase()} → GET IT</button>
    </div>
  </div>

  <div class="armbay">
    <div class="nos-mount" data-arm-mount>
      <div class="nos-pressed"></div>
      <button
        type="button"
        class="nos-button"
        data-arm
        role="switch"
        aria-checked="false"
        aria-label="ARM — RevLimiter processing"
      ><span class="arm-word" aria-hidden="true">ARM</span></button>
      <div class="nos-light"></div>
      <!-- label always reads ON (plugin behavior) — the .armed glow shows state -->
      <div class="nos-state">ON</div>
    </div>
    <span class="sr-only" aria-live="polite" data-arm-live></span>
  </div>
</div>

<script>
  // ── Idle Mix (factory preset f:0) as a Web Audio chain ──
  // Values are the plugin's own, denormalised from its preset table and
  // Cruise-mode DSP constants (applyModeSettings): threshold −3 dB,
  // ceiling −0.3 dB, mid +0.5 dB, heat 12%, limiter release 80 ms,
  // MB-comp crossovers 120 / 2500 Hz.
  const IDLE_MIX = {
    midGainDb: 0.5,
    heat: 0.12,
    limThresholdDb: -3,
    limReleaseS: 0.08,
    ceilingDb: -0.3,
    xoverLow: 120,
    xoverHigh: 2500,
    // thresholds sit 3 dB above the plugin's Cruise constants (−13/−14/−12):
    // DynamicsCompressorNode's peak-style detector reads dense material ~3 dB
    // hotter than the plugin's envelope followers, and over-reduces without
    // this calibration (measured: armed came out quieter than raw)
    bands: [
      { thr: -10, ratio: 1.6, att: 0.02, rel: 0.3 },   // low
      { thr: -11, ratio: 1.5, att: 0.015, rel: 0.2 },  // mid
      { thr: -9, ratio: 1.3, att: 0.008, rel: 0.12 },  // high
    ],
  };

  function buildIdleMix(ctx: AudioContext) {
    const input = ctx.createGain();

    // 3-band LR4 split (two cascaded Butterworth biquads per leg)
    const lr4 = (type: BiquadFilterType, f: number) => {
      const a = ctx.createBiquadFilter();
      const b = ctx.createBiquadFilter();
      a.type = b.type = type;
      a.frequency.value = b.frequency.value = f;
      a.Q.value = b.Q.value = Math.SQRT1_2;
      a.connect(b);
      return { in: a, out: b };
    };
    const lowLP = lr4('lowpass', IDLE_MIX.xoverLow);
    const lowHP = lr4('highpass', IDLE_MIX.xoverLow);
    const midLP = lr4('lowpass', IDLE_MIX.xoverHigh);
    const highHP = lr4('highpass', IDLE_MIX.xoverHigh);

    // DynamicsCompressorNode applies spec-mandated automatic makeup gain
    // (0 dBFS in → 0 dBFS out). Left uncompensated, the three band comps +
    // limiter stack ~10 dB of hidden gain into the ceiling — audible clipping
    // on loaded masters. Cancel it per node; makeup stays explicit below.
    const autoMakeupTrim = (thr: number, ratio: number) => {
      const g = ctx.createGain();
      g.gain.value = Math.pow(10, (thr * (1 - 1 / ratio)) / 20);
      return g;
    };

    const comps = IDLE_MIX.bands.map((b) => {
      const c = ctx.createDynamicsCompressor();
      c.threshold.value = b.thr;
      c.ratio.value = b.ratio;
      c.attack.value = b.att;
      c.release.value = b.rel;
      c.knee.value = 6;
      return c;
    });
    const sum = ctx.createGain();
    input.connect(lowLP.in);
    lowLP.out.connect(comps[0]).connect(autoMakeupTrim(IDLE_MIX.bands[0].thr, IDLE_MIX.bands[0].ratio)).connect(sum);
    input.connect(lowHP.in);
    lowHP.out.connect(midLP.in);
    midLP.out.connect(comps[1]).connect(autoMakeupTrim(IDLE_MIX.bands[1].thr, IDLE_MIX.bands[1].ratio)).connect(sum);
    input.connect(highHP.in);
    highHP.out.connect(comps[2]).connect(autoMakeupTrim(IDLE_MIX.bands[2].thr, IDLE_MIX.bands[2].ratio)).connect(sum);

    // mid +0.5 dB — wide bell at the geometric mean of the crossovers
    const eq = ctx.createBiquadFilter();
    eq.type = 'peaking';
    eq.frequency.value = 548;
    eq.Q.value = 0.7;
    eq.gain.value = IDLE_MIX.midGainDb;

    // Engine Heat — parallel soft saturation, blended at the preset's 12%.
    // Unity slope at zero (tanh(kx)/k, not /tanh(k)) so the stage adds NO
    // hidden gain — at heat 12% it's near-transparent warmth, like the plugin.
    const heat = ctx.createWaveShaper();
    const k = 2;
    const h = IDLE_MIX.heat;
    // WaveShaper curves map input −1..+1 across the array — index i is
    // input x = i/511.5 − 1, no wider domain (a ×2 domain = a +6 dB boost).
    const curve = new Float32Array(1024);
    for (let i = 0; i < 1024; i++) {
      const x = i / 511.5 - 1;
      curve[i] = (1 - h) * x + h * (Math.tanh(k * x) / k);
    }
    heat.curve = curve;
    heat.oversample = '4x';

    // limiter: thr −3 dB / 80 ms release, then makeup into the −0.3 dB ceiling
    const lim = ctx.createDynamicsCompressor();
    lim.threshold.value = IDLE_MIX.limThresholdDb;
    lim.ratio.value = 20;
    lim.knee.value = 1;
    lim.attack.value = 0.001;
    lim.release.value = IDLE_MIX.limReleaseS;
    const makeup = ctx.createGain();
    makeup.gain.value = Math.pow(10, (-IDLE_MIX.limThresholdDb + IDLE_MIX.ceilingDb) / 20);

    // soft-knee ceiling guard: linear until 3 dB below the ceiling, then a
    // smooth tanh round-off into it. With gain staging honest (auto-makeup
    // cancelled above) this only shaves rare transient overshoots — no more
    // hard-clip crunch. 'none' so the resampler can't ring past the ceiling;
    // inputs beyond ±1 land on the curve endpoints (≈ the ceiling).
    const ceil = Math.pow(10, IDLE_MIX.ceilingDb / 20);
    const knee = ceil * Math.pow(10, -3 / 20);
    const guard = ctx.createWaveShaper();
    const gcurve = new Float32Array(1024);
    for (let i = 0; i < 1024; i++) {
      const x = i / 511.5 - 1;
      const a = Math.abs(x);
      gcurve[i] = a <= knee
        ? x
        : Math.sign(x) * (knee + (ceil - knee) * Math.tanh((a - knee) / (ceil - knee)));
    }
    guard.curve = gcurve;
    guard.oversample = 'none';

    sum.connect(eq).connect(heat).connect(lim).connect(autoMakeupTrim(IDLE_MIX.limThresholdDb, 20)).connect(makeup).connect(guard);
    return { input, output: guard };
  }

  document.querySelectorAll<HTMLElement>('[data-abrack]').forEach((rack) => {
    const mount = rack.querySelector<HTMLElement>('[data-arm-mount]');
    const armBtn = rack.querySelector<HTMLButtonElement>('[data-arm]');
    const armLive = rack.querySelector<HTMLElement>('[data-arm-live]');
    const srcLabel = rack.querySelector<HTMLElement>('[data-src-label]');
    if (!mount || !armBtn) return;

    let armed = false;

    interface Track {
      root: HTMLElement;
      before: HTMLAudioElement;
      after: HTMLAudioElement;
      playBtn: HTMLButtonElement;
      seek: HTMLInputElement;
      bar: HTMLElement | null;
      timeEl: HTMLElement | null;
    }

    const tracks: Track[] = [];
    rack.querySelectorAll<HTMLElement>('[data-track]').forEach((root) => {
      const before = root.querySelector<HTMLAudioElement>('[data-before]');
      const after = root.querySelector<HTMLAudioElement>('[data-after]');
      const playBtn = root.querySelector<HTMLButtonElement>('[data-play]');
      const seek = root.querySelector<HTMLInputElement>('[data-seek]');
      if (!before || !after || !playBtn || !seek) return;
      tracks.push({
        root, before, after, playBtn, seek,
        bar: root.querySelector('[data-bar]'),
        timeEl: root.querySelector('[data-time]'),
      });
    });

    let current: Track | null = null;

    // channel 04 hooks — assigned when the user track initialises below
    let stopUser: () => void = () => {};
    let applyUserArm: () => void = () => {};
    let userPlaying: () => boolean = () => false;

    const fmt = (s: number) =>
      Number.isFinite(s) ? `${Math.floor(s / 60)}:${String(Math.floor(s % 60)).padStart(2, '0')}` : '-:--';

    // Which element is audible. Both always play together; ARM only swaps mute.
    const applyArm = (t: Track) => {
      t.before.muted = armed;
      t.after.muted = !armed;
    };

    // A seek lands late: by the time it completes, the reference clock has
    // moved on, so a plain `silent.currentTime = audible.currentTime` leaves
    // the silent element trailing by the seek latency forever. Measure that
    // latency per element and lead the target by it so lockstep converges.
    const seekLag = new WeakMap<HTMLMediaElement, number>();
    const seekIssued = new WeakMap<HTMLMediaElement, number>();
    const syncSeek = (el: HTMLMediaElement, target: number) => {
      const led = target + (seekLag.get(el) ?? 0);
      const d = el.duration;
      seekIssued.set(el, performance.now());
      // never lead a muted element past its end — it would fire `ended`,
      // pause, and a later ARM would flip to a dead element
      el.currentTime = Number.isFinite(d) ? Math.min(led, Math.max(0, d - 0.1)) : led;
    };

    // Keep the silent element in lockstep while playing, so an ARM flip is a
    // pure muted swap with no seek at flip time (a seek = decoder flush =
    // audible gap). The audible element's position is the truth; only ever
    // seek the muted one, and only once it has data (no seek-thrash while
    // it's still fetching its first bytes).
    const resync = (t: Track) => {
      if (t.before.paused) return;
      const audible = armed ? t.after : t.before;
      const silent = armed ? t.before : t.after;
      if (silent.seeking || silent.readyState < 3) return;
      // Tighter than the 0.05s arm threshold, so drift never grows big
      // enough for the arm handler's safety seek to fire.
      if (Math.abs(silent.currentTime - audible.currentTime) > 0.03) {
        syncSeek(silent, audible.currentTime);
      }
    };

    const paintProgress = (
      c: number,
      d: number,
      bar: HTMLElement | null,
      timeEl: HTMLElement | null,
      seek: HTMLInputElement,
    ) => {
      const p = Number.isFinite(d) && d > 0 ? c / d : 0;
      if (timeEl) timeEl.textContent = Number.isFinite(d) ? `${fmt(c)}/${fmt(d)}` : '-:--';
      if (bar) {
        const segs = bar.children;
        for (let i = 0; i < segs.length; i++) segs[i].classList.toggle('on', p > 0 && i / segs.length < p);
      }
      if (Number.isFinite(d) && d > 0) {
        seek.value = String(p * 100);
        seek.setAttribute('aria-valuetext', `${fmt(c)} of ${fmt(d)}`);
      }
    };

    const paintTime = (t: Track) =>
      paintProgress(t.before.currentTime, t.before.duration, t.bar, t.timeEl, t.seek);

    const setPlaying = (t: Track, playing: boolean) => {
      t.root.classList.toggle('playing', playing);
      t.playBtn.setAttribute('aria-label', `${playing ? 'Pause' : 'Play'} ${t.playBtn.dataset.label ?? ''}`.trim());
    };

    const stop = (t: Track) => {
      t.before.pause();
      t.after.pause();
      t.before.currentTime = 0;
      t.after.currentTime = 0;
      setPlaying(t, false);
      paintTime(t);
    };

    tracks.forEach((t) => {
      t.playBtn.dataset.label = t.playBtn.getAttribute('aria-label')?.replace(/^Play /, '') ?? '';
      applyArm(t);

      t.playBtn.addEventListener('click', () => {
        if (current === t && !t.before.paused) {
          t.before.pause();
          t.after.pause();
          setPlaying(t, false);
          return;
        }
        tracks.forEach((o) => {
          if (o !== t) stop(o);
        });
        stopUser();
        current = t;
        applyArm(t);
        if (srcLabel) srcLabel.textContent = armed ? 'SRC: MASTER BUS' : 'SRC: RAW BUS';
        t.root.classList.add('loading');
        // The after ships preload="none"; from first play on, let it buffer
        // ahead like the before so an ARM never lands on an empty buffer.
        t.after.preload = 'auto';
        // Both play() calls stay synchronous inside the click gesture (iOS).
        Promise.all([t.before.play(), t.after.play()])
          .then(() => setPlaying(t, true))
          .catch(() => setPlaying(t, false))
          .finally(() => t.root.classList.remove('loading'));
      });

      const onMeta = () => {
        t.seek.disabled = false;
        paintTime(t);
      };
      t.before.addEventListener('loadedmetadata', onMeta);
      // preload="metadata" can beat this module script (HAVE_METADATA already)
      if (t.before.readyState >= 1) onMeta();
      t.before.addEventListener('timeupdate', () => {
        paintTime(t);
        resync(t);
      });
      // Both fire ~4Hz out of phase — doubles the lockstep check cadence.
      t.after.addEventListener('timeupdate', () => resync(t));
      for (const el of [t.before, t.after]) {
        el.addEventListener('seeked', () => {
          const issued = seekIssued.get(el);
          if (issued === undefined) return; // user seek, not a resync
          seekIssued.delete(el);
          seekLag.set(el, Math.min((performance.now() - issued) / 1000, 0.25));
        });
      }
      t.before.addEventListener('ended', () => {
        t.after.pause();
        t.before.currentTime = 0;
        t.after.currentTime = 0;
        setPlaying(t, false);
        paintTime(t);
      });

      t.seek.addEventListener('input', () => {
        const d = t.before.duration;
        if (!Number.isFinite(d) || d <= 0) return;
        const time = (Number(t.seek.value) / 100) * d;
        t.before.currentTime = time;
        t.after.currentTime = time;
        paintTime(t);
      });
    });

    // ── channel 04: the visitor's own file through Idle Mix ──
    // One decoded buffer feeds a dry tap and the processing chain; ARM is a
    // 5 ms equal crossfade between the two gain taps — gapless by construction.
    const userRoot = rack.querySelector<HTMLElement>('[data-user-track]');
    if (userRoot) {
      const uPlay = userRoot.querySelector<HTMLButtonElement>('[data-uplay]');
      const uLoad = userRoot.querySelector<HTMLButtonElement>('[data-uload]');
      const uSwap = userRoot.querySelector<HTMLButtonElement>('[data-uswap]');
      const uName = userRoot.querySelector<HTMLElement>('[data-uname]');
      const uFile = userRoot.querySelector<HTMLInputElement>('[data-ufile]');
      const uSeek = userRoot.querySelector<HTMLInputElement>('[data-seek]');
      const uBar = userRoot.querySelector<HTMLElement>('[data-bar]');
      const uTime = userRoot.querySelector<HTMLElement>('[data-time]');
      const uLive = userRoot.querySelector<HTMLElement>('[data-user-live]');

      if (uPlay && uLoad && uName && uFile && uSeek) {
        let ctx: AudioContext | null = null;
        let tap: GainNode;
        let dryGain: GainNode;
        let wetGain: GainNode;
        let buffer: AudioBuffer | null = null;
        let srcNode: AudioBufferSourceNode | null = null;
        let startedAt = 0;
        let offset = 0;
        let playing = false;
        let raf = 0;

        const ensureCtx = () => {
          if (ctx) return ctx;
          ctx = new AudioContext();
          tap = ctx.createGain();
          dryGain = ctx.createGain();
          wetGain = ctx.createGain();
          dryGain.gain.value = armed ? 0 : 1;
          wetGain.gain.value = armed ? 1 : 0;
          const chain = buildIdleMix(ctx);
          tap.connect(dryGain).connect(ctx.destination);
          tap.connect(chain.input);
          chain.output.connect(wetGain).connect(ctx.destination);
          return ctx;
        };

        const pos = () => {
          if (!buffer) return 0;
          const c = playing && ctx ? offset + ctx.currentTime - startedAt : offset;
          return Math.min(c, buffer.duration);
        };

        const paint = () => paintProgress(pos(), buffer?.duration ?? NaN, uBar, uTime, uSeek);

        const setUPlaying = (p: boolean) => {
          userRoot.classList.toggle('playing', p);
          uPlay.setAttribute('aria-label', `${p ? 'Pause' : 'Play'} your track`);
        };

        const startSource = (at: number) => {
          const c = ensureCtx();
          const node = c.createBufferSource();
          node.buffer = buffer;
          node.connect(tap);
          node.onended = () => {
            if (node !== srcNode) return; // superseded by pause/seek/swap
            playing = false;
            offset = 0;
            srcNode = null;
            setUPlaying(false);
            cancelAnimationFrame(raf);
            paint();
          };
          srcNode = node;
          node.start(0, at);
          startedAt = c.currentTime;
          offset = at;
          playing = true;
        };

        const pauseUser = () => {
          if (!playing) return;
          offset = pos();
          if (srcNode) {
            srcNode.onended = null;
            srcNode.stop();
            srcNode = null;
          }
          playing = false;
          setUPlaying(false);
          cancelAnimationFrame(raf);
          paint();
        };

        stopUser = () => {
          pauseUser();
          offset = 0;
          paint();
        };

        applyUserArm = () => {
          if (!ctx) return;
          const t0 = ctx.currentTime;
          dryGain.gain.setTargetAtTime(armed ? 0 : 1, t0, 0.005);
          wetGain.gain.setTargetAtTime(armed ? 1 : 0, t0, 0.005);
        };

        userPlaying = () => playing;

        uPlay.addEventListener('click', () => {
          if (!buffer) return;
          if (playing) {
            pauseUser();
            return;
          }
          tracks.forEach(stop);
          current = null;
          const c = ensureCtx();
          if (c.state === 'suspended') c.resume();
          if (offset >= buffer.duration - 0.05) offset = 0;
          startSource(offset);
          setUPlaying(true);
          if (srcLabel) srcLabel.textContent = armed ? 'SRC: MASTER BUS' : 'SRC: RAW BUS';
          const tick = () => {
            paint();
            if (playing) raf = requestAnimationFrame(tick);
          };
          raf = requestAnimationFrame(tick);
        });

        const loadFile = async (file: File) => {
          userRoot.classList.add('loading');
          try {
            const data = await file.arrayBuffer();
            const buf = await ensureCtx().decodeAudioData(data);
            stopUser();
            buffer = buf;
            uName.textContent = file.name.replace(/\.[^.]+$/, '').toUpperCase();
            uPlay.hidden = false;
            uLoad.hidden = true;
            if (uSwap) uSwap.hidden = false;
            uSeek.disabled = false;
            paint();
            if (uLive) uLive.textContent = `Loaded ${file.name}. Press play, then ARM for the Idle Mix master.`;
          } catch {
            uName.textContent = "COULDN'T READ THAT FILE — TRY ANOTHER";
            if (uLive) uLive.textContent = 'Could not read that file. Try another.';
          } finally {
            userRoot.classList.remove('loading');
          }
        };

        uLoad.addEventListener('click', () => uFile.click());
        uSwap?.addEventListener('click', () => uFile.click());
        uFile.addEventListener('change', () => {
          const f = uFile.files?.[0];
          if (f) loadFile(f);
          uFile.value = '';
        });

        uSeek.addEventListener('input', () => {
          if (!buffer) return;
          const t = (Number(uSeek.value) / 100) * buffer.duration;
          if (playing && srcNode) {
            srcNode.onended = null;
            srcNode.stop();
            startSource(Math.min(t, Math.max(0, buffer.duration - 0.05)));
          } else {
            offset = t;
          }
          paint();
        });
      }
    }

    armBtn.addEventListener('click', () => {
      armed = !armed;
      if (current) {
        // Safety only — the timeupdate resync keeps both in lockstep, so the
        // element about to be unmuted should already be in position. Seek it
        // (while it's still muted) only if it's genuinely off.
        const from = armed ? current.before : current.after;
        const to = armed ? current.after : current.before;
        if (!to.seeking && Math.abs(to.currentTime - from.currentTime) > 0.05) syncSeek(to, from.currentTime);
      }
      tracks.forEach(applyArm);
      applyUserArm();
      mount.classList.toggle('armed', armed);
      rack.classList.toggle('is-armed', armed);
      armBtn.setAttribute('aria-checked', String(armed));
      if (armLive) armLive.textContent = armed ? 'RevLimiter on' : 'RevLimiter off';
      if (srcLabel) {
        const idle = (!current || current.before.paused) && !userPlaying();
        srcLabel.textContent = armed
          ? (idle ? 'SRC: MASTER BUS — PRESS PLAY' : 'SRC: MASTER BUS')
          : 'SRC: RAW BUS';
        if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
          srcLabel.classList.remove('blink');
          void srcLabel.offsetWidth;
          srcLabel.classList.add('blink');
        }
      }
      if (armed) rack.classList.add('was-armed'); // reveals the CTA, stays on
    });
  });
</script>

<style>
  /* ── dashboard housing ── */
  .dash {
    position: relative;
    width: 100%;
    padding: 26px 30px;
    display: grid;
    grid-template-columns: minmax(0, 1fr) 240px;
    gap: 24px;
    border-radius: 14px;
    background:
      repeating-linear-gradient(92deg, rgba(255, 255, 255, 0.015) 0 2px, transparent 2px 4px),
      linear-gradient(180deg, #33291f 0%, #241c14 30%, #1a140e 70%, #120d09 100%);
    border: 1px solid #0a0705;
    box-shadow:
      inset 0 2px 2px rgba(255, 225, 170, 0.13),
      inset 0 -3px 6px rgba(0, 0, 0, 0.6),
      0 18px 40px rgba(0, 0, 0, 0.65);
  }

  .screw {
    position: absolute;
    width: 13px;
    height: 13px;
    border-radius: 50%;
    background: radial-gradient(circle at 35% 30%, #8a7a5c, #4a3d2a 55%, #241c12);
    box-shadow: inset 0 -1px 2px rgba(0, 0, 0, 0.8), 0 1px 1px rgba(255, 220, 160, 0.15);
  }

  .screw::after {
    content: '';
    position: absolute;
    left: 15%;
    top: 46%;
    width: 70%;
    height: 1.5px;
    background: #181008;
    transform: rotate(38deg);
  }

  /* real panels never have four aligned slots */
  .screw.tr::after { transform: rotate(102deg); }
  .screw.bl::after { transform: rotate(-24deg); }
  .screw.br::after { transform: rotate(61deg); }

  .screw.tl { left: 10px; top: 10px; }
  .screw.tr { right: 10px; top: 10px; }
  .screw.bl { left: 10px; bottom: 10px; }
  .screw.br { right: 10px; bottom: 10px; }

  .dash-label {
    position: absolute;
    top: 8px;
    left: 50%;
    transform: translateX(-50%);
    font-family: 'Special Elite', monospace;
    font-size: 11px;
    letter-spacing: 0.3em;
    color: #7a6a4a;
  }

  /* ── the LCD monitor ── */
  .monitor {
    position: relative;
    min-width: 0;
    border-radius: 8px;
    padding: 8px;
    background: linear-gradient(180deg, #0d0b08, #060504);
    box-shadow: inset 0 3px 8px rgba(0, 0, 0, 0.9), inset 0 -1px 1px rgba(255, 215, 150, 0.08);
  }

  .glass {
    position: relative;
    border-radius: 5px;
    padding: 20px 24px 16px;
    overflow: hidden;
    background:
      radial-gradient(120% 90% at 50% 0%, rgba(255, 170, 50, 0.07), transparent 60%),
      linear-gradient(180deg, #100c04, #0a0703);
    font-family: 'VT323', monospace;
    color: #ffb340;
    transition: filter 0.3s ease;
  }

  .is-armed .glass { filter: brightness(1.18); }

  .glass::before {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: repeating-linear-gradient(0deg, rgba(0, 0, 0, 0.35) 0 1px, transparent 1px 3px);
  }

  .glass::after {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: linear-gradient(115deg, transparent 42%, rgba(255, 240, 210, 0.05) 47%, transparent 55%);
  }

  .mon-head {
    display: flex;
    justify-content: space-between;
    gap: 12px;
    font-size: 17px;
    color: #c07a20;
    letter-spacing: 0.14em;
    margin-bottom: 14px;
    text-shadow: 0 0 6px rgba(255, 150, 30, 0.4);
  }

  .trk {
    display: grid;
    grid-template-columns: 30px 52px minmax(90px, 190px) minmax(120px, 1fr) 110px;
    align-items: center;
    gap: 14px;
    padding: 9px 6px;
    font-size: 24px;
    text-shadow: 0 0 8px rgba(255, 160, 40, 0.55);
  }

  .trk + .trk { border-top: 1px dashed rgba(255, 170, 60, 0.18); }

  .trk .no { color: #8a5a18; font-size: 20px; }

  audio { display: none; }

  .lcdplay {
    all: unset;
    cursor: pointer;
    position: relative;
    z-index: 1;
    width: 48px;
    height: 34px;
    display: grid;
    place-items: center;
    border: 2px solid rgba(255, 170, 60, 0.55);
    border-radius: 3px;
    background: rgba(255, 160, 40, 0.08);
    box-shadow: 0 0 8px rgba(255, 160, 40, 0.18), inset 0 0 6px rgba(255, 160, 40, 0.1);
    transition: background 0.12s ease, box-shadow 0.12s ease, border-color 0.12s ease;
  }

  .lcdplay .glyph {
    font-size: 17px;
    line-height: 1;
    color: #ffb340;
    text-shadow: 0 0 8px rgba(255, 160, 40, 0.8);
  }

  .lcdplay .glyph::before { content: '▶'; }
  .trk.playing .lcdplay .glyph::before { content: '❚❚'; letter-spacing: -2px; }

  .lcdplay:hover {
    border-color: #ffcf70;
    background: rgba(255, 160, 40, 0.16);
    box-shadow: 0 0 14px rgba(255, 160, 40, 0.35), inset 0 0 8px rgba(255, 160, 40, 0.18);
  }

  .lcdplay:focus-visible { outline: 2px solid #ffd070; outline-offset: 3px; }

  .trk.playing { background: rgba(255, 160, 40, 0.07); }

  .trk.playing .lcdplay {
    border-color: #ffd070;
    background: rgba(255, 170, 60, 0.22);
    box-shadow: 0 0 16px rgba(255, 160, 40, 0.5), inset 0 0 10px rgba(255, 160, 40, 0.25);
  }

  .trk.playing .lcdplay .glyph { color: #ffe6a6; }

  .lcdplay .spinner { display: none; position: absolute; width: 14px; height: 14px;
    border: 2px solid rgba(255, 170, 60, 0.3); border-top-color: #ffb340;
    border-radius: 50%; animation: rack-spin 0.7s linear infinite; }
  .trk.loading .lcdplay .glyph { visibility: hidden; }
  .trk.loading .lcdplay .spinner { display: block; }

  @keyframes rack-spin { to { transform: rotate(360deg); } }

  .trk .name {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    text-transform: uppercase;
  }

  /* segmented LED progress with an invisible native range on top
     (free pointer drag + keyboard + AT semantics) */
  .bar-wrap { position: relative; min-width: 0; z-index: 1; }

  /* segments fill the column so the drag surface and the painted bar agree */
  .bar { display: flex; gap: 3px; min-width: 0; }
  .bar i { flex: 1 1 0; min-width: 0; height: 16px; background: rgba(255, 170, 60, 0.14); }
  .bar :global(i.on) { background: #ffb340; box-shadow: 0 0 6px rgba(255, 160, 40, 0.7); }
  .is-armed .bar :global(i.on) { background: #ffd070; box-shadow: 0 0 9px rgba(255, 190, 60, 0.95); }

  .seek {
    position: absolute;
    inset: -6px 0;
    width: 100%;
    margin: 0;
    opacity: 0;
    cursor: pointer;
  }

  .seek:disabled { cursor: default; }
  .bar-wrap:focus-within { outline: 2px solid #ffd070; outline-offset: 4px; }

  .time {
    text-align: right;
    font-size: 22px;
    color: #ffcf70;
  }

  /* ── channel 04 — the visitor's own track ── */
  .lcdplay .glyph.eject::before { content: '⏏'; }

  .uname {
    display: flex;
    align-items: center;
    gap: 10px;
    min-width: 0;
  }

  .uname [data-uname] {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .swap {
    all: unset;
    cursor: pointer;
    flex: none;
    font-size: 14px;
    letter-spacing: 0.08em;
    color: #8a5a18;
  }

  .swap:hover { color: #ffcf70; }
  .swap:focus-visible { outline: 2px solid #ffd070; outline-offset: 2px; }

  .local-note {
    margin: 2px 6px 0;
    font-size: 15px;
    letter-spacing: 0.1em;
    color: #8a5a18;
  }

  @keyframes src-blink {
    0%, 100% { opacity: 1; }
    20%, 60% { opacity: 0.25; }
    40%, 80% { opacity: 1; }
  }

  .mon-head :global(.blink) { animation: src-blink 0.6s steps(1) 1; }

  /* CTA — revealed the first time the visitor arms it */
  .cta {
    /* space is reserved from the start (visibility, not display) so the
       first arm doesn't grow the monitor and resize the whole cluster */
    display: block;
    visibility: hidden;
    width: 100%;
    text-align: left;
    background: none;
    border: none;
    padding: 10px 0 0;
    cursor: pointer;
    font-family: inherit;
    margin-top: 14px;
    border-top: 1px dashed rgba(255, 170, 60, 0.18);
    font-size: 20px;
    letter-spacing: 0.12em;
    color: #ffcf70;
    text-decoration: none;
    text-shadow: 0 0 8px rgba(255, 160, 40, 0.55);
    position: relative;
    z-index: 1;
  }

  .was-armed .cta { visibility: visible; animation: src-blink 0.6s steps(1) 1; }
  .cta:hover { color: #ffe6a6; }
  .cta:focus-visible { outline: 2px solid #ffd070; outline-offset: 3px; }

  @media (prefers-reduced-motion: reduce) {
    .mon-head :global(.blink), .was-armed .cta { animation: none; }
  }

  /* ── ARM bay ── */
  .armbay {
    position: relative;
    border-radius: 8px;
    padding: 12px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    background:
      repeating-linear-gradient(0deg, rgba(255, 255, 255, 0.012) 0 2px, transparent 2px 4px),
      linear-gradient(180deg, #1c150e, #100b07);
    box-shadow: inset 0 3px 8px rgba(0, 0, 0, 0.85), inset 0 -1px 1px rgba(255, 215, 150, 0.06);
  }

  /* ── ARM module — verbatim port of the plugin's #nosArm ── */
  .nos-mount {
    position: relative;
    /* fill the bay top-to-bottom; width follows the plate's 2:3 aspect */
    flex: 1 1 auto;
    min-height: 170px;
    aspect-ratio: 2 / 3;
    container-type: size;
    background: url('/plate/arm-mount-v3.png') no-repeat center / 100% 100%;
    transition: filter 0.25s ease;
  }

  .nos-mount:hover { filter: brightness(1.06); }

  .nos-mount.armed {
    filter: drop-shadow(0 0 6cqh rgba(255, 170, 32, 0.55));
  }

  .nos-mount.armed:hover {
    filter: drop-shadow(0 0 6cqh rgba(255, 170, 32, 0.55)) brightness(1.06);
  }

  .nos-pressed {
    position: absolute;
    inset: 0;
    background: url('/plate/arm-mount-v3-pressed.png') no-repeat center / 100% 100%;
    opacity: 0;
    transition: opacity 0.11s ease;
    pointer-events: none;
  }

  .nos-mount.armed .nos-pressed { opacity: 1; }

  /* the whole plate is the switch — it all looks pressable, so it all is */
  .nos-button {
    position: absolute;
    inset: 0;
    background: transparent;
    border: none;
    padding: 0;
    font-size: 0;
    cursor: pointer;
  }

  .nos-button:active { transform: scale(0.985); }
  .nos-button:focus-visible { outline: 2px solid #ffd070; outline-offset: 4px; }

  .arm-word { display: none; }

  .nos-light {
    position: absolute;
    left: 50%;
    top: 22.5%;
    width: 9%;
    aspect-ratio: 1;
    transform: translate(-50%, -50%);
    border-radius: 50%;
    background: radial-gradient(circle at 38% 34%,
      #fff2c0 0%, #ffe858 30%, #ffaa20 58%, #7a3c00 100%);
    box-shadow: 0 0 5.4cqh 1.4cqh rgba(255, 180, 40, 0.8);
    opacity: 0;
    transition: opacity 0.2s ease;
    pointer-events: none;
  }

  .nos-mount.armed .nos-light { opacity: 1; }

  .nos-state {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 16%;
    text-align: center;
    font-family: 'Special Elite', monospace;
    font-size: 7.3cqh; /* 11px at the plugin's native 150px height */
    letter-spacing: 0.22em;
    color: #7a6a4a;
    transition: color 0.2s ease, text-shadow 0.2s ease;
    pointer-events: none;
  }

  .nos-mount.armed .nos-state {
    color: #ffe858;
    text-shadow: 0 0 4.7cqh rgba(255, 200, 80, 0.7);
  }

  /* ── responsive (900 = the site-wide breakpoint) ── */
  @media (max-width: 900px) {
    .dash { grid-template-columns: 1fr; padding: 22px 16px; }
    .armbay { min-height: 260px; }
    .trk { grid-template-columns: 44px minmax(0, 1fr) 90px; grid-template-rows: auto auto; row-gap: 8px; }
    .trk .no { display: none; }
    .trk .name { grid-column: 2; }
    .trk .time { grid-column: 3; font-size: 18px; }
    .trk .bar-wrap { grid-column: 1 / -1; }
    .glass { padding: 16px 14px 12px; }
    .mon-head { font-size: 14px; }
    .trk { font-size: 20px; }
    .cta { font-size: 17px; }
  }

  @media (max-width: 420px) {
    .mon-head { font-size: 12px; letter-spacing: 0.06em; }
  }

  /* ── high contrast (html.hc): drop textures, keep function ── */
  :global(html.hc) .dash,
  :global(html.hc) .armbay,
  :global(html.hc) .monitor {
    background: var(--bg-2);
    box-shadow: none;
  }

  :global(html.hc) .dash { border: 2px solid var(--border-bright); }
  :global(html.hc) .glass { background: #000; }
  :global(html.hc) .glass::before,
  :global(html.hc) .glass::after { display: none; }

  :global(html.hc) .nos-mount,
  :global(html.hc) .nos-pressed { background: none; }

  :global(html.hc) .nos-mount {
    background: var(--bg-1);
    border: 2px solid var(--border-bright);
  }

  :global(html.hc) .nos-mount.armed {
    filter: none;
    border-color: var(--brass-bright);
  }

  :global(html.hc) .nos-button {
    background: var(--bg-2);
    border: 2px solid var(--border-bright);
  }

  /* the PNG's baked "ARM" disappears in hc — show a real label instead */
  :global(html.hc) .arm-word {
    display: block;
    font-family: var(--font-display);
    font-size: 28px;
    letter-spacing: 0.1em;
    color: var(--fg);
  }

  :global(html.hc) .swap,
  :global(html.hc) .local-note { color: var(--fg-faint); }

  :global(html.hc) .nos-state { color: var(--fg-faint); }
  :global(html.hc) .nos-mount.armed .nos-state {
    color: var(--brass-bright);
    text-shadow: none;
  }
</style>
