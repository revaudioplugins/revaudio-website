---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Cart from '../components/Cart.astro';
import { site } from '../data/site';

// Privacy-friendly analytics: only in production, only once a beacon token is set.
const analyticsOn = import.meta.env.PROD && !!site.cfBeaconToken;

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  /** When false, emit noindex. Default true now the store is live; pass index={false} to hide a single page. */
  index?: boolean;
}

const {
  title,
  description = 'RevAudio builds boutique VST plugins for producers who want tools that sound expensive and play simple.',
  ogImage = '/og-default.png',
  index = true,
} = Astro.props;

const fullTitle = title === 'RevAudio'
  ? 'RevAudio — Plugins built like cars'
  : `${title} — RevAudio`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    {!index && <meta name="robots" content="noindex, nofollow" />}

    <!-- OG / social -->
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content="RevAudio" />
    <meta name="twitter:card" content="summary_large_image" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <title>{fullTitle}</title>

    {/* Gate for reveal pre-hide (global.css html.motion-ok rules). Runs sync in
        head so revealable elements are never visibly hidden-then-shown; without
        JS or with reduced motion the class never lands and content is static. */}
    <script is:inline>
      if (!matchMedia('(prefers-reduced-motion: reduce)').matches)
        document.documentElement.classList.add('motion-ok');
    </script>

    {/* Cloudflare Web Analytics. No SRI: CF rotates beacon.min.js and ships it
        without a published hash, so a pinned integrity would break on update.
        Token is a public beacon id, not a secret. */}
    {analyticsOn && (
      <script
        defer
        src="https://static.cloudflareinsights.com/beacon.min.js"
        data-cf-beacon={`{"token": "${site.cfBeaconToken}"}`}
      ></script>
    )}
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
    <Cart />
    <script>
      import { initMotion } from '../lib/motion';
      import { initReveals } from '../lib/reveal';
      import { initWalkthrough } from '../lib/walkthrough';
      import { initSplitHeadlines } from '../lib/splittext';
      import { initScrubs } from '../lib/scrub';
      initMotion();
      initReveals();
      initWalkthrough();
      initSplitHeadlines();
      initScrubs();
    </script>
  </body>
</html>
