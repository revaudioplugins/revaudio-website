---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PluginCard from '../../components/PluginCard.astro';
import EmailCapture from '../../components/EmailCapture.astro';
import { plugins } from '../../data/plugins';
---

<BaseLayout
  title="Store"
  description="Buy RevAudio plugins. Boutique mixing and mastering tools, simple controls, built to feel."
>
  <section class="hero" style="padding: 5rem 0 3rem;">
    <div class="container">
      <div class="tag">Store</div>
      <h1>The plugin</h1>
      <p class="lede">Single purchase. Lifetime updates within the major version. No subscription, no hassle.</p>
    </div>
  </section>

  <section class="store-grid">
    <div class="container">
      <div class="cards">
        {plugins.map((p) => <PluginCard plugin={p} />)}
      </div>
    </div>
  </section>

  <section class="store-faq section">
    <div class="container">
      <h2 class="center">Common questions</h2>
      <div class="faq-grid">
        <div>
          <h3>What do I get?</h3>
          <p class="muted">A VST3 plugin (Windows 64-bit), free updates within the major version, and a licence for one user across up to three machines you own.</p>
        </div>
        <div>
          <h3>Can I try before I buy?</h3>
          <p class="muted">Every plugin ships with a free demo build. The demo runs identically to the full plugin but periodically interrupts audio so you can audition without committing.</p>
        </div>
        <div>
          <h3>Mac version?</h3>
          <p class="muted">macOS support is on the roadmap. Buying on Windows now includes the Mac build at no extra cost when it ships.</p>
        </div>
        <div>
          <h3>Refund policy?</h3>
          <p class="muted">14-day refund, no questions asked. If a plugin doesn't deliver, take your money back.</p>
        </div>
        <div>
          <h3>How does payment work?</h3>
          <p class="muted">Checkout is handled by <a href="https://gumroad.com" target="_blank" rel="noopener">Gumroad</a>. They handle tax, VAT, and licence delivery. RevAudio never sees your card details.</p>
        </div>
        <div>
          <h3>Need help?</h3>
          <p class="muted">Email <a href="mailto:support@revaudio.com">support@revaudio.com</a> or read the <a href="/support">support page</a>.</p>
        </div>
      </div>
      <p class="center muted" style="margin-top: 2rem; font-size: 0.85rem;">
        See also <a href="/eula">licence terms</a> &middot; <a href="/support">support &amp; install</a>
      </p>
    </div>
  </section>

  <EmailCapture
    heading="Don't miss launch"
    subhead="Beta access, demo codes, and intro pricing land here first."
  />
</BaseLayout>

<style>
  .store-grid { padding: 3rem 0 4rem; }

  .cards {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    max-width: 480px;
    margin: 0 auto;
  }

  .faq-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2rem;
    margin-top: 2rem;
  }

  @media (max-width: 720px) {
    .faq-grid { grid-template-columns: 1fr; }
  }

  .faq-grid h3 {
    color: var(--brass-bright);
    margin-bottom: 0.5rem;
  }
</style>
