---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PluginCard from '../../components/PluginCard.astro';
import EmailCapture from '../../components/EmailCapture.astro';
import { plugins } from '../../data/plugins';
---

<BaseLayout
  title="Store"
  description="Buy RevAudio plugins. Boutique mixing and mastering tools, simple controls, built to feel."
>
  <section class="hero" style="padding: 5rem 0 3rem;">
    <div class="container">
      <div class="tag">Store</div>
      <h1 data-split>The plugins</h1>
      <p class="lede">Single purchase. Lifetime updates within the major version. No subscription, no hassle.</p>
    </div>
  </section>

  <section class="store-grid">
    <div class="container">
      {/* sr-only heading: the cards expose plugin names as <h3>; this gives them
          an <h2> parent so the document outline doesn't jump h1 → h3. */}
      <h2 class="sr-only">Available plugins</h2>
      <div class="cards">
        {plugins.map((p) => <PluginCard plugin={p} showCart />)}
      </div>
    </div>
  </section>

  <section class="store-faq section">
    <div class="container">
      <h2 class="center" data-split>Common questions</h2>
      <div class="faq-grid" data-reveal-group>
        <div data-reveal-item>
          <h3>What do I get?</h3>
          <p class="muted">A VST3 / AU / AAX plugin (Windows &amp; macOS), free updates within the major version, and a licence for one user across up to two machines you own.</p>
        </div>
        <div data-reveal-item>
          <h3>Can I try before I buy?</h3>
          <p class="muted">Every plugin ships with a free demo build. The demo runs identically to the full plugin but periodically interrupts audio so you can audition without committing.</p>
        </div>
        <div data-reveal-item>
          <h3>Mac and Windows?</h3>
          <p class="muted">Available on both macOS and Windows. One licence covers both installers.</p>
        </div>
        <div data-reveal-item>
          <h3>Refund policy?</h3>
          <p class="muted">14-day refund, no questions asked. If a plugin doesn't deliver, take your money back.</p>
        </div>
        <div data-reveal-item>
          <h3>How does payment work?</h3>
          <p class="muted">Checkout is fully secure. Tax and VAT are handled automatically, your licence is delivered by email, and RevAudio never sees your card details.</p>
        </div>
        <div data-reveal-item>
          <h3>Need help?</h3>
          <p class="muted">Email <a href="mailto:support@revaudio.net">support@revaudio.net</a> or read the <a href="/support">support page</a>.</p>
        </div>
      </div>
      <p class="center muted" style="margin-top: 2rem; font-size: 0.85rem;">
        See also <a href="/eula">licence terms</a> &middot; <a href="/support">support &amp; install</a>
      </p>
    </div>
  </section>

  <EmailCapture
    heading="Hear it first"
    subhead="New plugins and demo codes, straight to your inbox. No spam."
  />
</BaseLayout>

<style>
  .store-grid { padding: 3rem 0 4rem; }

  .cards {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    max-width: 480px;
    margin: 0 auto;
  }

  .faq-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2rem;
    margin-top: 2rem;
  }

  @media (max-width: 720px) {
    .faq-grid { grid-template-columns: 1fr; }
  }

  .faq-grid h3 {
    color: var(--brass-bright);
    margin-bottom: 0.5rem;
  }
</style>
