---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import BuyButton from '../components/BuyButton.astro';
import BuyButtonCrane from '../components/BuyButtonCrane.astro';
import TrialStamp from '../components/TrialStamp.astro';
import CraneDropZone from '../components/CraneDropZone.astro';
import EmailCapture from '../components/EmailCapture.astro';
import TestimonialBlock from '../components/TestimonialBlock.astro';
import StarRating from '../components/StarRating.astro';
import Gallery from '../components/Gallery.astro';
import AudioDemoRack from '../components/AudioDemoRack.astro';
import MobileBuyBar from '../components/MobileBuyBar.astro';
import HotspotTour from '../components/HotspotTour.astro';
import { plugins, isBuyable } from '../data/plugins';
import { pluginImage } from '../lib/images';
import arrowBtn from '../assets/showcase/arrow-btn.png';

export function getStaticPaths() {
  return plugins.map((p) => ({ params: { slug: p.slug }, props: { plugin: p } }));
}

const { plugin } = Astro.props;
// Pre-launch products show a "reserve / get notified" block. Once a product is
// buyable, that block contradicts the Add-to-cart button, so it's hidden.
const buyable = isBuyable(plugin);
// RevLimiter's buy card is the crane-hung door (bench: /cranelab). The flag
// also drives the --crane layout modifiers: on mobile the door FLOATS top-right
// over the hero instead of stacking below the gallery (sketch 2026-07-06),
// while the classic BuyButton aside keeps the plain stacked flow.
const crane = plugin.slug === 'revlimiter' && buyable;
// GAS's hero is a compact portrait knob shot, not a wide desktop panel — at the
// gallery's default 100%-of-column width it dwarfs the copy. Shrink it down.
const narrowHero = plugin.slug === 'gas';

// Only surface A/B demos that actually have audio. Until clips are bounced,
// the "Hear it" section stays hidden rather than showing empty placeholders.
const playableDemos = plugin.audioDemos.filter((d) => d.beforeUrl && d.afterUrl);

// Shots for the sticky feature walkthrough: hero + gallery, deduped. With a
// single shot the stage just pins; per-step crossfade activates once
// galleryImages gets real entries (each step maps to shot index, clamped).
const seenShot = new Set<string>();
const shots = [plugin.heroImage, ...plugin.galleryImages]
  .map(pluginImage)
  .filter((m): m is NonNullable<typeof m> => !!m && !seenShot.has(m.src) && !!seenShot.add(m.src));

// Scroll-linked part-highlighter (docs/revlimiter-whats-inside-handoff.md).
// Active only when the plugin has a `stage` AND every feature carries a
// `part` slug that resolves in it — otherwise the plain crossfade above
// stays untouched. Reusable: a future plugin needs only its own `stage` +
// `part` slugs in plugins.ts, no template changes.
const stageShot = plugin.stage ? pluginImage(plugin.stage.shot) : undefined;
const hasStage = !!(
  plugin.stage &&
  stageShot &&
  plugin.features.length > 0 &&
  plugin.features.every((f) => f.part && plugin.stage!.parts[f.part])
);
// Parts that swap the stage to their own screenshot (a control living in a
// separate window / modal, not on the base panel). Each renders a hidden
// overlay <img> that walkthrough.ts crossfades in; on mobile it doubles as
// that step's static preview. Keyed by part slug via data-walk-alt.
const altShots = hasStage
  ? Object.entries(plugin.stage!.parts).flatMap(([slug, p]) => {
      if (!('shot' in p)) return [];
      const img = pluginImage(p.shot);
      return img ? [{ slug, img }] : [];
    })
  : [];

// Mobile anchor sub-nav (≤900px) — jump links to the sections that actually
// render on this page, in scroll order. #buy (the aside) and #install are
// always present; Sound/Features appear only when the plugin has those.
const anchorLinks = [
  playableDemos.length > 0 && { href: '#hear-it', label: 'Sound' },
  plugin.features.length > 0 && { href: '#features', label: 'Features' },
  { href: '#buy', label: 'Pricing' },
  { href: '#install', label: 'Support' },
].filter(Boolean) as { href: string; label: string }[];
---

<BaseLayout title={plugin.name} description={plugin.oneLiner}>
  <section class="product-detail">
    <div class="container">
      {/* Mobile-only sticky anchor sub-nav (≤900px). Fixed just under the site
          header; hidden until the hero scrolls past (IntersectionObserver on the
          sentinel below product-head, same pattern as MobileBuyBar). Lenis +
          native both honour scroll-padding-top, bumped for this bar via the
          html:has() rule in the stylesheet. */}
      {anchorLinks.length >= 2 && (
        <nav class="anchor-nav" data-anchor-nav aria-label="On this page">
          <ul>
            {anchorLinks.map((l) => (
              <li><a href={l.href}>{l.label}</a></li>
            ))}
          </ul>
        </nav>
      )}
      <p class="breadcrumb"><a href="/store">&larr; Back to store</a></p>

      <div class:list={['product-head', crane && 'product-head--crane']}>
        <div class="product-info">
          {!buyable && !plugin.hideStatusPill && <span class="status-pill">{plugin.statusLabel}</span>}
          {/* Title row — the trial stamp composes WITH the h1 (flex sibling),
              riding just above its cap line like a sticker slapped next to the
              wordmark. Anchored to the title, not to pixel coordinates, so the
              composition reuses on any plugin page regardless of name length
              (wraps below the title if it can't fit). Mobile: static between
              the title and the tagline. Bench: bench/trial-stamp-test.html. */}
          <div class="title-row">
            <h1>{plugin.name}</h1>
            {plugin.trialUrl && (
              <div class="trial-slot">
                <TrialStamp plugin={plugin} />
              </div>
            )}
          </div>
          <p class="tagline">{plugin.tagline}</p>
          <p class="plain-what">{plugin.plainWhat}</p>
          <div class="stars-wrap">
            <StarRating rating={plugin.reviewsAvg} count={plugin.reviewsCount} scale={1.05} />
          </div>
          <p class="long">{plugin.longPitch}</p>

          <Gallery
            hero={plugin.heroImage}
            images={plugin.galleryImages}
            alt={`${plugin.name} interface`}
            class={narrowHero ? 'gallery--narrow' : undefined}
          />
        </div>

        <aside id="buy" class:list={['product-aside', crane && 'product-aside--crane']} data-buy-aside>
          {/* Crane door falls back to the classic block if checkout ever pauses. */}
          {crane ? <BuyButtonCrane plugin={plugin} /> : <BuyButton plugin={plugin} />}
        </aside>
      </div>

      {/* Reveal trigger for the anchor sub-nav: once this sentinel (right below
          the hero/head) scrolls above the header, the bar slides in. */}
      {anchorLinks.length >= 2 && <div data-anchor-sentinel aria-hidden="true"></div>}

      {/* No data-reveal on the walkthrough section or .walk-grid: an animated
          ancestor transform would break position:sticky on the stage. Same
          rule extends to the highlight box: it lives INSIDE .stage-frame,
          never on .walk-stage or any shared ancestor. The screenshot itself
          is never transformed — no zoom/pan, ever, on .stage-zoom or its
          children — only the box animates. */}
      {plugin.features.length > 0 && (
        <section class="features" id="features" data-walkthrough data-walk-mode={hasStage ? 'stage' : 'crossfade'}>
          <h2 data-split>What's inside</h2>
          <div class="walk-grid" data-stage-parts={hasStage ? JSON.stringify(plugin.stage!.parts) : undefined}>
            <div class="walk-copy">
              {plugin.features.map((f, i) => (
                <div
                  class="walk-step"
                  data-walk-step
                  data-shot={shots.length ? Math.min(i, shots.length - 1) : 0}
                  data-part={hasStage ? f.part : undefined}
                >
                  <span class="f-name">{f.name}</span>
                  <p class="f-desc">{f.desc}</p>
                </div>
              ))}
            </div>

            {hasStage ? (
              <div class="walk-stage">
                <div class="stage-frame" data-walk-stage>
                  <div class="stage-zoom">
                    <Image
                      src={stageShot!}
                      alt={`${plugin.name} interface`}
                      width={1200}
                      widths={[600, 900, 1200]}
                      sizes="(max-width: 900px) 100vw, 560px"
                      format="webp"
                      loading="lazy"
                      class="walk-shot base"
                    />
                    {/* Alt panels (own-window controls) — stacked, hidden;
                        walkthrough.ts crossfades the active one in. */}
                    {altShots.map((a) => (
                      <Image
                        src={a.img}
                        alt=""
                        width={1200}
                        widths={[600, 900, 1200]}
                        sizes="(max-width: 900px) 100vw, 560px"
                        format="webp"
                        loading="lazy"
                        class="walk-shot alt"
                        data-walk-alt={a.slug}
                      />
                    ))}
                    <div class="stage-box" data-walk-box aria-hidden="true"></div>
                  </div>
                </div>
              </div>
            ) : (
              shots.length > 0 && (
                <div class="walk-stage">
                  <div class="stage-frame" data-walk-stage>
                    {shots.map((s, i) => (
                      <Image
                        src={s}
                        alt={i === 0 ? `${plugin.name} interface` : ''}
                        width={1000}
                        widths={[480, 800, 1000]}
                        sizes="(max-width: 900px) 100vw, 560px"
                        format="webp"
                        loading="lazy"
                        class={`walk-shot ${i === 0 ? 'base' : ''}`}
                        data-walk-shot={i}
                      />
                    ))}
                  </div>
                </div>
              )
            )}
          </div>

          {/* Mobile-only carousel controls (Phase B). The 13-card swipe row got
              only a counter + a card peek as cues; these ≥44px arrows scroll the
              native scroll-snap container (walkthrough.ts calls scrollBy) and a
              right-edge fade on .walk-copy signals more cards. Hidden ≥901px,
              where the walkthrough is the pinned desktop stage. */}
          <div class="walk-nav" data-walk-nav aria-hidden="true">
            <button type="button" class="walk-arrow walk-prev" data-walk-prev aria-label="Previous feature">
              <Image src={arrowBtn} alt="" width={140} format="webp" loading="lazy" />
            </button>
            <button type="button" class="walk-arrow walk-next" data-walk-next aria-label="Next feature">
              <Image src={arrowBtn} alt="" width={140} format="webp" loading="lazy" />
            </button>
          </div>
        </section>
      )}

      {/* C1 — mobile-only annotated dashboard (hidden >900px; desktop has the
          interactive walkthrough above). Self-hides unless the plugin has a
          `stage` + ≥5 part-tagged features. */}
      {hasStage && <HotspotTour plugin={plugin} />}

      {playableDemos.length > 0 && (
        <section class="audio-demos" id="hear-it">
          <h2 data-split>Hear it</h2>
          <p class="muted" data-reveal>Before / after on real source material. No staged transients, no cherry-picked frequency content. Hit play, then <span class="hear-desk">punch <strong>ARM</strong></span><span class="hear-mob">flip <strong>the switch</strong></span> to drop RevLimiter onto the bus.</p>
          <AudioDemoRack demos={playableDemos} plugin={plugin} />
        </section>
      )}

      {plugin.tutorialVideo && (
        <section class="video-section" id="drivers-manual">
          <h2 data-split>{plugin.tutorialVideo.title}</h2>
          {plugin.tutorialVideo.blurb && <p class="muted" data-reveal>{plugin.tutorialVideo.blurb}</p>}
          {/* Click-to-load facade: no ~900KB YouTube player JS (and no
              youtube.com request) until the visitor taps. Poster is YouTube's
              own thumbnail on a brand brown-black plate; a tap swaps in the
              autoplay iframe (script below). Aspect-ratio 16/9 is reserved on
              .video-frame, so the swap causes no layout shift. */}
          <div class="video-frame" data-reveal>
            <button
              type="button"
              class="video-facade"
              data-yt-facade
              data-yt-id={plugin.tutorialVideo.youtubeId}
              data-yt-title={`${plugin.name} — ${plugin.tutorialVideo.title}`}
              aria-label={`Play video: ${plugin.name} — ${plugin.tutorialVideo.title}`}
            >
              <img
                class="video-poster"
                src={`https://i.ytimg.com/vi/${plugin.tutorialVideo.youtubeId}/hqdefault.jpg`}
                alt=""
                loading="lazy"
                decoding="async"
                width="480"
                height="360"
              />
              <span class="video-play" aria-hidden="true"></span>
            </button>
          </div>
        </section>
      )}

      <section class="specs-section">
        <h2 data-split>System requirements</h2>
        <div class="specs" data-reveal>
          <div class="spec-row"><span class="key">Format</span><span class="val">{plugin.systemReq.formats}</span></div>
          <div class="spec-row"><span class="key">OS</span><span class="val">{plugin.systemReq.os}</span></div>
          <div class="spec-row"><span class="key">CPU</span><span class="val">{plugin.systemReq.cpu}</span></div>
          <div class="spec-row"><span class="key">RAM</span><span class="val">{plugin.systemReq.ram}</span></div>
          <div class="spec-row"><span class="key">Tested DAWs</span><span class="val">{plugin.systemReq.daws}</span></div>
        </div>
      </section>

      <section class="install-section" id="install">
        <h2 data-split>{plugin.isFree ? 'Install' : 'Install & activate'}</h2>
        {plugin.isFree ? (
          <ol class="muted" data-reveal>
            <li>Download the installer &mdash; free, no account required.</li>
            <li>Run the installer. {plugin.name} installs to the standard VST3, AU, and AAX folders for your OS.</li>
            <li>Open your DAW and scan for plugins (VST3 / AU / AAX). No serial, no activation.</li>
          </ol>
        ) : (
          <ol class="muted" data-reveal>
            <li>Buy securely &mdash; serial delivered to your inbox in under 5 minutes.</li>
            <li>Run the installer. {plugin.name} installs to the standard VST3, AU, and AAX folders for your OS.</li>
            <li>Open your DAW, scan for plugins (VST3 / AU / AAX), paste your serial on first launch.</li>
            <li>Up to 2 machines per licence. Lost serial? Email support and we resend within one business day.</li>
          </ol>
        )}
        <p class="muted" data-reveal>
          Full install + troubleshooting on the <a href="/support">support page</a>.
          Licence terms on the <a href="/eula">EULA page</a>.
        </p>

        {/* page-bottom landing site for the crane door: absolute overlay in
            this section's empty right half, straight under the aside door's
            hang point (runtime-measured x). Zero layout footprint; silent
            until drop() — see CraneDropZone's surprise contract. */}
        {crane && <CraneDropZone plugin={plugin} />}
      </section>

      <TestimonialBlock plugin={plugin.slug} heading={`What producers say about ${plugin.name}`} />
    </div>
  </section>

  {buyable && <MobileBuyBar plugin={plugin} />}

  {/* DEBUG (position bench): #stampedit drags the trial stamp live on the real
      page and prints the CSS to paste into .trial-slot — same hash-gate family
      as the crane's #cranep/#cranelight. No-op without the hash. The slot sits
      in the title-row flex now, so the bench nudges via transform:translate
      (a delta on the flex position), not left/top. */}
  {plugin.trialUrl && (
    <script>
      // NOTE: conditionally-rendered scripts are inlined VERBATIM (no TS
      // compile) — keep this block plain JS.
      const q = new URLSearchParams(location.hash.slice(1));
      const slot = document.querySelector('.trial-slot');
      if (q.has('stampedit') && slot) {
        // editing: the stamp must not navigate
        slot.addEventListener('click', (e) => { e.preventDefault(); e.stopPropagation(); }, true);
        slot.style.cursor = 'move';
        const out = document.createElement('div');
        // top-right, clear of the cookie banner (bottom strip)
        out.style.cssText = 'position:fixed;top:90px;right:12px;z-index:9999;background:#000c;color:#e8c878;font:12px/1.6 monospace;padding:10px 14px;border:1px solid #3a3128;border-radius:6px;white-space:pre';
        document.body.appendChild(out);
        let dx = 0, dy = 0;
        const apply = () => {
          // keep the CSS -50% vertical anchor; the bench only adds a delta
          slot.style.transform = `translate(${dx}px, calc(-50% + ${dy}px))`;
          out.textContent = `.trial-slot {\n  margin-left: calc(clamp(1rem,2vw,2.25rem) + ${dx}px);\n  transform: translateY(calc(-50% + ${dy}px));\n}\ndrag stamp · arrows nudge · shift=10px`;
        };
        apply();
        let drag = null;
        slot.addEventListener('pointerdown', (e) => {
          drag = { x: e.clientX - dx, y: e.clientY - dy };
          slot.setPointerCapture(e.pointerId);
          e.preventDefault();
        });
        slot.addEventListener('pointermove', (e) => {
          if (!drag) return;
          dx = Math.round(e.clientX - drag.x);
          dy = Math.round(e.clientY - drag.y);
          apply();
        });
        slot.addEventListener('pointerup', () => { drag = null; apply(); });
        window.addEventListener('keydown', (e) => {
          if (!['ArrowLeft', 'ArrowRight', 'ArrowUp', 'ArrowDown'].includes(e.key)) return;
          e.preventDefault();
          const step = e.shiftKey ? 10 : 1;
          dx += e.key === 'ArrowLeft' ? -step : e.key === 'ArrowRight' ? step : 0;
          dy += e.key === 'ArrowUp' ? -step : e.key === 'ArrowDown' ? step : 0;
          apply();
        });
      }
    </script>
  )}

  {/* id="waitlist" keeps BuyButton's /{slug}#waitlist links landing on the one capture form. */}
  {!buyable && <EmailCapture id="waitlist" />}

  {/* YouTube facade → real player. Injects the autoplay iframe only on tap, so
      the player JS (and the first youtube.com hit) is deferred until intent. */}
  <script>
    document.querySelectorAll<HTMLButtonElement>('[data-yt-facade]').forEach((facade) => {
      facade.addEventListener('click', () => {
        const id = facade.dataset.ytId;
        if (!id) return;
        const iframe = document.createElement('iframe');
        iframe.src = `https://www.youtube-nocookie.com/embed/${id}?autoplay=1&rel=0`;
        iframe.title = facade.dataset.ytTitle ?? '';
        iframe.allow =
          'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share';
        iframe.referrerPolicy = 'strict-origin-when-cross-origin';
        iframe.allowFullscreen = true;
        facade.replaceWith(iframe);
        iframe.focus();
      });
    });
  </script>

  {/* Mobile anchor sub-nav: slide the bar in once the hero scrolls past the
      sentinel, and mirror the active section on its links. IO-only, same family
      as MobileBuyBar; on desktop the bar is display:none so this is inert. */}
  <script>
    const anav = document.querySelector('[data-anchor-nav]');
    const sentinel = document.querySelector('[data-anchor-sentinel]');
    if (anav && sentinel) {
      const reveal = new IntersectionObserver(
        ([e]) => anav.classList.toggle('is-shown', !e.isIntersecting && e.boundingClientRect.top < 60),
        { rootMargin: '-48px 0px 0px 0px', threshold: 0 },
      );
      reveal.observe(sentinel);

      // Active-link scroll-spy. Position-based (not IntersectionObserver) so it
      // stays accurate across un-anchored sections between the targets (e.g. the
      // specs block) and regardless of nav order — #buy sits up in the hero head
      // while it renders first in the bar. Sorted by document position; the last
      // target whose top has passed the header+bar line wins.
      const links = Array.from(anav.querySelectorAll<HTMLAnchorElement>('a'));
      const targets = links
        .map((a) => ({ a, el: document.getElementById(a.getAttribute('href')!.slice(1)) }))
        .filter((t): t is { a: HTMLAnchorElement; el: HTMLElement } => !!t.el)
        .sort((x, y) => x.el.getBoundingClientRect().top - y.el.getBoundingClientRect().top);
      if (targets.length) {
        const line = 110; // ~header (44) + bar (44) + margin
        const updateActive = () => {
          let current = targets[0];
          for (const t of targets) {
            if (t.el.getBoundingClientRect().top - line <= 0) current = t;
          }
          links.forEach((l) => l.classList.toggle('is-active', l === current.a));
        };
        updateActive();
        window.addEventListener('scroll', () => requestAnimationFrame(updateActive), { passive: true });
      }
    }
  </script>
</BaseLayout>

<style>
  .product-detail { padding: 3rem 0 5rem; }

  /* ── Mobile anchor sub-nav (≤900px only) — thin VT323 strip on brown-black,
     fixed directly under the sticky site header. Desktop never renders it. ── */
  .anchor-nav {
    display: none;
    position: fixed;
    top: calc(var(--nav-h) + env(safe-area-inset-top, 0px));
    left: 0;
    right: 0;
    z-index: 45; /* below the header (z50), above page content */
    background: #120804;
    border-bottom: 1px solid var(--brass-dark);
    box-shadow: 0 6px 18px rgba(0, 0, 0, 0.45);
    transform: translateY(-100%);
    opacity: 0;
    transition: transform 0.28s var(--ease-settle), opacity 0.28s var(--ease-settle);
  }
  .anchor-nav ul {
    display: flex;
    list-style: none;
    margin: 0;
    padding: 0 env(safe-area-inset-right, 0px) 0 env(safe-area-inset-left, 0px);
    overflow-x: auto;
    scrollbar-width: none;
    -webkit-overflow-scrolling: touch;
  }
  .anchor-nav ul::-webkit-scrollbar { display: none; }
  .anchor-nav a {
    display: flex;
    align-items: center;
    min-height: 44px;
    padding: 0 1.1rem;
    font-family: 'VT323', var(--font-mono);
    font-size: 1.05rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    white-space: nowrap;
    color: var(--fg-dim);
  }
  .anchor-nav a.is-active {
    color: #e83a3a;
    box-shadow: inset 0 -2px 0 #e83a3a;
  }
  @media (hover: hover) {
    .anchor-nav a:hover { color: var(--brass-bright); }
  }
  @media (max-width: 900px) {
    .anchor-nav { display: block; }
    .anchor-nav.is-shown { transform: translateY(0); opacity: 1; }
    /* Clear the header + this bar (each ~44px) so anchored sections land below
       both — Lenis and native scrolling both read scroll-padding-top. */
    :global(html:has([data-anchor-nav])) {
      scroll-padding-top: calc(var(--nav-h) + 44px + 0.75rem);
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .anchor-nav { transition: none; }
  }

  .breadcrumb {
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--fg-faint);
    margin-bottom: 1.5rem;
  }

  .breadcrumb a { color: var(--fg-dim); }
  .breadcrumb a:hover { color: var(--brass-bright); }

  .product-head {
    display: grid;
    grid-template-columns: 1fr minmax(320px, 400px);
    gap: 3rem;
    align-items: start;
    margin-bottom: 4rem;
  }

  @media (max-width: 900px) {
    .product-head { grid-template-columns: 1fr; }
  }

  .status-pill {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--brass);
    border: 1px solid var(--brass-dark);
    padding: 0.25rem 0.6rem;
    margin-bottom: 1rem;
  }

  .product-info h1 {
    color: var(--brass-bright);
    margin: 0 0 0.25rem;
  }

  .tagline {
    font-family: var(--font-mono);
    text-transform: uppercase;
    font-size: 0.85rem;
    letter-spacing: 0.1em;
    color: var(--brass);
    margin: 0 0 1rem;
  }

  .plain-what {
    font-size: 1.2rem;
    line-height: 1.45;
    color: var(--fg);
    max-width: 54ch;
    margin: 0 0 1.5rem;
    padding-left: 0.9rem;
    border-left: 3px solid var(--brass);
  }

  .long { font-size: 1.05rem; color: var(--fg-dim); max-width: 60ch; margin-bottom: 2rem; }

  /* GAS's hero is a compact portrait knob shot, not a wide desktop panel —
     at the gallery's default 100%-of-column width it dwarfs the copy. ~40% of
     that width reads as a proper product photo instead of a poster. Applied
     as a class on Gallery's own root (not a wrapper div): the crane's mobile
     layout reorders .gallery via flex `order`, which requires it stay a
     DIRECT child of .product-info. */
  :global(.gallery--narrow) { max-width: 40%; }
  @media (max-width: 900px) {
    :global(.gallery--narrow) { max-width: 60%; margin-inline: auto; }
  }

  .features { padding: 2rem 0 3rem; border-top: 1px solid var(--border); }

  /* ── Sticky feature walkthrough (motion plan step 3). Stage column pins via
     native position:sticky while the copy steps scroll past; JS in
     src/lib/walkthrough.ts toggles .active + crossfades shots. ── */
  .walk-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1.15fr);
    gap: 3rem;
    align-items: start;
    margin-top: 1rem;
  }

  .walk-step {
    min-height: 36vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 1.25rem;
    background: var(--bg-1);
    border-left: 3px solid var(--border-bright);
    margin-bottom: 0.75rem;
  }

  /* De-emphasise inactive steps only when the motion system is live; static/no-JS
     readers get every step at full strength. Emphasis is COLOR-based, not opacity —
     opacity:0.35 dropped the step text under 4.5:1 (WCAG 1.4.3 Contrast). Both the
     dimmed (--fg-dim ≈5:1) and active states stay above AA. */
  :global(html.motion-ok) .walk-step {
    transition: border-color 0.45s var(--ease-settle);
  }
  :global(html.motion-ok) .walk-step .f-name { color: var(--fg-dim); }
  :global(html.motion-ok) .walk-step .f-desc { color: var(--fg-dim); }
  :global(html.motion-ok) .walk-step .f-name,
  :global(html.motion-ok) .walk-step .f-desc { transition: color 0.45s var(--ease-settle); }

  :global(html.motion-ok) .walk-step.active {
    border-left-color: var(--brass);
  }
  :global(html.motion-ok) .walk-step.active .f-name { color: var(--brass-bright); }
  :global(html.motion-ok) .walk-step.active .f-desc { color: var(--fg); }

  .walk-stage {
    position: sticky;
    /* Clear the sticky site header (--nav-h) plus headroom for the ±12px
       scrubbed drift — otherwise the unit's top tucks behind the nav blur. */
    top: calc(var(--sale-h, 0px) + var(--nav-h, 75px) + 1.5rem);
  }

  .stage-frame {
    position: relative;
    width: fit-content; /* border hugs the image when height-limited */
    margin-inline: auto;
    background: var(--bg-2);
    border: 1px solid var(--border-bright);
    border-radius: 10px;
    overflow: hidden;
    box-shadow: 0 24px 60px rgba(0, 0, 0, 0.55);
  }

  .walk-shot { width: 100%; height: auto; display: block; }

  /* The whole unit must fit the viewport below the header, even on short
     laptop windows — never pin a shot the viewer can't see in full. */
  .stage-frame .walk-shot.base {
    max-height: calc(100vh - var(--sale-h, 0px) - var(--nav-h, 75px) - 6rem);
    width: auto;
    max-width: 100%;
  }

  /* Overlay shots stack on the base; walkthrough.ts crossfades opacity. */
  .stage-frame .walk-shot:not(.base) {
    position: absolute;
    inset: 0;
    height: 100%;
    object-fit: contain;
    opacity: 0;
  }

  /* ── Part-highlighter overlay (stage mode only — see plugins.ts `stage`).
     CSS default = full/undimmed/no box; walkthrough.ts is the only thing that
     ever animates the box, so no-JS + reduced-motion readers see the whole
     screenshot at rest, exactly like the crossfade fallback. ── */
  .stage-zoom {
    /* Plain wrapper — never transformed. The screenshot sits static; only
       .stage-box (below) ever animates, so nothing here jitters. */
    position: relative;
    display: inline-block;
  }

  .stage-box {
    position: absolute;
    left: 50%;
    top: 50%;
    width: 0;
    height: 0;
    opacity: 0;
    pointer-events: none;
    border-radius: 6px;
    z-index: 2;
    /* Ring + glow around the active part, plus a giant spread that (clipped by
       .stage-frame's overflow:hidden) reads as a dim mask over everything
       outside the box — one element does both jobs, no separate mask layer
       to keep in sync while the box moves/resizes. */
    box-shadow:
      0 0 0 2px var(--brass-bright),
      0 0 22px 4px rgba(232, 200, 120, 0.35),
      0 0 0 9999px rgba(6, 8, 10, 0.55);
  }

  /* Odometer counter for the mobile carousel ("04 / 13") — injected by
     walkthrough.ts, so no-JS readers never see an inert element. Hidden on
     desktop. Replaces the old 13-dot row: at 13 items 6px dots were sub-3:1
     wayfinding; a tachometer page counts its progress on a readout. */
  .walk-grid :global(.walk-count) { display: none; }

  /* Carousel arrows are a phone affordance only — the desktop walkthrough is the
     pinned scroll-driven stage, so no manual controls there. Base = hidden;
     the ≤900px block below reveals them. */
  .walk-nav { display: none; }

  @media (max-width: 900px) {
    .walk-grid { grid-template-columns: 1fr; gap: 1.5rem; }
    /* The stage screenshot is dropped on phones — it duplicates the RevLimiter
       shot already shown up the page, and the swipe carousel below carries the
       walkthrough on its own. Kept in the DOM (walkthrough.ts still queries it)
       but not rendered. Desktop is unchanged (stage still pins beside steps). */
    .walk-stage { display: none; }
    /* No stage on phones, so no focus target to de-emphasise against — every
       card reads at full strength; the active card is marked by its border
       (below) and the counter. */
    :global(html.motion-ok) .walk-step .f-name { color: var(--brass-bright); }
    :global(html.motion-ok) .walk-step .f-desc { color: var(--fg-dim); }

    /* Active state: full 1px brass frame + a bg step, replacing the desktop
       3px border-left stripe (on a card carousel the stripe read as skewed
       furniture, and at --border-bright it measured 1.55:1 — invisible). The
       `border` shorthand also resets the 3px left edge from the base rule. */
    .walk-step { border: 1px solid var(--border-bright); }
    :global(html.motion-ok) .walk-step { transition: border-color 0.45s var(--ease-settle), background-color 0.45s var(--ease-settle); }
    :global(html.motion-ok) .walk-step.active {
      border-color: var(--brass);
      background: var(--bg-2);
    }

    /* ── Swipe carousel: 13 stacked step boxes ran 5-6 screens tall on phones,
       so under 900px the copy column becomes a horizontal scroll-snap row of
       cards instead. Pure CSS — works without JS; walkthrough.ts only adds
       the dot indicator + active tracking on top. ── */
    .walk-copy {
      display: flex;
      gap: 0.75rem;
      min-width: 0;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      /* Bleed to the screen edges so the next card peeks from the edge —
         the peek is the swipe affordance. Gutter = .container padding. */
      margin-inline: calc(-1 * var(--space-5));
      padding-inline: var(--space-5);
      scroll-padding-inline: var(--space-5);
      scrollbar-width: none;
      -webkit-overflow-scrolling: touch;
      /* Right-edge fade cue: the last visible card dissolves into the page,
         reading as "swipe right for more". Mask sits on the scroll viewport, so
         it stays put as cards scroll under it. */
      -webkit-mask-image: linear-gradient(to right, #000 82%, transparent 100%);
              mask-image: linear-gradient(to right, #000 82%, transparent 100%);
    }
    .walk-copy::-webkit-scrollbar { display: none; }

    /* Text-only cards: flex row default `align-items: stretch` gives every
       card the height of the tallest, so titles/descriptions align cleanly
       across the swipe regardless of copy length. */
    .walk-step {
      flex: 0 0 78%; /* next card peeks ~15% at the right edge */
      max-width: 320px;
      scroll-snap-align: start;
      min-height: 0;
      margin-bottom: 0;
      justify-content: flex-start;
    }

    .walk-grid :global(.walk-count) {
      display: block;
      text-align: center;
      margin-top: 0.75rem;
      font-family: var(--font-mono);
      font-variant-numeric: tabular-nums; /* odometer digits don't jiggle */
      font-size: 1rem; /* Phase B: bumped 0.85→1rem so the "01 / 13" readout ≥13px */
      letter-spacing: 0.14em;
      color: var(--fg-dim);
    }
    .walk-grid :global(.walk-count .wc-cur) { color: var(--brass-bright); }

    /* Prev/next carousel arrows — reuse the showcase arrow plate. */
    .walk-nav {
      display: flex;
      justify-content: center;
      gap: 2.5rem;
      margin-top: 0.75rem;
    }
    .walk-arrow {
      width: 56px;
      min-height: 44px;
      padding: 0;
      border: 0;
      background: none;
      cursor: pointer;
      line-height: 0;
    }
    .walk-arrow :global(img) {
      width: 100%;
      height: auto;
      display: block;
      filter: grayscale(0.3) brightness(0.8);
      opacity: 0.85;
      transition: transform 0.12s var(--ease), filter 0.2s var(--ease), opacity 0.2s var(--ease);
    }
    .walk-prev :global(img) { transform: scaleX(-1); }
    .walk-next:active :global(img) { transform: scale(0.92); }
    .walk-prev:active :global(img) { transform: scaleX(-1) scale(0.92); }
  }

  @media (hover: hover) and (max-width: 900px) {
    .walk-arrow:hover :global(img) { filter: grayscale(0) brightness(0.95); opacity: 1; }
  }
  @media (prefers-reduced-motion: reduce) {
    .walk-arrow :global(img) { transition: none; }
  }

  .f-name {
    color: var(--brass-bright);
    font-family: var(--font-display);
    letter-spacing: 0.04em;
    font-size: 1.35rem;
  }

  .f-desc { color: var(--fg-dim); font-size: 0.98rem; margin: 0.4rem 0 0; max-width: 44ch; }

  .audio-demos { padding: 2rem 0 3rem; border-top: 1px solid var(--border); }

  /* the intro names the control: desktop has the ARM plate, mobile has the
     in-glass A/B switch (AudioDemoRack's 900px layout) */
  .audio-demos .hear-mob { display: none; }
  @media (max-width: 900px) {
    .audio-demos .hear-desk { display: none; }
    .audio-demos .hear-mob { display: inline; }
  }

  /* ── Driver's Manual (plugin.tutorialVideo) — brass-framed 16:9 embed,
     framed like the walkthrough stage. ── */
  .video-section { padding: 2rem 0 3rem; border-top: 1px solid var(--border); }

  .video-section .muted { max-width: 60ch; }

  .video-frame {
    position: relative;
    max-width: 860px;
    aspect-ratio: 16 / 9;
    margin-top: 1.5rem;
    background: var(--bg-1);
    border: 1px solid var(--border-bright);
    border-radius: 10px;
    overflow: hidden;
    box-shadow: 0 24px 60px rgba(0, 0, 0, 0.55);
  }

  .video-frame iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }

  /* ── Click-to-load facade (race-red #e83a3a play badge on brown-black
     #120804). The whole frame is the button, so the tap target is far larger
     than the 44px minimum; the badge is 72px. ── */
  .video-facade {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    padding: 0;
    border: 0;
    display: block;
    cursor: pointer;
    background: #120804;
    overflow: hidden;
  }

  .video-poster {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    /* hqdefault is 4:3 — cover crops its letterbox bars to the 16:9 frame */
    object-fit: cover;
    opacity: 0.82;
    transition: opacity 0.25s var(--ease), transform 0.4s var(--ease);
  }

  .video-facade:hover .video-poster,
  .video-facade:focus-visible .video-poster {
    opacity: 1;
    transform: scale(1.03);
  }

  .video-play {
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    width: 72px;
    height: 72px;
    border-radius: 50%;
    background: #e83a3a;
    border: 3px solid #120804;
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.55), 0 0 0 6px rgba(232, 58, 58, 0.18);
    transition: transform 0.15s var(--ease), background 0.2s var(--ease);
  }

  .video-play::before {
    content: '';
    position: absolute;
    left: 54%;
    top: 50%;
    transform: translate(-50%, -50%);
    border-style: solid;
    border-width: 13px 0 13px 22px;
    border-color: transparent transparent transparent #120804;
  }

  .video-facade:hover .video-play,
  .video-facade:focus-visible .video-play {
    transform: translate(-50%, -50%) scale(1.08);
    background: #ff4a4a;
  }

  .video-facade:focus-visible {
    outline: 2px solid var(--brass-bright);
    outline-offset: 3px;
  }

  @media (prefers-reduced-motion: reduce) {
    .video-poster, .video-play { transition: none; }
  }

  /* high contrast: drop the poster tint, keep the badge legible */
  :global(html.hc) .video-facade { background: var(--bg-2); }
  :global(html.hc) .video-poster { opacity: 1; }
  :global(html.hc) .video-play { border-color: var(--fg); }

  /* ── Trial stamp slot — the stamp itself lives in TrialStamp.astro; this
     slot owns WHERE it sits. Desktop: flex sibling of the h1 in .title-row,
     lifted above the cap line (negative margin) so it reads as a sticker
     slapped beside the wordmark. The title is the anchor — no head-relative
     coordinates — so the pair composes the same for any plugin name. ── */
  .product-head { position: relative; }

  /* inline-block = the row hugs the wordmark, so the stamp can anchor to the
     title's RIGHT EDGE (left:100%) and float out into the empty gap between
     the text column and the door — not confined to the text column's width
     (which would wrap it below the title). Absolute = out of flow, so it never
     pushes the tagline down. */
  .title-row { position: relative; display: inline-block; }

  .trial-slot {
    position: absolute;
    left: 100%;               /* right edge of the title */
    top: 50%;
    transform: translateY(calc(-50% - 10px));
    margin-left: clamp(1rem, 2vw, 2.25rem);
    width: min(300px, 26vw);
    z-index: 3;
  }

  /* Tight desktop band (901–1100px): the door is close enough that there's no
     real gap beside the title, so beside-placement collides with the BUY card.
     Drop the stamp below the title, left-aligned — still clear of the door. */
  @media (min-width: 901px) and (max-width: 1100px) {
    .title-row { display: block; }
    .trial-slot {
      position: static;
      transform: none;
      width: min(280px, 30vw);
      margin: 0.6rem 0 0.4rem;
    }
  }

  @media (max-width: 900px) {
    /* Stacked on phones: the door floats over the head up top, so the stamp
       flows in the reading instead — centered between the title and tagline. */
    .title-row { display: block; }
    .trial-slot {
      position: static;
      transform: none;
      width: min(260px, 72vw);
      margin: 0.75rem auto 1rem;
    }
  }

  .specs-section { padding: 2rem 0 3rem; border-top: 1px solid var(--border); }

  /* position:relative = the anchor box for the crane drop-zone overlay
     (CraneDropZone.astro sits absolute in the empty right half). */
  .install-section { padding: 2rem 0 3rem; border-top: 1px solid var(--border); position: relative; }

  .install-section ol {
    margin: 1rem 0;
    padding-left: 1.5rem;
  }

  .install-section ol li { margin: 0.5rem 0; }

  /* ── Mobile crane layout (RevLimiter only — .product-head--crane): the door
     buy card floats top-right OVER the hero instead of stacking below the
     gallery, mimicking the desktop "lowered from the top of the website"
     conceit (user phone sketch 2026-07-06). Scoped to the --crane modifiers so
     the classic BuyButton aside keeps its plain stacked flow on other plugins.
     Kept LAST in this style block on purpose: later same-specificity base
     rules would silently beat an earlier media override. ── */
  @media (max-width: 900px) {
    .product-head--crane { position: relative; }

    /* Declutter the top strip on the crane (RevLimiter) page: the door already
       carries availability ("$56 LAUNCH SALE / BUY NOW") and the store is one
       nav tap away, so the breadcrumb + status pill read as orphaned furniture
       under the floating door. Scoped to the crane page only — other product
       pages keep both. */
    .product-detail:has(.product-head--crane) .breadcrumb { display: none; }
    .product-head--crane .status-pill { display: none; }

    .product-aside--crane {
      position: absolute;
      /* Hang from the document top: with the breadcrumb hidden the head starts
         at the 3rem section padding, so a 3rem pull lands the door at the top;
         the chain continues under the sticky nav (z50 beats our z2). */
      top: -3rem;
      /* Centre the door over the (now centred) header column. left+right+auto
         margins centre the fixed-width box without a transform — the gsap
         descent drives transforms on the crane's inner layers, so the wrapper
         stays transform-free to avoid stacking it against them. */
      left: 0;
      right: 0;
      margin-inline: auto;
      /* Door doubled from the prior 32.9vw/161px → 65.8vw/322px. */
      width: 65.8vw;
      max-width: 322px;
      z-index: 2;
    }

    /* Stack under the door: product-info becomes a flex column so the RevLimiter
       screenshot (.gallery) jumps ahead of the reading. The gallery sits right
       under the door and carries the door clearance; the reading (h1 → tagline →
       plain-what → long) follows it in DOM order. */
    .product-head--crane .product-info {
      display: flex;
      flex-direction: column;
    }

    /* Flatten title-row so h1 and .trial-slot become independent flex children,
       letting the trial stamp order AFTER the gallery. Door-clearing margin
       moves to h1 (display:contents has no box, so margins on it are inert).
       :global — .gallery is the Gallery component's root, no page scope hash. */
    .product-head--crane .product-info .title-row { display: contents; }
    .product-head--crane .product-info h1 {
      order: 1;
      margin-top: max(0px, calc(min(117.9vw, 577px) - 36px));
    }
    .product-head--crane .product-info .tagline   { order: 2; }
    .product-head--crane .product-info :global(.gallery) {
      order: 3;
      margin-bottom: 1.75rem;
    }
    .product-head--crane .product-info .trial-slot { order: 4; }
    .product-head--crane .product-info .plain-what { order: 5; }
    .product-head--crane .product-info .stars-wrap { order: 6; }
    .product-head--crane .product-info .long      { order: 7; }

    /* Centre the header reading: the door floats top-right above this column,
       so a centred stack reads as a composed hero rather than ragged-left
       under the door. The .plain-what brass stripe is a left-edge accent —
       incoherent under centred text — so it drops here (kept on desktop). The
       capped-width blocks (plain-what 54ch, long 60ch) also need auto side
       margins to sit centred once the viewport clears their max-width. */
    .product-head--crane .product-info :is(h1, .tagline, .plain-what, .long) {
      text-align: center;
    }
    .product-head--crane .product-info .plain-what {
      border-left: 0;
      padding-left: 0;
      margin-inline: auto;
    }
    .product-head--crane .product-info .long { margin-inline: auto; }
  }
</style>
