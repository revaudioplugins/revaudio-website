---
import BaseLayout from '../layouts/BaseLayout.astro';
import EmailCapture from '../components/EmailCapture.astro';
---

<BaseLayout
  title="The AC"
  description="The AC — air-band exciter and tube saturator. Cold to hot, the AC dashboard turns shine into breath."
>
  <section class="plugin-detail">
    <div class="container">
      <h1>The AC</h1>
      <p class="pitch">
        An air-band exciter and tube saturator built like a car AC panel.
        Crank the temperature: cold opens the high shelf, hot brings the tubes.
        Mid is both. Either way the mix breathes.
      </p>
      <p><a href="/store/the-ac" class="inline-cta">Pricing &amp; reserve &rarr;</a></p>

      <div class="hero-img">[ The AC UI screenshot — drop in /public/screenshots/the-ac-hero.png ]</div>

      <h3>What it does</h3>
      <p>
        A hybrid between an exciter and a saturator, focused on the air band.
        The chain runs gentle high-shelf boost &rarr; tube saturation &rarr; intelligent
        dynamic EQ that suppresses resonances before they sting. The dashboard reads
        in &deg;F and fan bars because mixing should feel like driving.
      </p>

      <div class="demo-block">
        <h3>Hear it</h3>
        <div class="ab">
          <h4>Vocal — A/B</h4>
          <div class="placeholder">[ before / after WAV — wire when bounced ]</div>
        </div>
        <div class="ab">
          <h4>Acoustic guitar — A/B</h4>
          <div class="placeholder">[ before / after WAV — wire when bounced ]</div>
        </div>
        <div class="ab">
          <h4>Full mix — A/B</h4>
          <div class="placeholder">[ before / after WAV — wire when bounced ]</div>
        </div>
      </div>

      <h3>Specs</h3>
      <div>
        <div class="spec-row"><span class="key">Format</span><span class="val">VST3</span></div>
        <div class="spec-row"><span class="key">Platform</span><span class="val">Windows 64-bit (macOS planned)</span></div>
        <div class="spec-row"><span class="key">Modes</span><span class="val">Cold (exciter) &middot; Mid (blend) &middot; Hot (tube)</span></div>
        <div class="spec-row"><span class="key">Resonance control</span><span class="val">Soothe-style narrow-band dynamic EQ</span></div>
        <div class="spec-row"><span class="key">Status</span><span class="val">In development</span></div>
      </div>
    </div>
  </section>

  <EmailCapture
    heading="Crack a window"
    subhead="Get a heads up the day The AC ships."
  />
</BaseLayout>
