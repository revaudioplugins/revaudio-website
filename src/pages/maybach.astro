---
import BaseLayout from '../layouts/BaseLayout.astro';
import EmailCapture from '../components/EmailCapture.astro';
---

<BaseLayout
  title="Maybach"
  description="Maybach — dynamic EQ with a Maybach suspension that bounces in time with your spectral moves."
>
  <section class="plugin-detail">
    <div class="container">
      <h1>Maybach</h1>
      <p class="pitch">
        A dynamic EQ with a Maybach suspension on the screen.
        The wheels and shocks move in sync with every cut and boost.
        Auto mode tames peaks for you. The ride is smooth.
      </p>

      <div class="hero-img">[ Maybach UI mockup — coming ]</div>

      <h3>What it does</h3>
      <p>
        A dynamic EQ that visualises spectral movement as a luxury car&rsquo;s rear suspension.
        Auto mode finds peaks and smooths them. Manual bands behave like any
        modern dynamic EQ &mdash; threshold, ratio, attack, release &mdash; but the
        feedback is the car. You see the work happening.
      </p>

      <h3>Status</h3>
      <p class="muted">
        Maybach is the next plugin in the lineup. Sign up to be the first to know when development opens.
      </p>
    </div>
  </section>

  <EmailCapture
    heading="Reserve your seat"
    subhead="One email when Maybach goes into beta. That&rsquo;s it."
  />
</BaseLayout>
