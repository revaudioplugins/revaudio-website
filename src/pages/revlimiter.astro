---
import BaseLayout from '../layouts/BaseLayout.astro';
import EmailCapture from '../components/EmailCapture.astro';
---

<BaseLayout
  title="RevLimiter"
  description="RevLimiter — mastering limiter built around a car rev gauge. Multi-band, oversampled, true-peak ceiling."
>
  <section class="plugin-detail">
    <div class="container">
      <h1>RevLimiter</h1>
      <p class="pitch">
        A mastering limiter that makes loudness, depth, and punch feel like floor-it-and-go.
        The redline is your threshold. The needle is your gain reduction. You drive.
      </p>

      <div class="hero-img">[ RevLimiter UI screenshot — drop in /public/screenshots/revlimiter-hero.png ]</div>

      <h3>What it does</h3>
      <p>
        Multi-band compression, analog-modelled saturation, and an adaptive limiter — chained the way
        a top-tier mastering engineer would chain them. RevLimiter sits early on the master bus and
        glues the mix together with warmth, weight, and a true-peak ceiling that holds at oversampled
        rate.
      </p>

      <div class="demo-block">
        <h3>Hear it</h3>
        <div class="ab">
          <h4>Vocal — A/B</h4>
          <div class="placeholder">[ before / after WAV — wire when bounced ]</div>
        </div>
        <div class="ab">
          <h4>Drum bus — A/B</h4>
          <div class="placeholder">[ before / after WAV — wire when bounced ]</div>
        </div>
        <div class="ab">
          <h4>Full mix master — A/B</h4>
          <div class="placeholder">[ before / after WAV — wire when bounced ]</div>
        </div>
      </div>

      <h3>Specs</h3>
      <div>
        <div class="spec-row"><span class="key">Format</span><span class="val">VST3 (AU + AAX planned)</span></div>
        <div class="spec-row"><span class="key">Platform</span><span class="val">Windows 64-bit (macOS planned)</span></div>
        <div class="spec-row"><span class="key">Oversampling</span><span class="val">Up to 16&times; for true-peak ceiling</span></div>
        <div class="spec-row"><span class="key">Bands</span><span class="val">Multi-band with adaptive release</span></div>
        <div class="spec-row"><span class="key">Metering</span><span class="val">True peak + LUFS-M/S/I + LRA + per-band GR</span></div>
        <div class="spec-row"><span class="key">Status</span><span class="val">Beta &mdash; Q3 2026</span></div>
      </div>
    </div>
  </section>

  <EmailCapture
    heading="Get the RevLimiter beta"
    subhead="Join the waitlist for early access, demo codes, and launch pricing."
  />
</BaseLayout>
