---
import BaseLayout from '../layouts/BaseLayout.astro';
import EulaContent from '../components/legal/EulaContent.astro';
/*
 * Licence terms (EULA). Body lives in the shared <EulaContent> so the page and
 * the checkout legal-reader modal (Cart.astro) render one source of truth.
 * Drafted + hardened 2026-07-01; NOT lawyer-ratified — fill the entity/address
 * placeholder in the preamble (same value as /terms §1) before publishing.
 */
---

<BaseLayout
  title="Licence terms"
  description="RevAudio plugin end-user licence agreement (EULA) — licence grant, restrictions, output ownership, warranty, and liability."
>
  <section class="plugin-detail">
    <div class="container" style="max-width: 760px;">
      <h1>Licence terms</h1>
      <EulaContent />
    </div>
  </section>
</BaseLayout>
