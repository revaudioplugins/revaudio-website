---
import BaseLayout from '../layouts/BaseLayout.astro';
import EmailCapture from '../components/EmailCapture.astro';
import { plugins, fmtPrice } from '../data/plugins';
import { everythingBundle, bundleSavingsPct, bundleSavingsUsd } from '../data/bundle';

const buyable = everythingBundle.status === 'live' && !!everythingBundle.gumroadUrl;
---

<BaseLayout title="Everything Bundle" description={everythingBundle.pitch}>
  <section class="bundle-detail">
    <div class="container">
      <p class="breadcrumb"><a href="/store">&larr; Back to lineup</a></p>

      <div class="head">
        <div class="info">
          <span class="status-pill">{everythingBundle.statusLabel}</span>
          <h1>{everythingBundle.name}</h1>
          <p class="tagline">{everythingBundle.tagline}</p>
          <p class="long">{everythingBundle.pitch}</p>
        </div>

        <aside class="aside">
          <div class="buy-block">
            <div class="prices">
              <span class="now">{fmtPrice(everythingBundle.bundlePriceUsd)}</span>
              <span class="was">{fmtPrice(everythingBundle.individualSumUsd)}</span>
              <span class="tag">&minus;{bundleSavingsPct(everythingBundle)}%</span>
            </div>
            <p class="save muted">You save {fmtPrice(bundleSavingsUsd(everythingBundle))} versus buying separately.</p>

            {buyable && everythingBundle.gumroadUrl ? (
              <a class="btn primary" href={everythingBundle.gumroadUrl}>Add to cart</a>
            ) : (
              <a class="btn primary" href="#waitlist">Join the bundle waitlist</a>
            )}

            <ul class="includes">
              <li>All four RevAudio plugins</li>
              <li>Free updates within each plugin's v1.x</li>
              <li>Mac builds included when shipped</li>
              <li>Up to 3 machines per licence</li>
              <li>14-day refund</li>
            </ul>
          </div>
        </aside>
      </div>

      <section class="contents">
        <h2>What's in the bundle</h2>
        <div class="bundle-grid">
          {plugins.map((p) => (
            <a href={`/${p.slug}`} class="bundle-card">
              <div class="bc-head">
                <h3>{p.name}</h3>
                <span class="bc-price">{fmtPrice(p.introPriceUsd)}</span>
              </div>
              <p class="bc-tagline muted">{p.tagline}</p>
              <p class="bc-pitch">{p.oneLiner}</p>
              <span class="bc-more">View {p.name} &rarr;</span>
            </a>
          ))}
        </div>
      </section>

      <section class="why">
        <h2>Why buy the bundle?</h2>
        <ul class="why-list">
          <li>
            <span class="why-name">{bundleSavingsPct(everythingBundle)}% off vs. buying separately</span>
            <span class="why-desc">Pay {fmtPrice(everythingBundle.bundlePriceUsd)} once instead of {fmtPrice(everythingBundle.individualSumUsd)}.</span>
          </li>
          <li>
            <span class="why-name">All four plugins, one purchase</span>
            <span class="why-desc">No per-plugin checkout, no licence-management gymnastics.</span>
          </li>
          <li>
            <span class="why-name">Free updates within each major version</span>
            <span class="why-desc">v1.x updates included for every plugin in the bundle.</span>
          </li>
          <li>
            <span class="why-name">Mac builds included free</span>
            <span class="why-desc">Buying the bundle on Windows now? You also get the Mac build the day it ships.</span>
          </li>
          <li>
            <span class="why-name">One coherent toolkit</span>
            <span class="why-desc">All four plugins share a design language. The shortcuts, metering, and presets feel like one product.</span>
          </li>
        </ul>
      </section>

      <section id="waitlist" class="waitlist-anchor">
        <h2>Reserve the bundle</h2>
        <p class="muted">
          The bundle goes live once at least one plugin is on sale. Join the waitlist and you'll get a 30% bundle launch
          code as soon as it opens.
        </p>
      </section>
    </div>
  </section>

  <EmailCapture
    heading="Bundle waitlist"
    subhead="Get the bundle launch code the day it opens. One email per release."
  />
</BaseLayout>

<style>
  .bundle-detail { padding: 3rem 0 5rem; }

  .breadcrumb {
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--fg-faint);
    margin-bottom: 1.5rem;
  }
  .breadcrumb a { color: var(--fg-dim); }
  .breadcrumb a:hover { color: var(--brass-bright); }

  .head {
    display: grid;
    grid-template-columns: 1fr minmax(320px, 400px);
    gap: 3rem;
    align-items: start;
    margin-bottom: 4rem;
  }

  @media (max-width: 900px) {
    .head { grid-template-columns: 1fr; }
  }

  .status-pill {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--brass);
    border: 1px solid var(--brass-dark);
    padding: 0.25rem 0.6rem;
    margin-bottom: 1rem;
  }

  .info h1 { color: var(--brass-bright); margin: 0 0 0.25rem; }

  .tagline {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--brass);
    margin: 0 0 1.5rem;
  }

  .long { font-size: 1.05rem; color: var(--fg-dim); max-width: 60ch; }

  .buy-block {
    padding: 1.75rem;
    background: var(--bg-1);
    border: 1px solid var(--border);
    border-top: 3px solid var(--brass);
  }

  .buy-block .prices {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .buy-block .now {
    font-family: var(--font-display);
    font-size: 2.5rem;
    color: var(--brass-bright);
    letter-spacing: 0.04em;
  }

  .buy-block .was {
    font-family: var(--font-display);
    font-size: 1.25rem;
    color: var(--fg-faint);
    text-decoration: line-through;
  }

  .buy-block .tag {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--oxide);
    border: 1px solid var(--oxide);
    padding: 0.15rem 0.5rem;
  }

  .save { font-size: 0.85rem; margin: 0.25rem 0 1rem; }

  .btn {
    display: block;
    padding: 0.875rem 1.5rem;
    font-family: var(--font-display);
    font-size: 1.05rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-align: center;
    background: var(--brass);
    color: var(--bg-0);
  }

  .btn:hover { background: var(--brass-bright); color: var(--bg-0); }

  .includes {
    list-style: none;
    padding: 1rem 0 0;
    margin: 1rem 0 0;
    border-top: 1px solid var(--border);
    font-size: 0.85rem;
    color: var(--fg-dim);
  }

  .includes li { padding: 0.4rem 0; }

  .includes li::before {
    content: '+ ';
    color: var(--brass);
    font-weight: 600;
  }

  .contents { padding: 2rem 0 3rem; border-top: 1px solid var(--border); }

  .bundle-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
    margin-top: 1.5rem;
  }

  @media (max-width: 720px) {
    .bundle-grid { grid-template-columns: 1fr; }
  }

  .bundle-card {
    display: block;
    padding: 1.25rem;
    background: var(--bg-1);
    border: 1px solid var(--border);
    color: inherit;
    transition: border-color 0.2s var(--ease);
  }

  .bundle-card:hover { border-color: var(--brass-dark); }

  .bc-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
  }

  .bc-head h3 { color: var(--brass-bright); margin: 0; font-size: 1.5rem; }

  .bc-price {
    font-family: var(--font-mono);
    color: var(--fg-dim);
    font-size: 0.9rem;
  }

  .bc-tagline {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin: 0.25rem 0 0.75rem;
  }

  .bc-pitch { font-size: 0.9rem; color: var(--fg-dim); margin: 0 0 0.75rem; }

  .bc-more {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--fg);
  }

  .why { padding: 2rem 0 3rem; border-top: 1px solid var(--border); }

  .why-list {
    list-style: none;
    padding: 0;
    margin: 1rem 0 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.75rem;
  }

  .why-list li {
    padding: 1rem 1.25rem;
    background: var(--bg-1);
    border-left: 3px solid var(--brass-dark);
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .why-name {
    color: var(--brass-bright);
    font-family: var(--font-display);
    letter-spacing: 0.04em;
    font-size: 1.1rem;
  }

  .why-desc { color: var(--fg-dim); font-size: 0.95rem; }

  .waitlist-anchor { padding: 3rem 0 0; scroll-margin-top: 80px; }
</style>
