---
import BaseLayout from '../layouts/BaseLayout.astro';
import EmailCapture from '../components/EmailCapture.astro';
---

<BaseLayout
  title="The Cooker"
  description="The Cooker — multi-band panner with autopilot. Set it once and let the stereo image cook itself."
>
  <section class="plugin-detail">
    <div class="container">
      <h1>The Cooker</h1>
      <p class="pitch">
        A creative stereo tool. Pan selected frequency bands left and right,
        sprinkle saturation, reverb, and tremolo per band, then hit Autopilot
        and let an LFO drive the movement. The mix breathes left to right
        without manual riding.
      </p>

      <div class="hero-img">[ The Cooker UI screenshot — drop in /public/screenshots/the-cooker-hero.png ]</div>

      <h3>What it does</h3>
      <p>
        Multi-band stereo panner with per-band saturation, reverb, and tremolo.
        Autopilot mode applies LFO modulation to the pan or any selected band, so
        a static synth pad turns into a living, drifting stereo field. Auto Swerve
        adds drift to the autopilot path so it never feels mechanical.
      </p>

      <div class="demo-block">
        <h3>Hear it</h3>
        <div class="ab">
          <h4>Synth pad — Off / Autopilot</h4>
          <div class="placeholder">[ before / after WAV — wire when bounced ]</div>
        </div>
        <div class="ab">
          <h4>Vocal — band pan demo</h4>
          <div class="placeholder">[ before / after WAV — wire when bounced ]</div>
        </div>
        <div class="ab">
          <h4>Full mix — Auto Swerve</h4>
          <div class="placeholder">[ before / after WAV — wire when bounced ]</div>
        </div>
      </div>

      <h3>Specs</h3>
      <div>
        <div class="spec-row"><span class="key">Format</span><span class="val">VST3</span></div>
        <div class="spec-row"><span class="key">Platform</span><span class="val">Windows 64-bit (macOS planned)</span></div>
        <div class="spec-row"><span class="key">Per-band FX</span><span class="val">Saturation &middot; Reverb &middot; Tremolo &middot; Pan</span></div>
        <div class="spec-row"><span class="key">Autopilot</span><span class="val">LFO modulation with Auto Swerve drift</span></div>
        <div class="spec-row"><span class="key">Status</span><span class="val">In development</span></div>
      </div>
    </div>
  </section>

  <EmailCapture
    heading="Ride along"
    subhead="Get the Cooker beta access when it opens."
  />
</BaseLayout>
