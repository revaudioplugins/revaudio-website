---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import PluginShowcase from '../components/PluginShowcase.astro';
import TestimonialBlock from '../components/TestimonialBlock.astro';
import DAWStrip from '../components/DAWStrip.astro';
import PressLogos from '../components/PressLogos.astro';
import EmailCapture from '../components/EmailCapture.astro';
import SubscribeModal from '../components/SubscribeModal.astro';
import { bySlug, isBuyable, fmtPrice } from '../data/plugins';
import signBeam from '../assets/hero/sign-beam.png';
import signHanger from '../assets/hero/sign-hanger.png';
import faceImg from '../assets/hero/rev-gauge-face.png';
import needleImg from '../assets/hero/needle-v2.png';
import hubImg from '../assets/hero/hub-v2.png';

const rl = bySlug('revlimiter');

/* Gauge geometry — the plugin's 406-viewBox units as % of the square dial box:
   needle <image> x122 y67.69 w162.4, pivot (203,203); hub x180.54 y181.08 w45.5.
   Reused at both dial sizes below — all child positioning is %-based, so it
   scales as one regardless of the dial's own width. */
const N = { left: '30.049%', top: '16.672%', w: '40%', ox: '49.877%', oy: '83.32%' };
const H = { left: '44.468%', top: '44.601%', w: '11.207%' };
---

<BaseLayout title="RevAudio">
  {/* Hero — desktop: left-aligned text column (two-line headline) with the
      original full-size REV gauge to its right. The brass STORE button is
      gone — the hanging wooden STORE sign (corner overlay, lifted 80px off
      its earlier drop) is the only "go to store" CTA now. Mobile keeps its
      own stacked layout: centered text, small gauge under the headline,
      sign hidden. Entrance: text cascade → dial settle → needle rev-blip →
      idle. Scroll revs toward the redline; pointer micro-deflects (lerp).
      Reduced motion: static needle at idle. */}
  <section class="hero hero-feat" data-hero>
    <div class="sign-mount" data-hero-in>
      <Image class="sign-beam" src={signBeam} alt="" width={872} format="webp" loading="eager" />
      <a class="hanger" data-sign href="/store" aria-label="Visit the store">
        <Image src={signHanger} alt="" width={560} format="webp" loading="eager" />
      </a>
    </div>
    <div class="hero-grid">
      <div class="hero-head">
        <div class="hh-tag" data-hero-in>Boutique VST plugins</div>
        <h1 class="hh-h1" data-split>
          <span class="hh-h1-line">Engineered,</span>
          <span class="hh-h1-line">Then Tuned.</span>
        </h1>

        {/* Mobile-only: small gauge under the headline (desktop uses the
            original full-size gauge, to the right of this text column). */}
        <div class="hero-dial hero-dial-mobile" data-dial data-hero-in role="img" aria-label="RevLimiter rev gauge — needle at idle">
          <Image class="g-face" src={faceImg} alt="" width={360} format="webp" loading="eager" />
          <div class="g-needle" data-needle style={`left:${N.left}; top:${N.top}; width:${N.w}; transform-origin:${N.ox} ${N.oy};`}>
            <Image src={needleImg} alt="" width={170} format="webp" loading="eager" />
          </div>
          <Image class="g-hub" src={hubImg} alt="" width={60} format="webp" loading="eager" style={`left:${H.left}; top:${H.top}; width:${H.w};`} />
        </div>

        <span class="hh-redline" data-hero-sweep aria-hidden="true"></span>
        <p class="hh-lede" data-hero-in>
          Measured to spec, then voiced by ear.<br />The precision of a machine, the feel of an instrument.
        </p>

        {rl && isBuyable(rl) && (
          <p class="hh-fastbuy" data-hero-in>
            <a href="/revlimiter">RevLimiter — <strong>{fmtPrice(rl.introPriceUsd)}</strong>
              <s>{fmtPrice(rl.regularPriceUsd)}</s> · Buy now &rarr;</a>
          </p>
        )}
      </div>

      {/* Desktop-only: original full-size gauge, to the right of the text. */}
      <div class="hero-dial hero-dial-desktop" data-dial role="img" aria-label="RevLimiter rev gauge — needle at idle">
        <Image class="g-face" src={faceImg} alt="" width={1100} widths={[360, 640, 1100]} sizes="(max-width: 860px) 300px, 30vw" format="webp" loading="eager" />
        <div class="g-needle" data-needle style={`left:${N.left}; top:${N.top}; width:${N.w}; transform-origin:${N.ox} ${N.oy};`}>
          <Image src={needleImg} alt="" width={500} format="webp" loading="eager" />
        </div>
        <Image class="g-hub" src={hubImg} alt="" width={200} format="webp" loading="eager" style={`left:${H.left}; top:${H.top}; width:${H.w};`} />
      </div>
    </div>
  </section>

  {/* Mobile-only: the same hanging STORE sign, in-flow and centered right
      above "Our Plugins" (desktop keeps the absolute corner overlay above,
      hidden here). Its own small positioned wrapper reserves exactly the
      scaled footprint, since once it's outside .hero-feat there's no
      positioned ancestor left for an absolute .sign-mount to anchor to. */}
  <div class="sign-mount-mobile-wrap">
    <div class="sign-mount sign-mount-mobile" data-hero-in>
      <Image class="sign-beam" src={signBeam} alt="" width={872} format="webp" loading="eager" />
      <a class="hanger" data-sign href="/store" aria-label="Visit the store">
        <Image src={signHanger} alt="" width={560} format="webp" loading="eager" />
      </a>
    </div>
  </div>

  <PluginShowcase />

  <DAWStrip />
  <TestimonialBlock heading="Producers on RevAudio" />
  <PressLogos />
  <EmailCapture id="subscribe" />
  <SubscribeModal />
</BaseLayout>

<script>
  import { gsap, ScrollTrigger, reducedMotion } from '../lib/motion';

  // Plugin scale: dB −60…0 maps to −135°…+135°. Idle ≈ −50 dB, redline ≈ −10 dB.
  const A_MIN = -135, A_IDLE = -90, A_RED = 90, A_MAX = 135;
  const root = document.querySelector<HTMLElement>('[data-hero]');
  const dials = root ? Array.from(root.querySelectorAll<HTMLElement>('[data-dial]')) : [];

  if (root) {
    if (reducedMotion()) {
      dials.forEach((dial) => {
        const needle = dial.querySelector<HTMLElement>('[data-needle]');
        if (needle) gsap.set(needle, { rotation: A_IDLE });
      });
    } else {
      // ── Entrance: text cascade + redline sweep + dial settle ──
      const tl = gsap.timeline({ defaults: { ease: 'expo.out' } });
      tl.fromTo('[data-hero-in]', { y: 24, opacity: 0 }, { y: 0, opacity: 1, duration: 0.6, stagger: 0.12 }, 0.05)
        .fromTo('[data-hero-sweep]', { scaleX: 0 }, { scaleX: 1, duration: 0.7, ease: 'power3.out' }, 0.75);

      // One render path per dial, three signals each — base (load sweep →
      // idle), scroll deflection, pointer micro-deflection (lerped). Only
      // one of the two dials is ever visible at a time (desktop vs mobile
      // breakpoint), but both animate the same way regardless.
      dials.forEach((dial) => {
        const needle = dial.querySelector<HTMLElement>('[data-needle]');
        if (!needle) return;

        const state = { base: A_MIN, scroll: 0, pointer: 0, pointerTarget: 0 };
        gsap.ticker.add(() => {
          state.pointer += (state.pointerTarget - state.pointer) * 0.08;
          gsap.set(needle, { rotation: Math.min(state.base + state.scroll + state.pointer, A_MAX) });
        });

        tl.fromTo(dial, { y: 40, scale: 0.88, opacity: 0 }, { y: 0, scale: 1, opacity: 1, duration: 0.8 }, 0.35)
          .to(state, { base: A_MAX, duration: 0.85, ease: 'power3.in' }, 0.9) // floor it
          .to(state, { base: A_IDLE, duration: 1.1, ease: 'back.out(1.05)' }, '>'); // settle to idle

        // ── Scroll: rev toward the redline as the hero leaves the viewport ──
        ScrollTrigger.create({
          trigger: root,
          start: 'top top',
          end: 'bottom 20%',
          scrub: true,
          onUpdate: (self) => { state.scroll = self.progress * (A_RED - A_IDLE); },
        });

        // ── Pointer: micro-deflection (desktop only) ──
        if (matchMedia('(pointer: fine)').matches) {
          root.addEventListener('pointermove', (e) => {
            const r = dial.getBoundingClientRect();
            state.pointerTarget = ((e.clientX - (r.left + r.width / 2)) / r.width) * 6; // ±3° feel
          });
          root.addEventListener('pointerleave', () => { state.pointerTarget = 0; });
        }
      });
    }
  }

  // ── Hanging STORE sign(s): click = kick swing, then back to idle sway ──
  // Two instances exist (desktop corner overlay + mobile in-flow); only one
  // is ever visible at a time, but both get the interaction wired up.
  document.querySelectorAll<HTMLElement>('[data-sign]').forEach((sign) => {
    if (reducedMotion()) {
      sign.classList.add('static');
    } else {
      sign.addEventListener('click', () => {
        sign.classList.remove('kick');
        void sign.offsetWidth; // restart animation
        sign.classList.add('kick');
      });
      sign.addEventListener('animationend', (e) => {
        if (e.animationName.startsWith('kick')) sign.classList.remove('kick');
      });
    }
  });
</script>

<style>
  /* ── Hero — left text column + real REV gauge on the right (desktop), plus
     the hanging STORE sign overlay. ── */
  /* border-bottom: none overrides the global .hero divider — the hero should
     flow straight into the plugin showcase. */
  /* Bottom padding +100px pushes everything below the headline/gauge row —
     the hanging sign (bottom-anchored within this section) and every
     section after it (carousel, DAW strip, ...) — down 100px as one unit,
     per Gil's request. The headline/gauge content itself is unaffected
     (top-anchored at the top of the row). */
  .hero-feat { position: relative; padding: var(--space-6) 0 calc(var(--space-8) + 100px); overflow-x: clip; border-bottom: none; }

  /* Desktop: centered text column with the gauge to its right, as one
     centered row. Mobile (below) collapses this back to a centered stack. */
  .hero-grid {
    max-width: var(--maxw);
    margin: 0 auto;
    display: flex;
    flex-direction: row;
    align-items: center;
    justify-content: center;
    text-align: center;
    gap: clamp(2.5rem, 6vw, 5rem);
    padding: clamp(1.5rem, 4vh, 3rem) clamp(1.5rem, 4vw, 4rem) 0;
  }

  .hero-head {
    display: flex;
    flex-direction: column;
    align-items: center;
    max-width: 46ch;
    flex: 0 1 auto;
  }

  .hh-tag {
    font-family: var(--font-display);
    font-size: max(0.85rem, 1.05vw);
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--brass);
    margin-bottom: 1.1rem;
  }

  /* Two-line headline: "Engineered," / "Then Tuned." — each line its own
     block so it stacks regardless of container width. */
  .hh-h1 {
    font-family: var(--font-display);
    font-size: clamp(2.6rem, 5.6vw, 5.4rem);
    line-height: 1.05;
    letter-spacing: 0.02em;
    color: var(--fg);
    margin: 0 0 1.15rem;
  }
  .hh-h1-line { display: block; white-space: nowrap; }

  .hh-redline {
    display: block;
    width: min(300px, 60%);
    height: 3px;
    border-radius: 2px;
    background: linear-gradient(90deg, var(--brass-bright), var(--redline));
    transform-origin: center;
    margin: 0 auto 1.25rem;
  }

  .hh-lede {
    font-family: var(--font-body);
    font-size: 1.08rem;
    line-height: 1.6;
    color: var(--fg-dim);
    max-width: 52ch;
    margin: 0 auto;
  }

  /* ── The gauge: face capture masked round; needle + hub overlay per the
     plugin's geometry (see N/H above). All children positioned in % so each
     size below scales as one. Desktop dial = original full size
     (clamp(280px,30vw,400px)); mobile dial = 1/2 of it, under the headline. ── */
  .hero-dial {
    position: relative;
    aspect-ratio: 1;
    border-radius: 50%;
    box-shadow: 0 30px 80px rgba(0, 0, 0, 0.65), 0 6px 18px rgba(0, 0, 0, 0.4);
    flex: 0 0 auto;
  }

  .hero-dial-desktop { width: clamp(280px, 30vw, 400px); }

  .hero-dial-mobile { display: none; width: min(160px, 40vw); margin: 0.5rem 0 0; }

  .hero-dial :global(img.g-face) {
    width: 100%;
    height: 100%;
    display: block;
    border-radius: 50%; /* masks the panel-leather corners of the capture */
  }

  .g-needle {
    position: absolute;
    filter: drop-shadow(0 4px 6px rgba(0, 0, 0, 0.5));
  }
  .g-needle :global(img) { width: 100%; height: auto; display: block; }

  .hero-dial :global(img.g-hub) {
    position: absolute;
    height: auto;
  }

  /* Direct-to-product line under the lede — additive, all widths. */
  .hh-fastbuy {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    text-align: center;
    margin: 0.9rem 0 0;
  }
  .hh-fastbuy a {
    color: var(--brass);
    text-decoration: underline;
    text-decoration-style: dashed;
    text-decoration-color: var(--brass-dark);
    text-underline-offset: 3px;
  }
  .hh-fastbuy a:hover { color: var(--brass-bright); }
  .hh-fastbuy strong { color: var(--brass-bright); font-weight: 400; }
  .hh-fastbuy s { color: var(--fg-faint); }

  /* ── Hanging STORE sign — left edge, bottom-anchored so the plank rests
     just above the plugin showcase. All px derive from the source render at
     scale 0.1816 (plank = 264 css px): mount 436×243, beam 436×45 at 0,0,
     hanger 280×212 at 109,31; pivot x = (1379−600)·s ≈ 50.5% of the hanger,
     y = (210−240)·s ≈ −5px (the beam's centerline, above the crop's top). ── */
  /* scale(0.82) keeps the rig clear of the headline on short viewports while
     preserving the interlocked slice geometry (origin = bottom-left anchor).
     bottom was dropped 200px from the original 0.75rem (12px, → -188px),
     then lifted back 80px per Gil's request (→ -108px net). */
  .sign-mount {
    position: absolute;
    left: 0;
    bottom: -108px;
    width: 436px;
    height: 243px;
    z-index: 4;
    transform: scale(0.82);
    transform-origin: 0 100%;
  }

  /* Static beam on top (z 2) — covers the hanger's masked rope-overlap band. */
  .sign-mount :global(img.sign-beam) {
    position: absolute;
    left: 0;
    top: 0;
    width: 436px;
    height: auto;
    z-index: 2;
    pointer-events: none;
    filter: drop-shadow(0 10px 22px rgba(0, 0, 0, 0.55));
  }

  /* Hanging unit: pivots where the ropes meet the beam. */
  .hanger {
    position: absolute;
    left: 109px;
    top: 31px;
    width: 280px;
    display: block;
    z-index: 1;
    transform-origin: 50.5% -5px;
    animation: sway 5.6s ease-in-out infinite;
    cursor: pointer;
    -webkit-tap-highlight-color: transparent;
  }
  .hanger :global(img) {
    width: 100%;
    height: auto;
    display: block;
    filter: drop-shadow(0 18px 36px rgba(0, 0, 0, 0.6));
    transition: filter 0.25s var(--ease, ease);
  }
  .hanger:hover :global(img) {
    filter: drop-shadow(0 18px 36px rgba(0, 0, 0, 0.6)) drop-shadow(0 0 14px rgba(232, 200, 120, 0.35));
  }
  .hanger.static { animation: none; }
  .hanger.kick {
    animation:
      kick 1.7s cubic-bezier(0.3, 0.85, 0.3, 1.08) 1,
      sway 5.6s ease-in-out 1.7s infinite;
  }
  /* Kick peaks at 6°: the rope tops travel ≤ ~10 css px at the seam, safely
     inside the ~14 px overlap band hidden behind the beam. */
  @keyframes sway {
    0%, 100% { transform: rotate(-1.4deg); }
    50% { transform: rotate(1.4deg); }
  }
  @keyframes kick {
    0% { transform: rotate(-1.4deg); }
    20% { transform: rotate(6deg); }
    52% { transform: rotate(-3.5deg); }
    78% { transform: rotate(1.8deg); }
    100% { transform: rotate(-1.4deg); }
  }
  .hanger:focus-visible { outline: 3px solid var(--brass-bright); outline-offset: 6px; }

  /* Below ~1100px the text column reaches into the sign's corner — reserve
     the rig's height under the content so nothing hides behind it. */
  @media (max-width: 1100px) {
    .hero-grid { padding-bottom: 225px; }
  }

  @media (max-width: 860px) {
    /* Collapse the row back to a stack (padding-bottom: 0 also undoes the
       >1100px sign reserve, which doesn't apply here). Text is already
       centered at every width, so only the column direction/width changes. */
    .hero-grid { flex-direction: column; gap: 2rem; padding-bottom: 0; }
    .hero-head { max-width: 62ch; }
    .hh-h1-line { white-space: normal; }

    /* Tag + headline sized up 50%, gauge sized up 25%, mobile only. */
    .hh-tag { font-size: 1.275rem; } /* 0.85rem × 1.5 */
    .hh-h1 { font-size: 3.9rem; } /* 2.6rem × 1.5 */
    .hero-dial-mobile { width: min(200px, 50vw); } /* 160px / 40vw × 1.25 */

    /* The absolute corner overlay has no positioned ancestor to anchor to
       on mobile (it's the in-flow .sign-mount-mobile-wrap below instead). */
    .sign-mount:not(.sign-mount-mobile) { display: none; }
    /* Mobile keeps only its own small under-headline dial. */
    .hero-dial-desktop { display: none; }
    .hero-dial-mobile { display: block; }
  }

  /* Mobile-only duplicate of the sign, in-flow instead of the absolute
     corner overlay — this small wrapper reserves exactly the scaled
     footprint (436×243 at scale 0.6 = 261.6×145.8) so normal page flow
     places it right above "Our Plugins". Hidden above the breakpoint. */
  .sign-mount-mobile-wrap { display: none; }

  @media (max-width: 860px) {
    .sign-mount-mobile-wrap {
      display: block;
      position: relative;
      width: 261.6px;
      height: 145.8px;
      margin: 0.5rem auto 1.5rem;
    }
    .sign-mount.sign-mount-mobile {
      left: 0;
      top: 0;
      bottom: auto;
      transform: scale(0.6);
      transform-origin: 0 0;
    }
  }

</style>
