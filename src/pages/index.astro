---
import BaseLayout from '../layouts/BaseLayout.astro';
import PluginCard from '../components/PluginCard.astro';
import TestimonialBlock from '../components/TestimonialBlock.astro';
import DAWStrip from '../components/DAWStrip.astro';
import PressLogos from '../components/PressLogos.astro';
import SaleBanner from '../components/SaleBanner.astro';
import { plugins, fmtPrice, discountPct, isBuyable } from '../data/plugins';

const flagship = plugins[0];
const flagshipPct = discountPct(flagship);
const flagshipLive = isBuyable(flagship);
const bannerMsg = flagshipLive
  ? `${flagship.name} is available now — ${fmtPrice(flagship.introPriceUsd)}.`
  : flagshipPct
    ? `Pre-launch — join the waitlist for ${flagshipPct}% off ${flagship.name}, the first plugin to ship.`
    : `Pre-launch — join the waitlist for intro pricing on ${flagship.name}, the first plugin to ship.`;
---

<BaseLayout title="RevAudio">
  <SaleBanner
    message={bannerMsg}
    ctaLabel={flagshipLive ? 'Get it' : 'Join waitlist'}
    ctaHref={flagshipLive ? `/${flagship.slug}` : '/#waitlist'}
  />

  <section class="hero hero-feat">
    <div class="hero-stage">
      <div class="hs-tag reveal" style="--d: .05s">Boutique VST plugins</div>
      <h1 class="hs-h1 reveal" style="--d: .12s">Engineered,<br/>then tuned.</h1>
      <span class="hs-redline" aria-hidden="true"></span>
      <p class="hs-lede reveal" style="--d: .22s">Measured to spec, then voiced by ear.<br/>The precision of a machine, the feel of an instrument.</p>
    </div>
  </section>

  <section class="plugin-grid">
    <div class="container">
      <div class="grid-head">
        <div>
          <h2>The plugin</h2>
          <p class="muted">One tool, built like a car. The first of the line.</p>
        </div>
        <a href="/store" class="head-link">Visit the store &rarr;</a>
      </div>
      <div class="plugin-cards single">
        <PluginCard plugin={flagship} />
      </div>
    </div>
  </section>

  <DAWStrip />
  <TestimonialBlock heading="Producers on RevAudio" />
  <PressLogos />
</BaseLayout>

<style>
  /* ── Hero — laid out visually in /herolab as a 1200×600 "stage". Positions
     baked as container-query units (cqw) so the whole composition scales as one
     unit from the 1200px design width down, then reflows to a centered stack on
     phones. Edit by re-running /herolab, not by hand. ── */
  .hero-feat { padding: var(--space-6) 0; }

  .hero-stage {
    position: relative;
    width: 100%;
    max-width: var(--maxw);          /* 1200px — the design width */
    margin: 0 auto;
    aspect-ratio: 1200 / 600;        /* reserves the stage height proportionally */
    container-type: inline-size;     /* cqw children scale to stage width */
    overflow: hidden;
  }

  .hero-stage > * {
    position: absolute;
    margin: 0;
    max-width: none;
  }

  .hs-tag {
    left: 34.583cqw; top: 5.75cqw; width: 37.083cqw;
    font-family: var(--font-display);
    font-size: max(0.85rem, 1.667cqw);
    line-height: 1; letter-spacing: 0.3em;
    text-align: center; text-transform: uppercase;
    color: var(--brass);
  }

  .hs-h1 {
    left: 1.75cqw; top: 9.25cqw; width: 103.667cqw;
    font-family: var(--font-display);
    font-size: max(2.75rem, 8.133cqw);
    line-height: 1; letter-spacing: 0.02em;
    text-align: center; color: var(--fg);
  }

  .hs-redline {
    left: 42.25cqw; top: 26.583cqw; width: 21.667cqw;
    height: max(2px, 0.25cqw);
    background: linear-gradient(90deg, var(--brass-bright), var(--redline));
    border-radius: 2px;
    transform-origin: center;
  }

  .hs-lede {
    left: 31.417cqw; top: 28.75cqw; width: 43.333cqw;
    font-family: var(--font-display);
    font-size: max(0.95rem, 1.667cqw);
    line-height: 1.6; letter-spacing: 0;
    text-align: center; color: var(--fg-dim);
  }

  /* Signature "rev-in": staggered rise + redline sweep. Pure CSS, motion-safe. */
  @media (prefers-reduced-motion: no-preference) {
    .hero-stage .reveal {
      opacity: 0;
      transform: translateY(14px);
      animation: heroRise 0.6s var(--ease) both;
      animation-delay: var(--d, 0s);
    }
    .hs-redline {
      transform: scaleX(0);
      animation: heroSweep 0.7s var(--ease) 0.45s both;
    }
  }

  @keyframes heroRise { to { opacity: 1; transform: none; } }
  @keyframes heroSweep { to { transform: scaleX(1); } }

  /* Phones: drop the absolute stage, stack centered with readable sizes. */
  @media (max-width: 720px) {
    .hero-stage {
      aspect-ratio: auto;
      overflow: visible;
      container-type: normal;
      padding: 3rem 1.5rem 2rem;
      text-align: center;
    }
    .hero-stage > * { position: static; width: auto; }
    .hs-tag { font-size: 0.85rem; margin-bottom: 1.25rem; }
    .hs-h1 { font-size: clamp(2.75rem, 14vw, 4rem); margin-bottom: 0.75rem; }
    .hs-redline {
      display: block;
      width: min(220px, 55%);
      height: 3px;
      margin: 0.5rem auto 1.25rem;
    }
    .hs-lede { font-size: 1.05rem; max-width: 34ch; margin: 0 auto; }
  }

  .grid-head {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 2rem;
    margin-bottom: 2.5rem;
    flex-wrap: wrap;
  }

  .grid-head h2 { margin: 0; }
  .grid-head .muted { margin: 0.25rem 0 0; }

  .head-link {
    font-family: var(--font-display);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--brass-bright);
    border-bottom: 1px solid var(--brass-dark);
    padding-bottom: 0.2rem;
  }

  .head-link:hover { color: var(--chrome); border-color: var(--chrome); }

  /* single-product: center the lone card instead of the 2-up grid */
  .plugin-cards.single {
    grid-template-columns: 1fr;
    max-width: 460px;
    margin-inline: auto;
  }
</style>
