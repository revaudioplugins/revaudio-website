---
import BaseLayout from '../layouts/BaseLayout.astro';
import PluginCard from '../components/PluginCard.astro';
import EmailCapture from '../components/EmailCapture.astro';
---

<BaseLayout title="RevAudio">
  <section class="hero">
    <div class="container">
      <div class="tag">Boutique VST plugins</div>
      <h1>Plugins built like cars.</h1>
      <p class="lede">High quality. Simple controls. Built to feel.</p>
    </div>
  </section>

  <section class="values">
    <div class="v">
      <h3>Quality</h3>
      <p>Every DSP stage measured, null-tested, and audited. No corner cases left in the bin.</p>
    </div>
    <div class="v">
      <h3>Simplicity</h3>
      <p>One look at the panel and you know what it does. Fewer knobs, more decisions.</p>
    </div>
    <div class="v">
      <h3>Creativity</h3>
      <p>Tools that move people emotionally. Mechanical metaphors, musical results.</p>
    </div>
  </section>

  <section class="plugin-grid">
    <div class="container">
      <h2 class="center">The lineup</h2>
      <div class="plugin-cards">
        <PluginCard
          name="RevLimiter"
          href="/revlimiter"
          status="beta"
          statusLabel="Beta — Q3 2026"
          oneLiner="Mastering limiter built around a car rev gauge. Multi-band, oversampled, true-peak ceiling. The redline is your threshold."
        />
        <PluginCard
          name="The AC"
          href="/the-ac"
          status="dev"
          statusLabel="In development"
          oneLiner="Air-band exciter and tube saturator with a car AC dashboard. Cold air to warm shine — turn the dial and breathe into the mix."
        />
        <PluginCard
          name="The Cooker"
          href="/the-cooker"
          status="dev"
          statusLabel="In development"
          oneLiner="Multi-band panner with autopilot. Pan, saturate, reverb, and tremolo per band — set it and let the stereo image cook itself."
        />
        <PluginCard
          name="Maybach"
          href="/maybach"
          status="dev"
          statusLabel="Coming"
          oneLiner="Dynamic EQ with a Maybach suspension that bounces in time with your spectral moves. Auto-mode tames peaks before you hear them."
        />
      </div>
    </div>
  </section>

  <EmailCapture
    heading="First in line"
    subhead="Beta builds, demo codes, and launch pricing land here first. One email per release. No spam, ever."
  />
</BaseLayout>
