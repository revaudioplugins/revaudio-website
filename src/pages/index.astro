---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import PluginShowcase from '../components/PluginShowcase.astro';
import TestimonialBlock from '../components/TestimonialBlock.astro';
import DAWStrip from '../components/DAWStrip.astro';
import PressLogos from '../components/PressLogos.astro';
import EmailCapture from '../components/EmailCapture.astro';
import SubscribeModal from '../components/SubscribeModal.astro';
import { bySlug, isBuyable, fmtPrice } from '../data/plugins';
import signBeam from '../assets/hero/sign-beam.png';
import signHanger from '../assets/hero/sign-hanger.png';

const rl = bySlug('revlimiter');
---

<BaseLayout title="RevAudio">
  {/* Hero — text stack + a hanging wooden STORE sign off the left edge,
      bottom-anchored so it sits just above the plugin showcase. Designed in
      /signlab (local bench); edit there first, then port. Entrance: text
      cascade + redline sweep. Sign: idle sway, click = kick swing, whole sign
      links to /store. Reduced motion: everything static. */}
  <section class="hero hero-feat" data-hero>
    {/* True-alpha Higgsfield asset (nano_banana_pro 2k → bg removed), sliced
        into a static beam + a swinging hanger. Slice geometry derives from the
        source 2752×1536 render (beam rows 70–318, hanger crop 600,240–2140,1410,
        rope pivot x≈1379, beam center y≈210) at scale 264/1454 ≈ 0.1816. The
        hanger's top 78px band is alpha-masked to the rope columns and hides
        behind the beam, so the seam stays covered while swinging. */}
    <div class="sign-mount" data-hero-in>
      <Image class="sign-beam" src={signBeam} alt="" width={872} format="webp" loading="eager" />
      <a class="hanger" data-sign href="/store" aria-label="Visit the store">
        <Image src={signHanger} alt="" width={560} format="webp" loading="eager" />
      </a>
    </div>
    <div class="hero-grid">
      <div class="hero-head">
        <div class="hh-tag" data-hero-in>Boutique VST plugins</div>
        <h1 class="hh-h1" data-split>Engineered, then tuned.</h1>
        <span class="hh-redline" data-hero-sweep aria-hidden="true"></span>
        <p class="hh-lede" data-hero-in>
          Measured to spec, then voiced by ear.<br />The precision of a machine, the feel of an instrument.
        </p>
      </div>

      <div class="hero-show">
        <div class="hero-buy" data-hero-in>
          {rl && isBuyable(rl) && (
            <p class="hh-fastbuy">
              <a href="/revlimiter">RevLimiter — <strong>{fmtPrice(rl.introPriceUsd)}</strong>
                <s>{fmtPrice(rl.regularPriceUsd)}</s> · Buy now &rarr;</a>
            </p>
          )}
        </div>
      </div>
    </div>
  </section>

  <PluginShowcase />

  <DAWStrip />
  <TestimonialBlock heading="Producers on RevAudio" />
  <PressLogos />
  <EmailCapture id="subscribe" />
  <SubscribeModal />
</BaseLayout>

<script>
  import { gsap, reducedMotion } from '../lib/motion';

  if (document.querySelector('[data-hero]') && !reducedMotion()) {
    // ── Entrance: text cascade + redline sweep ──
    const tl = gsap.timeline({ defaults: { ease: 'expo.out' } });
    tl.fromTo('[data-hero-in]', { y: 24, opacity: 0 }, { y: 0, opacity: 1, duration: 0.6, stagger: 0.12 }, 0.05)
      .fromTo('[data-hero-sweep]', { scaleX: 0 }, { scaleX: 1, duration: 0.7, ease: 'power3.out' }, 0.75);
  }

  // ── Hanging STORE sign: click = kick swing, then back to idle sway ──
  const sign = document.querySelector<HTMLElement>('[data-sign]');
  if (sign) {
    if (reducedMotion()) {
      sign.classList.add('static');
    } else {
      sign.addEventListener('click', () => {
        sign.classList.remove('kick');
        void sign.offsetWidth; // restart animation
        sign.classList.add('kick');
      });
      sign.addEventListener('animationend', (e) => {
        if (e.animationName.startsWith('kick')) sign.classList.remove('kick');
      });
    }
  }
</script>

<style>
  /* ── Hero — text stack + hanging STORE sign (designed in /signlab). ── */
  /* border-bottom: none overrides the global .hero divider — the hero should
     flow straight into the plugin showcase. */
  .hero-feat { position: relative; padding: var(--space-6) 0 var(--space-8); overflow-x: clip; border-bottom: none; }

  /* Centered composition (FabFilter-style): a centered headline block on top,
     then the gauge + buy plate sitting together as a centered pair below — so
     nothing is pushed to the extreme edges (no left-jammed / right-floating
     "barbell"). Everything shares one center axis, so it all lines up. */
  .hero-grid {
    max-width: var(--maxw);
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: clamp(1.75rem, 4vh, 3rem);
    padding: clamp(1.5rem, 4vh, 3rem) clamp(1.5rem, 4vw, 4rem) 0;
  }

  .hero-head {
    display: flex;
    flex-direction: column;
    align-items: center;
    max-width: 62ch;
  }

  .hh-tag {
    font-family: var(--font-display);
    font-size: max(0.85rem, 1.05vw);
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--brass);
    margin-bottom: 1.1rem;
  }

  /* One line at every desktop width — "Engineered, then tuned." holds a single
     line; white-space:nowrap guarantees it never wraps until the mobile block
     releases it. */
  .hh-h1 {
    font-family: var(--font-display);
    font-size: clamp(2.6rem, 5.6vw, 5.4rem);
    line-height: 1.0;
    letter-spacing: 0.02em;
    color: var(--fg);
    margin: 0 0 1.15rem;
    white-space: nowrap;
  }

  .hh-redline {
    display: block;
    width: min(300px, 60%);
    height: 3px;
    border-radius: 2px;
    background: linear-gradient(90deg, var(--brass-bright), var(--redline));
    transform-origin: center;
    margin: 0 auto 1.25rem;
  }

  .hh-lede {
    font-family: var(--font-body);
    font-size: 1.08rem;
    line-height: 1.6;
    color: var(--fg-dim);
    max-width: 52ch;
    margin: 0 auto;
  }

  /* Buy plate + fast-buy line, centered under the headline. */
  .hero-show {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: clamp(2rem, 5vw, 4.5rem);
    flex-wrap: wrap;
  }

  .hero-buy {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  /* One quiet direct-to-product line — additive, all widths. */
  .hh-fastbuy {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    text-align: center;
    margin: 0.9rem 0 0;
  }
  .hh-fastbuy a {
    color: var(--brass);
    text-decoration: underline;
    text-decoration-style: dashed;
    text-decoration-color: var(--brass-dark);
    text-underline-offset: 3px;
  }
  .hh-fastbuy a:hover { color: var(--brass-bright); }
  .hh-fastbuy strong { color: var(--brass-bright); font-weight: 400; }
  .hh-fastbuy s { color: var(--fg-faint); }

  /* ── Hanging STORE sign — left edge, bottom-anchored so the plank rests
     just above the plugin showcase. All px derive from the source render at
     scale 0.1816 (plank = 264 css px): mount 436×243, beam 436×45 at 0,0,
     hanger 280×212 at 109,31; pivot x = (1379−600)·s ≈ 50.5% of the hanger,
     y = (210−240)·s ≈ −5px (the beam's centerline, above the crop's top). ── */
  /* scale(0.82) keeps the rig clear of the headline on short viewports while
     preserving the interlocked slice geometry (origin = bottom-left anchor). */
  .sign-mount {
    position: absolute;
    left: 0;
    bottom: 0.75rem;
    width: 436px;
    height: 243px;
    z-index: 4;
    transform: scale(0.82);
    transform-origin: 0 100%;
  }

  /* Static beam on top (z 2) — covers the hanger's masked rope-overlap band. */
  .sign-mount :global(img.sign-beam) {
    position: absolute;
    left: 0;
    top: 0;
    width: 436px;
    height: auto;
    z-index: 2;
    pointer-events: none;
    filter: drop-shadow(0 10px 22px rgba(0, 0, 0, 0.55));
  }

  /* Hanging unit: pivots where the ropes meet the beam. */
  .hanger {
    position: absolute;
    left: 109px;
    top: 31px;
    width: 280px;
    display: block;
    z-index: 1;
    transform-origin: 50.5% -5px;
    animation: sway 5.6s ease-in-out infinite;
    cursor: pointer;
    -webkit-tap-highlight-color: transparent;
  }
  .hanger :global(img) {
    width: 100%;
    height: auto;
    display: block;
    filter: drop-shadow(0 18px 36px rgba(0, 0, 0, 0.6));
    transition: filter 0.25s var(--ease, ease);
  }
  .hanger:hover :global(img) {
    filter: drop-shadow(0 18px 36px rgba(0, 0, 0, 0.6)) drop-shadow(0 0 14px rgba(232, 200, 120, 0.35));
  }
  .hanger.static { animation: none; }
  .hanger.kick {
    animation:
      kick 1.7s cubic-bezier(0.3, 0.85, 0.3, 1.08) 1,
      sway 5.6s ease-in-out 1.7s infinite;
  }
  /* Kick peaks at 6°: the rope tops travel ≤ ~10 css px at the seam, safely
     inside the ~14 px overlap band hidden behind the beam. */
  @keyframes sway {
    0%, 100% { transform: rotate(-1.4deg); }
    50% { transform: rotate(1.4deg); }
  }
  @keyframes kick {
    0% { transform: rotate(-1.4deg); }
    20% { transform: rotate(6deg); }
    52% { transform: rotate(-3.5deg); }
    78% { transform: rotate(1.8deg); }
    100% { transform: rotate(-1.4deg); }
  }
  .hanger:focus-visible { outline: 3px solid var(--brass-bright); outline-offset: 6px; }

  /* Below ~1100px the centered text column reaches into the sign's corner —
     reserve the rig's height under the content so nothing hides behind it. */
  @media (max-width: 1100px) {
    .hero-grid { padding-bottom: 225px; }
  }

  @media (max-width: 860px) {
    /* Release the one-line lock so the headline can wrap on narrow screens. */
    .hh-h1 { white-space: normal; font-size: clamp(2.4rem, 9vw, 3.4rem); }
    .hero-grid { gap: 2rem; padding-bottom: 195px; }
    .hero-show { gap: 2rem; }
    .sign-mount { transform: scale(0.72); transform-origin: 0 100%; }
  }

</style>
