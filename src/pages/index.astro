---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import PluginCard from '../components/PluginCard.astro';
import TestimonialBlock from '../components/TestimonialBlock.astro';
import DAWStrip from '../components/DAWStrip.astro';
import PressLogos from '../components/PressLogos.astro';
import SaleBanner from '../components/SaleBanner.astro';
import { plugins, fmtPrice, discountPct, isBuyable } from '../data/plugins';
import heroImg from '../assets/plugins/revlimiter-hero.png';
import buyImg from '../assets/ui/btn-buy.png';
import buyPressed from '../assets/ui/btn-buy-pressed.png';

const flagship = plugins[0];
const flagshipPct = discountPct(flagship);
const flagshipLive = isBuyable(flagship);
const bannerMsg = flagshipLive
  ? `${flagship.name} is available now — ${fmtPrice(flagship.introPriceUsd)}.`
  : flagshipPct
    ? `Pre-launch — join the waitlist for ${flagshipPct}% off ${flagship.name}, the first plugin to ship.`
    : `Pre-launch — join the waitlist for intro pricing on ${flagship.name}, the first plugin to ship.`;
---

<BaseLayout title="RevAudio">
  <SaleBanner
    message={bannerMsg}
    ctaLabel={flagshipLive ? 'Get it' : 'Join waitlist'}
    ctaHref={flagshipLive ? `/${flagship.slug}` : '/#waitlist'}
  />

  <section class="hero hero-feat">
    <div class="container hero-grid">
      <div class="hero-copy">
        <div class="tag reveal" style="--d: .05s">Boutique VST plugins</div>
        <h1 class="reveal" style="--d: .12s">Plugins built<br/>like cars.</h1>
        <span class="redline" aria-hidden="true"></span>
        <p class="lede reveal" style="--d: .22s">High quality. Simple controls. Built to feel.<br/>Mechanical metaphors, musical results.</p>
        <div class="hero-cta reveal" style="--d: .32s">
          {flagshipLive ? (
            <div class="buy-btn panel">
              <Image src={buyImg} alt="" width={520} height={347} format="webp" />
              <a href={`/${flagship.slug}`} class="panel-hit hit-round hit-buy" aria-label={`Buy ${flagship.name}`}></a>
              <Image src={buyPressed} alt="" width={520} height={347} format="webp" loading="eager" class="press" />
            </div>
          ) : (
            <a href={`/${flagship.slug}`} class="cta-primary">Reserve {flagship.name}</a>
          )}
          <a href="/store" class="store-link">Visit the store &rarr;</a>
        </div>
        <p class="hero-meta muted reveal" style="--d: .4s">
          {flagshipLive
            ? `${flagship.name} · available now · ${fmtPrice(flagship.introPriceUsd)}`
            : `${flagship.name} ships ${flagship.releaseTarget} · intro price ${fmtPrice(flagship.introPriceUsd)}${flagshipPct ? ` (${flagshipPct}% off)` : ''}`}
        </p>
      </div>
      <div class="hero-visual">
        <Image
          src={heroImg}
          alt="RevLimiter mastering limiter — plugin interface"
          class="plugin-shot"
          widths={[620, 960, 1240]}
          sizes="(max-width: 900px) 90vw, 620px"
          format="webp"
          loading="eager"
          fetchpriority="high"
        />
      </div>
    </div>
  </section>

  <section class="values">
    <div class="v">
      <h3>Quality</h3>
      <p>Every DSP stage measured, null-tested, and audited. Every release goes through a custom test bench before it ships.</p>
    </div>
    <div class="v">
      <h3>Simplicity</h3>
      <p>One look at the panel and you know what it does. Fewer knobs, more decisions.</p>
    </div>
    <div class="v">
      <h3>Creativity</h3>
      <p>Tools that move people emotionally. Mechanical metaphors that translate into musical outcomes.</p>
    </div>
  </section>

  <section class="plugin-grid">
    <div class="container">
      <div class="grid-head">
        <div>
          <h2>The plugin</h2>
          <p class="muted">One tool, built like a car. The first of the line.</p>
        </div>
        <a href="/store" class="head-link">Visit the store &rarr;</a>
      </div>
      <div class="plugin-cards single">
        <PluginCard plugin={flagship} />
      </div>
    </div>
  </section>

  <DAWStrip />
  <TestimonialBlock heading="Producers on RevAudio" />
  <PressLogos />
</BaseLayout>

<style>
  .hero-feat { padding: var(--space-10, 5rem) 0 var(--space-8, 4rem); }

  /* Signature moment: the hero "revs in". Concept-tied (tachometer redline
     sweep + staggered copy). Pure CSS, no layout shift, motion-safe. */
  .hero-copy .redline {
    display: block;
    height: 3px;
    width: min(260px, 60%);
    margin: 0.5rem 0 0.75rem;
    border-radius: 2px;
    background: linear-gradient(90deg, var(--brass-bright), var(--redline));
    transform-origin: left center;
  }

  @media (prefers-reduced-motion: no-preference) {
    .hero-copy .reveal {
      opacity: 0;
      transform: translateY(14px);
      animation: heroRise 0.6s var(--ease) both;
      animation-delay: var(--d, 0s);
    }
    .hero-copy .redline {
      transform: scaleX(0);
      animation: heroSweep 0.7s var(--ease) 0.45s both;
    }
    .hero-visual .plugin-shot {
      animation: heroSettle 0.9s var(--ease) both;
    }
  }

  @keyframes heroRise { to { opacity: 1; transform: none; } }
  @keyframes heroSweep { to { transform: scaleX(1); } }
  @keyframes heroSettle {
    from { opacity: 0.6; transform: scale(1.04); }
    to { opacity: 1; transform: none; }
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: 4rem;
    align-items: center;
  }

  @media (max-width: 900px) {
    .hero-grid { grid-template-columns: 1fr; gap: 2rem; }
    .hero-visual { order: -1; }
  }

  .hero-copy h1 {
    text-align: left;
    margin: 0 0 1rem;
    line-height: 1;
  }

  .hero-copy .lede {
    text-align: left;
    max-width: 36ch;
    margin: 0 0 2rem;
  }

  .hero-copy .tag {
    text-align: left;
    margin-bottom: 1.5rem;
  }

  .hero-cta {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    align-items: center;
  }

  .buy-btn { width: 176px; }

  .store-link {
    font-family: var(--font-display);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-size: 1.05rem;
    color: var(--brass-bright);
    border-bottom: 1px solid var(--brass-dark);
    padding-bottom: 0.2rem;
    transition: color 0.2s var(--ease), border-color 0.2s var(--ease);
  }
  .store-link:hover { color: var(--chrome); border-bottom-color: var(--chrome); }

  .cta-primary,
  .cta-ghost {
    display: inline-block;
    padding: 0.875rem 1.75rem;
    font-family: var(--font-display);
    font-size: 1.05rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    border: 1px solid transparent;
    transition: background 0.2s, border-color 0.2s, color 0.2s;
  }

  .cta-primary { background: var(--brass); color: var(--bg-0); }
  .cta-primary:hover { background: var(--brass-bright); }

  .cta-ghost {
    background: transparent;
    color: var(--fg);
    border-color: var(--border-bright);
  }
  .cta-ghost:hover { border-color: var(--brass); color: var(--brass-bright); }

  .hero-meta {
    margin-top: 1.5rem;
    font-size: 0.85rem;
  }

  .hero-visual {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .plugin-shot {
    width: 100%;
    max-width: 620px;
    height: auto;
    border-radius: 10px;
    border: 1px solid var(--border-bright);
    box-shadow: 0 24px 60px rgba(0, 0, 0, 0.7);
  }

  .grid-head {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 2rem;
    margin-bottom: 2.5rem;
    flex-wrap: wrap;
  }

  .grid-head h2 { margin: 0; }
  .grid-head .muted { margin: 0.25rem 0 0; }

  .head-link {
    font-family: var(--font-display);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--brass-bright);
    border-bottom: 1px solid var(--brass-dark);
    padding-bottom: 0.2rem;
  }

  .head-link:hover { color: var(--chrome); border-color: var(--chrome); }

  /* single-product: center the lone card instead of the 2-up grid */
  .plugin-cards.single {
    grid-template-columns: 1fr;
    max-width: 460px;
    margin-inline: auto;
  }
</style>
