---
import BaseLayout from '../layouts/BaseLayout.astro';
import PluginCard from '../components/PluginCard.astro';
import EmailCapture from '../components/EmailCapture.astro';
import { plugins } from '../data/plugins';

const cardStatus = (s: string): 'live' | 'beta' | 'dev' =>
  s === 'live' ? 'live' : s === 'beta' ? 'beta' : 'dev';
---

<BaseLayout title="RevAudio">
  <section class="hero">
    <div class="container">
      <div class="tag">Boutique VST plugins</div>
      <h1>Plugins built like cars.</h1>
      <p class="lede">High quality. Simple controls. Built to feel.</p>
      <div class="hero-cta">
        <a href="/store" class="cta-primary">Browse the store</a>
        <a href="/about" class="cta-ghost">Why RevAudio</a>
      </div>
    </div>
  </section>

  <section class="values">
    <div class="v">
      <h3>Quality</h3>
      <p>Every DSP stage measured, null-tested, and audited. No corner cases left in the bin.</p>
    </div>
    <div class="v">
      <h3>Simplicity</h3>
      <p>One look at the panel and you know what it does. Fewer knobs, more decisions.</p>
    </div>
    <div class="v">
      <h3>Creativity</h3>
      <p>Tools that move people emotionally. Mechanical metaphors, musical results.</p>
    </div>
  </section>

  <section class="plugin-grid">
    <div class="container">
      <h2 class="center">The lineup</h2>
      <div class="plugin-cards">
        {plugins.map((p) => (
          <PluginCard
            name={p.name}
            href={`/${p.slug}`}
            status={cardStatus(p.status)}
            statusLabel={p.statusLabel}
            oneLiner={p.oneLiner}
          />
        ))}
      </div>
    </div>
  </section>

  <EmailCapture
    heading="First in line"
    subhead="Beta builds, demo codes, and launch pricing land here first. One email per release. No spam, ever."
  />
</BaseLayout>

<style>
  .hero-cta {
    display: flex;
    gap: 0.75rem;
    justify-content: center;
    flex-wrap: wrap;
    margin-top: 0.5rem;
  }

  .cta-primary,
  .cta-ghost {
    display: inline-block;
    padding: 0.875rem 1.75rem;
    font-family: var(--font-display);
    font-size: 1.05rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    border: 1px solid transparent;
    transition: background 0.2s, border-color 0.2s, color 0.2s;
  }

  .cta-primary {
    background: var(--brass);
    color: var(--bg-0);
  }
  .cta-primary:hover { background: var(--brass-bright); color: var(--bg-0); }

  .cta-ghost {
    background: transparent;
    color: var(--fg);
    border-color: var(--border-bright);
  }
  .cta-ghost:hover {
    border-color: var(--brass);
    color: var(--brass-bright);
  }
</style>
