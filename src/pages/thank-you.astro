---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="You're in"
  description="Your RevLimiter purchase is complete. Your download link and licence key are on the way to your email."
  index={false}
>
  <section class="plugin-detail thankyou">
    <div class="container" style="max-width: 620px;" data-reveal>
      <p class="tag">Purchase complete</p>
      <h1>You&rsquo;re in.</h1>
      <p class="pitch">
        Your <strong>download link</strong> and <strong>licence key</strong> are on their way
        to <strong>the inbox of the email you paid with</strong>. Open it to grab them:
      </p>

      <div class="quick-row">
        <a class="btn primary" href="https://mail.google.com/mail/u/0/#inbox" target="_blank" rel="noopener">Gmail</a>
        <a class="btn ghost" href="https://outlook.live.com/mail/0/inbox" target="_blank" rel="noopener">Outlook</a>
        <a class="btn ghost" href="https://mail.yahoo.com/" target="_blank" rel="noopener">Yahoo</a>
      </div>

      <p class="micro muted">
        Nothing yet? Check spam / promotions. Install help on the
        <a href="/support">support page</a>; problems &rarr;
        <a href="mailto:support@revaudio.net">support@revaudio.net</a>.
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  .thankyou .tag {
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.18em;
    font-size: 0.72rem;
    color: var(--brass);
    margin: 0 0 0.5rem;
  }

  .quick-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    margin-bottom: 1.5rem;
  }
  .quick-row .btn {
    padding: 0.55rem 1.1rem;
    font-size: 0.85rem;
  }
</style>
