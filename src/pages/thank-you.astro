---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="You're in"
  description="Your RevLimiter purchase is complete. Your download link and licence key are on the way to your email."
  index={false}
>
  <section class="plugin-detail thankyou">
    <div class="container" style="max-width: 620px;" data-reveal>
      <p class="tag">Purchase complete</p>
      <h1>You&rsquo;re in.</h1>
      <p class="pitch">
        Your <strong>download link</strong> and <strong>licence key</strong> are on their way
        to <strong>the inbox of the email you paid with</strong>. Open it to grab them:
      </p>

      <div class="quick-row">
        <a class="mail-btn gmail" href="https://mail.google.com/mail/u/0/#inbox" target="_blank" rel="noopener">
          <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M24 5.457v13.909c0 .904-.732 1.636-1.636 1.636h-3.819V11.73L12 16.64l-6.545-4.91v9.273H1.636A1.636 1.636 0 0 1 0 19.366V5.457c0-2.023 2.309-3.178 3.927-1.964L5.455 4.64 12 9.548l6.545-4.91 1.528-1.145C21.69 2.28 24 3.434 24 5.457z"/></svg>
          <span class="lbl">Gmail</span>
        </a>
        <a class="mail-btn outlook" href="https://outlook.live.com/mail/0/inbox" target="_blank" rel="noopener">
          <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M7.88 12.04q0 .45-.11.87-.1.41-.33.74-.22.33-.58.52-.37.2-.87.2t-.85-.2q-.35-.21-.57-.55-.22-.33-.33-.75-.1-.42-.1-.86t.1-.87q.1-.43.34-.76.22-.34.59-.54.36-.2.87-.2t.86.2q.35.21.57.55.22.34.31.77.1.43.1.88zM24 12v9.38q0 .46-.33.8-.33.32-.8.32H7.13q-.46 0-.8-.33-.32-.33-.32-.8V18H1q-.41 0-.7-.3-.3-.29-.3-.7V7q0-.41.3-.7Q.58 6 1 6h6.5V2.55q0-.44.3-.75.3-.3.75-.3h12.9q.44 0 .75.3.3.3.3.75V10.85l1.24.72h.01q.1.07.18.18.07.12.07.25zm-6-8.25v3h3v-3zm0 4.5v3h3v-3zm0 4.5v1.83l3.05-1.83zm-5.25-9v3h3.75v-3zm0 4.5v3h3.75v-3zm0 4.5v2.03l2.41 1.5 1.34-.8v-2.73zM9 3.75V6h2l.13.01.12.04v-2.3zM5.98 15.98q.9 0 1.6-.3.7-.32 1.19-.86.48-.55.73-1.28.25-.74.25-1.61 0-.83-.25-1.55-.24-.71-.71-1.24t-1.15-.83q-.68-.3-1.55-.3-.92 0-1.64.3-.71.3-1.2.85-.5.54-.75 1.3-.25.74-.25 1.63 0 .85.26 1.56.26.72.74 1.23.48.52 1.17.81.69.3 1.56.3z"/></svg>
          <span class="lbl">Outlook</span>
        </a>
        <a class="mail-btn yahoo" href="https://mail.yahoo.com/" target="_blank" rel="noopener">
          <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M18.86 1.56L14.27 11.87H19.4L24 1.56H18.86M0 6.71L5.15 18.27L3.3 22.44H7.83L14.69 6.71H10.19L7.39 13.44L4.62 6.71H0M15.62 12.87C13.95 12.87 12.71 14.12 12.71 15.58C12.71 17 13.91 18.19 15.5 18.19C17.18 18.19 18.43 16.96 18.43 15.5C18.43 14.03 17.23 12.87 15.62 12.87Z"/></svg>
          <span class="lbl">Yahoo</span>
        </a>
      </div>

      <p class="micro muted">
        Nothing yet? Check spam / promotions. Install help on the
        <a href="/support">support page</a>; problems &rarr;
        <a href="mailto:support@revaudio.net">support@revaudio.net</a>.
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  .thankyou .tag {
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.18em;
    font-size: 0.72rem;
    color: var(--brass);
    margin: 0 0 0.5rem;
  }

  .quick-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.7rem;
    margin-bottom: 1.5rem;
  }

  /* Brass-plate mail buttons (Higgsfield plate + native-colour logos) */
  .mail-btn {
    --accent: var(--brass);
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.6rem 1.05rem;
    border-radius: 9px;
    background-image: url('/plate/mail-plate-b.png');
    background-size: cover;
    background-position: center;
    color: #2a1f0e;
    text-decoration: none;
    font-family: var(--font-display);
    font-size: 1.05rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    line-height: 1;
    border: 1px solid rgba(0, 0, 0, 0.4);
    box-shadow:
      0 3px 0 rgba(0, 0, 0, 0.45),
      0 5px 10px rgba(0, 0, 0, 0.4),
      inset 0 1px 0 rgba(255, 255, 255, 0.25),
      inset 0 -3px 0 var(--accent);
    transition: filter 0.18s var(--ease), transform 0.1s var(--ease),
      box-shadow 0.1s var(--ease);
  }
  .mail-btn .lbl {
    padding-top: 0.14em;
    text-shadow: 0 1px 0 rgba(255, 255, 255, 0.28);
  }
  .mail-btn svg {
    width: 1.15em;
    height: 1.15em;
    display: block;
    flex: none;
    fill: var(--accent);
    filter: drop-shadow(0 1px 1px rgba(0, 0, 0, 0.3));
  }
  .mail-btn:hover { filter: brightness(1.08) saturate(1.05); }
  .mail-btn:active {
    transform: translateY(2px);
    box-shadow:
      0 1px 0 rgba(0, 0, 0, 0.45),
      0 2px 5px rgba(0, 0, 0, 0.4),
      inset 0 1px 0 rgba(255, 255, 255, 0.2),
      inset 0 -3px 0 var(--accent);
  }
  .mail-btn.gmail { --accent: #ea4335; }
  .mail-btn.outlook { --accent: #0078d4; }
  .mail-btn.yahoo { --accent: #6001d2; }
</style>
