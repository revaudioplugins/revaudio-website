---
import BaseLayout from '../layouts/BaseLayout.astro';
import PrivacyContent from '../components/legal/PrivacyContent.astro';
/*
 * Privacy Policy. Body lives in the shared <PrivacyContent> so the page and the
 * checkout legal-reader modal (Cart.astro) render one source of truth.
 * Data controller = RevAudio, Yehudit Boulevard 8, Tel Aviv 67016, Israel
 * (GDPR Art. 13). Legal form still generic — confirm with counsel before reliance.
 */
---

<BaseLayout
  title="Privacy Policy"
  description="How RevAudio collects, uses, and protects your personal data — email, orders, licences, and cookieless analytics."
>
  <section class="plugin-detail">
    <div class="container" style="max-width: 760px;">
      <h1>Privacy Policy</h1>
      <PrivacyContent />
    </div>
  </section>
</BaseLayout>
