---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contact"
  description="Get in touch with RevAudio — press, partnership, or support."
>
  <section class="plugin-detail">
    <div class="container">
      <h1>Get in touch</h1>
      <p class="pitch">
        For press, partnership, demo requests, or just a hello.
      </p>

      <div style="margin-top: 3rem;">
        <div class="spec-row"><span class="key">Email</span><span class="val"><a href="mailto:hello@revaudio.net">hello@revaudio.net</a></span></div>
        <div class="spec-row"><span class="key">GitHub</span><span class="val"><a href="https://github.com/Revaudio" target="_blank" rel="noopener">github.com/Revaudio</a></span></div>
        <div class="spec-row"><span class="key">Instagram</span><span class="val"><a href="https://instagram.com/revaudio" target="_blank" rel="noopener">@revaudio</a></span></div>
        <div class="spec-row"><span class="key">YouTube</span><span class="val"><a href="https://youtube.com/@revaudio" target="_blank" rel="noopener">@revaudio</a></span></div>
      </div>

      <p class="muted" style="margin-top: 3rem; font-size: 0.85rem;">
        Social handles are placeholders &mdash; some may not be claimed yet. Update <code>src/pages/contact.astro</code> once you reserve them.
      </p>
    </div>
  </section>
</BaseLayout>
